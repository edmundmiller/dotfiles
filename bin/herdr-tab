#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
"""Cycle Herdr tabs within the active workspace."""

from __future__ import annotations

import argparse
import json
import os
from pathlib import Path
import shutil
import subprocess
import sys
from typing import Any, NoReturn

PROG = "herdr-tab"


def die(message: str, code: int = 1) -> NoReturn:
    print(f"{PROG}: {message}", file=sys.stderr)
    raise SystemExit(code)


def herdr_bin() -> str:
    configured = os.environ.get("HERDR_BIN_PATH", "herdr")
    return configured if shutil.which(configured) else "herdr"


def run_json(herdr: str, *args: str) -> dict[str, Any]:
    try:
        result = subprocess.run(
            [herdr, *args],
            check=True,
            text=True,
            stdout=subprocess.PIPE,
        )
    except FileNotFoundError:
        die(f"Herdr binary not found: {herdr}", 127)
    except subprocess.CalledProcessError as exc:
        raise SystemExit(exc.returncode)
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError as exc:
        die(f"invalid JSON from `{' '.join([herdr, *args])}`: {exc}")


def focused_workspace_id(herdr: str) -> str:
    env_workspace = os.environ.get("HERDR_ACTIVE_WORKSPACE_ID", "")
    if env_workspace:
        return env_workspace
    payload = run_json(herdr, "workspace", "list")
    workspaces = payload.get("result", {}).get("workspaces", [])
    focused = next((ws for ws in workspaces if ws.get("focused")), None)
    return str(focused.get("workspace_id", "")) if focused else ""


def target_tab_id(payload: dict[str, Any], workspace_id: str, direction: str) -> str:
    tabs = [
        tab
        for tab in payload.get("result", {}).get("tabs", [])
        if tab.get("workspace_id") == workspace_id
    ]
    tabs.sort(key=lambda tab: tab.get("number", 0))
    if not tabs:
        die("no tabs found in active workspace")
    focused_index = next((i for i, tab in enumerate(tabs) if tab.get("focused")), 0)
    offset = -1 if direction == "previous" else 1
    return str(tabs[(focused_index + offset) % len(tabs)]["tab_id"])


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(prog=PROG, usage="%(prog)s previous|next")
    parser.add_argument("direction", choices=("previous", "next"))
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    herdr = herdr_bin()
    workspace_id = focused_workspace_id(herdr)
    if not workspace_id:
        die("could not determine active workspace")
    tab_id = target_tab_id(run_json(herdr, "tab", "list"), workspace_id, args.direction)
    os.execvp(herdr, [herdr, "tab", "focus", tab_id])


def _sample_tab_payload() -> dict[str, Any]:
    return {
        "result": {
            "tabs": [
                {"tab_id": "t1", "workspace_id": "w1", "number": 1, "focused": False},
                {"tab_id": "t2", "workspace_id": "w1", "number": 2, "focused": True},
                {"tab_id": "t3", "workspace_id": "w1", "number": 3, "focused": False},
                {"tab_id": "other", "workspace_id": "w2", "number": 1, "focused": True},
            ]
        }
    }


def test_target_tab_id_cycles_next() -> None:
    assert target_tab_id(_sample_tab_payload(), "w1", "next") == "t3"


def test_target_tab_id_cycles_previous() -> None:
    assert target_tab_id(_sample_tab_payload(), "w1", "previous") == "t1"


def test_target_tab_id_wraps() -> None:
    payload = _sample_tab_payload()
    for tab in payload["result"]["tabs"]:
        tab["focused"] = tab["tab_id"] == "t3"
    assert target_tab_id(payload, "w1", "next") == "t1"


def test_focused_workspace_prefers_environment(monkeypatch) -> None:
    monkeypatch.setenv("HERDR_ACTIVE_WORKSPACE_ID", "from-env")
    assert focused_workspace_id("missing-herdr") == "from-env"


def run_self_test() -> int:
    import shutil
    import tempfile

    try:
        import pytest
    except ImportError:
        eprint = getattr(sys.modules[__name__], "eprint", None)
        message = (
            f"{PROG}: pytest is required for --self-test; run via "
            f"`uv run --with pytest --script {Path(__file__).name} --self-test`"
        )
        if eprint:
            eprint(message.removeprefix(f"{PROG}: "))
        else:
            print(message, file=sys.stderr)
        return 1

    with tempfile.TemporaryDirectory(prefix=f"{PROG}-self-test-") as tempdir:
        test_file = Path(tempdir) / f"{PROG}.py"
        shutil.copy2(__file__, test_file)
        return pytest.main([str(test_file)])


if __name__ == "__main__":
    if "--self-test" in sys.argv[1:]:
        raise SystemExit(run_self_test())
    main()
