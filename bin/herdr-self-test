#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
"""Run the maintained dotfiles Herdr integration tests."""

from __future__ import annotations

from pathlib import Path
import subprocess
import sys


CHECKS = (
    (
        "agent automation",
        [
            "python3",
            "-m",
            "unittest",
            "tests.test_herdr_agent_automation",
            "tests.test_herdr_config_bootstrap",
        ],
    ),
    (
        "dev-layout plugin",
        [
            "python3",
            "-m",
            "unittest",
            "packages/herdr-plugins/dotfiles-dev-layout/dev_layout_test.py",
        ],
    ),
    (
        "agent-read plugin",
        [
            "python3",
            "-m",
            "unittest",
            "packages/herdr-plugins/dotfiles-agent-read-command/agent_read_command_test.py",
        ],
    ),
    (
        "Pi integrations",
        [
            "bun",
            "test",
            "packages/pi-packages/pi-herdr/extensions/herdr.test.ts",
            "packages/pi-packages/pi-hunk/extensions/hunk.test.ts",
        ],
    ),
)


def main() -> int:
    root = Path(__file__).resolve().parent.parent
    failures: list[str] = []
    for label, command in CHECKS:
        print(f"==> {label}", flush=True)
        result = subprocess.run(command, cwd=root, check=False)
        if result.returncode != 0:
            failures.append(label)
    if failures:
        print(f"herdr-self-test: failed: {', '.join(failures)}", file=sys.stderr)
        return 1
    print("herdr-self-test: all checks passed")
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
