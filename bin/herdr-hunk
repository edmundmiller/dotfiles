#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
"""Open Hunk in Herdr, mirroring the tmux open-hunk.sh workflow."""

from __future__ import annotations

import argparse
import json
import os
from pathlib import Path
import shlex
import shutil
import socket
import subprocess
import sys
from typing import Any, NoReturn

PROG = "herdr-hunk"


def eprint(message: str) -> None:
    print(f"{PROG}: {message}", file=sys.stderr)


def die(message: str, code: int = 1) -> NoReturn:
    eprint(message)
    raise SystemExit(code)


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        prog=PROG,
        usage="%(prog)s [--tab] [--staged|--cached|--branch-committed] [-- HUNK_ARGS...]",
        description="Open Hunk from the active Herdr context.",
        formatter_class=argparse.RawDescriptionHelpFormatter,
        add_help=False,
        epilog="""Default: split the active Herdr pane to the right, focus it, and run `hunk diff`.

Options:
  --tab               Open Hunk in a new focused Herdr tab instead of a right split
  --staged, --cached  Review staged changes
  --branch-committed  Review commits on the current branch against upstream/main/master
  -h, --help          Show this help
""",
    )
    # Keep Bash-compatible parsing: known helper flags are consumed, `--` stops
    # helper parsing, and every other token is passed through to `hunk diff`.
    placement = "pane"
    mode = "worktree"
    passthrough: list[str] = []
    argv = sys.argv[1:]
    while argv:
        token, *rest = argv
        if token == "--tab":
            placement = "tab"
            argv = rest
        elif token in ("--staged", "--cached"):
            mode = "staged"
            argv = rest
        elif token == "--branch-committed":
            mode = "branch-committed"
            argv = rest
        elif token in ("-h", "--help"):
            parser.print_help()
            raise SystemExit(0)
        elif token == "--":
            passthrough.extend(rest)
            break
        else:
            passthrough.append(token)
            argv = rest
    return argparse.Namespace(tab=placement == "tab", mode=mode, hunk_args=passthrough)


def herdr_bin() -> str:
    configured = os.environ.get("HERDR_BIN_PATH", "herdr")
    return configured if shutil.which(configured) else "herdr"


def run_json(command: list[str]) -> dict[str, Any]:
    try:
        result = subprocess.run(command, check=True, text=True, stdout=subprocess.PIPE)
    except FileNotFoundError:
        die(f"command not found: {command[0]}", 127)
    except subprocess.CalledProcessError as exc:
        raise SystemExit(exc.returncode)
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError as exc:
        die(f"invalid JSON from `{' '.join(command)}`: {exc}")


def run_capture(
    command: list[str], cwd: Path | None = None, check: bool = True
) -> subprocess.CompletedProcess[str]:
    return subprocess.run(
        command,
        cwd=cwd,
        check=check,
        text=True,
        stdout=subprocess.PIPE,
        stderr=subprocess.DEVNULL,
    )


def active_context(herdr: str) -> tuple[str, str, Path]:
    active_pane = os.environ.get("HERDR_ACTIVE_PANE_ID", "")
    active_workspace = os.environ.get("HERDR_ACTIVE_WORKSPACE_ID", "")
    start_cwd = Path(os.environ.get("HERDR_ACTIVE_PANE_CWD", os.getcwd()))
    if active_pane:
        return active_pane, active_workspace, start_cwd

    payload = run_json([herdr, "pane", "list"])
    panes = payload.get("result", {}).get("panes", [])
    focused = next((pane for pane in panes if pane.get("focused")), None)
    if not focused:
        die("could not determine the active Herdr pane")
    pane_cwd = focused.get("cwd") or str(start_cwd)
    return (
        str(focused.get("pane_id", "")),
        str(focused.get("workspace_id", "")),
        Path(pane_cwd),
    )


def git_root_from(start_cwd: Path) -> Path:
    if not start_cwd.is_dir():
        start_cwd = Path.cwd()
    try:
        run_capture(["git", "rev-parse", "--git-dir"], cwd=start_cwd)
    except (FileNotFoundError, subprocess.CalledProcessError):
        die(f"not in a git repo: {start_cwd}")

    resolver = (
        Path(os.environ.get("DOTFILES_BIN", str(Path.home() / ".config/dotfiles/bin")))
        / "git-worktree-cwd"
    )
    if not os.access(resolver, os.X_OK):
        resolver = Path.home() / ".config/dotfiles/bin/git-worktree-cwd"
    if os.access(resolver, os.X_OK):
        try:
            root = run_capture([str(resolver), "."], cwd=start_cwd).stdout.strip()
        except subprocess.CalledProcessError:
            die(f"not in a usable checkout: {start_cwd}")
    else:
        root = run_capture(
            ["git", "rev-parse", "--show-toplevel"], cwd=start_cwd
        ).stdout.strip()
    if not root:
        die(f"not in a git repo: {start_cwd}")
    return Path(root)


def review_args(mode: str, passthrough: list[str], git_root: Path) -> list[str]:
    args = ["diff"]
    if mode == "staged":
        args.append("--staged")
    elif mode == "branch-committed":
        base_ref = ""
        upstream = run_capture(
            ["git", "rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{upstream}"],
            cwd=git_root,
            check=False,
        )
        if upstream.returncode == 0:
            base_ref = upstream.stdout.strip()
        else:
            for candidate in ("origin/main", "origin/master", "main", "master"):
                if (
                    run_capture(
                        ["git", "rev-parse", "--verify", candidate],
                        cwd=git_root,
                        check=False,
                    ).returncode
                    == 0
                ):
                    base_ref = candidate
                    break
        if base_ref:
            merge_base = run_capture(
                ["git", "merge-base", "HEAD", base_ref], cwd=git_root, check=False
            ).stdout.strip()
            args.append(f"{merge_base}...HEAD" if merge_base else "HEAD")
        else:
            args.append("HEAD")
    args.extend(passthrough)
    return args


def hunk_command() -> str:
    if shutil.which("hunk"):
        return "hunk"
    if shutil.which("bunx"):
        return "bunx hunkdiff"
    die("neither hunk nor bunx is available on PATH")


def socket_path() -> Path:
    explicit = os.environ.get("HERDR_SOCKET_PATH")
    if explicit:
        return Path(explicit)
    config_home = Path(os.environ.get("XDG_CONFIG_HOME", Path.home() / ".config"))
    session = os.environ.get("HERDR_SESSION")
    if session and session != "default":
        return config_home / "herdr" / "sessions" / session / "herdr.sock"
    return config_home / "herdr" / "herdr.sock"


def herdr_socket_request(method: str, params: dict[str, Any]) -> dict[str, Any]:
    request = {"id": f"{PROG}:{method}", "method": method, "params": params}
    try:
        with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
            client.connect(str(socket_path()))
            client.sendall((json.dumps(request) + "\n").encode())
            chunks: list[bytes] = []
            while True:
                chunk = client.recv(4096)
                if not chunk:
                    break
                chunks.append(chunk)
                if b"\n" in chunk:
                    break
    except OSError as exc:
        die(f"Herdr socket request failed: {exc}")
    payload = json.loads(b"".join(chunks).split(b"\n", 1)[0].decode())
    if "error" in payload:
        error = payload["error"]
        die(f"{error.get('code', 'error')}: {error.get('message', error)}")
    return payload


def find_pane_id(value: Any) -> str | None:
    if isinstance(value, dict):
        pane_id = value.get("pane_id")
        if isinstance(pane_id, str):
            return pane_id
        for child in value.values():
            if found := find_pane_id(child):
                return found
    elif isinstance(value, list):
        for child in value:
            if found := find_pane_id(child):
                return found
    return None


def shell_command(git_root: Path, review: list[str]) -> str:
    return " ".join(
        [
            "cd",
            shlex.quote(str(git_root)),
            "&&",
            hunk_command(),
            *(shlex.quote(arg) for arg in review),
        ]
    )


def main() -> None:
    args = parse_args()
    herdr = herdr_bin()
    active_pane, active_workspace, start_cwd = active_context(herdr)
    if not active_pane:
        die("could not determine the active Herdr pane")
    git_root = git_root_from(start_cwd)
    command = shell_command(git_root, review_args(args.mode, args.hunk_args, git_root))

    if args.tab:
        params: dict[str, Any] = {"cwd": str(git_root), "label": "hunk", "focus": True}
        if active_workspace:
            params["workspace_id"] = active_workspace
        response = herdr_socket_request("tab.create", params)
    else:
        response = herdr_socket_request(
            "pane.split",
            {
                "target_pane_id": active_pane,
                "direction": "right",
                "cwd": str(git_root),
                "focus": True,
            },
        )
    target_pane = find_pane_id(response)
    if not target_pane:
        die("no pane_id in herdr response")
    subprocess.run([herdr, "pane", "run", target_pane, command], check=True)


if __name__ == "__main__":
    main()
