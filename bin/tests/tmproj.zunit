#!/usr/bin/env zunit

# Tests for tmproj canonical tmux attach/create helper.

@setup {
  local tmp_dir
  tmp_dir=$(mktemp -d)
  export TEST_DIR=$(cd "$tmp_dir" && pwd -P)
  export ORIG_PWD=$PWD
  export BASH_PATH=$(command -v bash)
  export SCRIPT="$ORIG_PWD/bin/tmproj"

  export REPO_DIR="$TEST_DIR/source"
  export HUB_DIR="$TEST_DIR/hub"
  export MOCK_BIN="$TEST_DIR/mock-bin"
  export MOCK_TMUX_LOG="$TEST_DIR/tmux.log"

  mkdir -p "$REPO_DIR/app/src" "$HUB_DIR" "$MOCK_BIN"
  : > "$MOCK_TMUX_LOG"

  cd "$REPO_DIR"
  git init --quiet --initial-branch=main
  git config user.email "test@test.com"
  git config user.name "Test"
  echo "hi" > README.md
  echo "nested" > app/src/main.txt
  git add README.md app/src/main.txt
  git commit --quiet -m "init"

  # Build bare-hub layout: hub/.git (bare) + hub/main worktree.
  git clone --quiet --bare "$REPO_DIR" "$HUB_DIR/.bare"
  mv "$HUB_DIR/.bare" "$HUB_DIR/.git"
  git -C "$HUB_DIR/.git" config remote.origin.fetch "+refs/heads/*:refs/remotes/origin/*"
  git -C "$HUB_DIR/.git" fetch --quiet origin
  git -C "$HUB_DIR/.git" worktree add --quiet "$HUB_DIR/main" main

  cat > "$MOCK_BIN/tmux" <<'MOCK'
#!__BASH_PATH__
set -euo pipefail
printf '%s\n' "$*" >> "$MOCK_TMUX_LOG"

case "${1:-}" in
  has-session)
    if [[ "${MOCK_TMUX_HAS_SESSION:-0}" == "1" ]]; then
      exit 0
    fi
    exit 1
    ;;
  attach-session|switch-client|new-session)
    exit 0
    ;;
  *)
    echo "unexpected tmux command: $*" >&2
    exit 64
    ;;
esac
MOCK
  perl -0pi -e 's|__BASH_PATH__|$ENV{BASH_PATH}|g' "$MOCK_BIN/tmux"
  chmod +x "$MOCK_BIN/tmux"
}

@teardown {
  cd "$ORIG_PWD"
  rm -rf "$TEST_DIR"
}

@test 'attaches existing session outside tmux using canonical project name' {
  run env -u TMUX PATH="$MOCK_BIN:$PATH" MOCK_TMUX_LOG="$MOCK_TMUX_LOG" MOCK_TMUX_HAS_SESSION=1 "$SCRIPT" "$REPO_DIR/app/src"

  assert $state equals 0
  actual=$(cat "$MOCK_TMUX_LOG")
  assert "$actual" contains "has-session -t source"
  assert "$actual" contains "attach-session -t source"
}

@test 'switches existing session when already inside tmux' {
  run env PATH="$MOCK_BIN:$PATH" MOCK_TMUX_LOG="$MOCK_TMUX_LOG" MOCK_TMUX_HAS_SESSION=1 TMUX=1 "$SCRIPT" "$REPO_DIR/app/src"

  assert $state equals 0
  actual=$(cat "$MOCK_TMUX_LOG")
  assert "$actual" contains "has-session -t source"
  assert "$actual" contains "switch-client -t source"
}

@test 'creates missing session at checkout root and attaches outside tmux' {
  run env -u TMUX PATH="$MOCK_BIN:$PATH" MOCK_TMUX_LOG="$MOCK_TMUX_LOG" MOCK_TMUX_HAS_SESSION=0 "$SCRIPT" "$REPO_DIR/app/src"

  assert $state equals 0
  actual=$(cat "$MOCK_TMUX_LOG")
  assert "$actual" contains "has-session -t source"
  assert "$actual" contains "new-session -d -s source -c $REPO_DIR"
  assert "$actual" contains "attach-session -t source"
}

@test 'creates missing session from bare hub at resolved worktree and switches inside tmux' {
  run env PATH="$MOCK_BIN:$PATH" MOCK_TMUX_LOG="$MOCK_TMUX_LOG" MOCK_TMUX_HAS_SESSION=0 TMUX=1 "$SCRIPT" "$HUB_DIR"

  assert $state equals 0
  actual=$(cat "$MOCK_TMUX_LOG")
  assert "$actual" contains "has-session -t main"
  assert "$actual" contains "new-session -d -s main -c $HUB_DIR/main"
  assert "$actual" contains "switch-client -t main"
}
