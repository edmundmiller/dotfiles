#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"

usage() {
  cat <<'EOF'
Usage: bin/qa-changed [options]

Run pi-packages quality checks (typecheck + package tests) on changed packages.

Options:
  --base-ref <ref>     Base git ref for changed-file detection
  --head-ref <ref>     Head git ref (default: HEAD)
  --package <name>     Check a specific package (repeatable, e.g. pi-dcp)
  --all                Check all pi-* packages
  -h, --help           Show this help
EOF
}

base_ref=""
head_ref="HEAD"
run_all=0
packages=()

while [[ $# -gt 0 ]]; do
  case "$1" in
    --base-ref)
      base_ref="${2:-}"
      shift 2
      ;;
    --head-ref)
      head_ref="${2:-}"
      shift 2
      ;;
    --package)
      packages+=("${2:-}")
      shift 2
      ;;
    --all)
      run_all=1
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "error: unknown arg: $1" >&2
      usage >&2
      exit 2
      ;;
  esac
done

if [[ ${#packages[@]} -eq 0 && $run_all -eq 0 ]]; then
  if [[ -z "$base_ref" ]]; then
    if upstream_ref=$(git -C "$ROOT_DIR" rev-parse --abbrev-ref --symbolic-full-name '@{upstream}' 2>/dev/null); then
      base_ref="$upstream_ref"
    elif git -C "$ROOT_DIR" rev-parse --verify origin/main >/dev/null 2>&1; then
      base_ref="origin/main"
    elif git -C "$ROOT_DIR" rev-parse --verify HEAD~1 >/dev/null 2>&1; then
      base_ref="HEAD~1"
    else
      base_ref="HEAD"
    fi
  fi

  range="$base_ref...$head_ref"
  mapfile -t changed_files < <(git -C "$ROOT_DIR" diff --name-only "$range" -- 'pi-packages/**')

  for file in "${changed_files[@]}"; do
    if [[ "$file" =~ ^pi-packages/(pi-[^/]+)/ ]]; then
      packages+=("${BASH_REMATCH[1]}")
    fi
  done
else
  mapfile -t changed_files < <(git -C "$ROOT_DIR" diff --name-only "${base_ref:-HEAD~1}...$head_ref" -- 'pi-packages/**' 2>/dev/null || true)
fi

if [[ $run_all -eq 1 ]]; then
  mapfile -t packages < <(find "$ROOT_DIR/pi-packages" -mindepth 1 -maxdepth 1 -type d -name 'pi-*' -exec basename {} \; | sort)
fi

if [[ ${#packages[@]} -eq 0 ]]; then
  echo "qa-changed: no pi-packages changes detected"
  exit 0
fi

mapfile -t packages < <(printf '%s\n' "${packages[@]}" | sed '/^$/d' | sort -u)

echo "qa-changed: checking packages: ${packages[*]}"

arch_files=()
for file in "${changed_files[@]}"; do
  if [[ -f "$ROOT_DIR/$file" && "$file" =~ ^pi-packages/pi-[^/]+/.*\.tsx?$ ]]; then
    arch_files+=("$file")
  fi
done

if [[ ${#arch_files[@]} -gt 0 ]]; then
  ./bin/lint-ts-architecture "${arch_files[@]}"
else
  echo "qa-changed: no changed TypeScript files for architecture lint"
fi

if ! command -v bun >/dev/null 2>&1; then
  echo "error: bun is required for qa-changed" >&2
  exit 1
fi

if ! command -v jq >/dev/null 2>&1; then
  echo "error: jq is required for qa-changed" >&2
  exit 1
fi

existing_packages=()
removed_packages=()
for pkg in "${packages[@]}"; do
  if [[ -f "$ROOT_DIR/pi-packages/$pkg/package.json" ]]; then
    existing_packages+=("$pkg")
  else
    removed_packages+=("$pkg")
  fi
done

if [[ ${#removed_packages[@]} -gt 0 ]]; then
  echo "qa-changed: skipping removed packages: ${removed_packages[*]}"
fi
packages=("${existing_packages[@]}")

run_integration=0
if [[ $run_all -eq 1 ]]; then
  run_integration=1
else
  for file in "${changed_files[@]}"; do
    if [[ "$file" == pi-packages/tests/* || "$file" == pi-packages/package.json ]]; then
      run_integration=1
      break
    fi
    if [[ "$file" == pi-packages/bun.lock && ${#packages[@]} -gt 0 ]]; then
      run_integration=1
      break
    fi
  done
fi

if [[ ${#packages[@]} -eq 0 && $run_integration -eq 0 ]]; then
  echo "qa-changed: no remaining packages or integration tests to check"
  exit 0
fi

echo "qa-changed: ensuring workspace deps are installed"
symlinked_node_modules=()
while IFS= read -r -d '' link_path; do
  link_target="$(readlink "$link_path")"
  symlinked_node_modules+=("$link_path=$link_target")
  rm -f "$link_path"
done < <(find "$ROOT_DIR/pi-packages" -mindepth 2 -maxdepth 2 -type l -name node_modules -print0)

restore_symlinked_node_modules() {
  local record link_path link_target
  for record in "${symlinked_node_modules[@]}"; do
    link_path="${record%%=*}"
    link_target="${record#*=}"
    rm -rf "$link_path"
    ln -s "$link_target" "$link_path"
  done
}
trap restore_symlinked_node_modules EXIT

(
  cd "$ROOT_DIR/pi-packages"
  bun install --frozen-lockfile --silent
)

has_script() {
  local pkg_json="$1/package.json"
  local script_name="$2"
  jq -e --arg script_name "$script_name" '.scripts[$script_name] != null' "$pkg_json" >/dev/null
}

for pkg in "${packages[@]}"; do
  pkg_dir="$ROOT_DIR/pi-packages/$pkg"

  if has_script "$pkg_dir" typecheck; then
    echo "qa-changed: $pkg -> typecheck"
    (cd "$pkg_dir" && bun run --silent typecheck)
  fi

  if has_script "$pkg_dir" test; then
    echo "qa-changed: $pkg -> test"
    (cd "$pkg_dir" && bun run --silent test)
  fi
done

if [[ $run_integration -eq 1 ]]; then
  echo "qa-changed: running pi-packages integration tests"
  (cd "$ROOT_DIR/pi-packages" && bun run --silent test:integration)
fi

echo "qa-changed: done"
