+          connectorId: "google",
+          id: "deterministic-1",
+        },
+      ],
+      sources: {},
+      version: 1,
+    })}\n`,
+  );
+  ingest.mockReset();
+  runOpenWikiAgent.mockReset();
+  vi.resetModules();
+});
+
+afterEach(async () => {
+  if (originalHome === undefined) delete process.env.HOME;
+  else process.env.HOME = originalHome;
+  await rm(home, { recursive: true, force: true });
+});
