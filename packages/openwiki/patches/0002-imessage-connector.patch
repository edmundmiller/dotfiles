index 0000000000000000000000000000000000000000..f85977f4dbdc36063a0fcd2d479cdb502a734490
--- /dev/null
+++ i/src/connectors/sources/imessage.ts
@@ -0,0 +1,587 @@
+import { execFile } from "node:child_process";
+import { basename } from "node:path";
+import { promisify } from "node:util";
+import {
+  createRunId,
+  readConnectorConfig,
+  readConnectorState,
+  updateStateWithRun,
+  writeConnectorState,
+  writeRawJson,
+} from "../io.js";
+import type {
+  ConnectorDefinition,
+  ConnectorIngestOptions,
+  ConnectorIngestResult,
+  ConnectorRuntime,
+  ConnectorState,
+} from "../types.js";
+
+const execFileAsync = promisify(execFile);
+const MAX_BUFFER_BYTES = 10 * 1024 * 1024;
+const MAX_WINDOW_HOURS = 168;
+
+export type IMessageConfig = {
+  enabled?: boolean;
+  chatIds?: number[];
+  participants?: string[];
+  windowHours?: number;
+  maxMessagesPerChat?: number;
+};
+
+type IMessageChat = {
+  guid: string;
+  id: number;
+  identifier: string;
+  isGroup: boolean;
+  participants: string[];
+};
+
+type IMessageRow = {
+  attachments?: unknown[];
+  chat_id: number;
+  created_at: string;
+  guid: string;
+  id: number;
+  is_from_me?: boolean;
+  reply_to_guid?: string;
+  sender?: string;
+  text: string;
+  thread_originator_guid?: string;
+};
+
+type NormalizedMessage = {
+  attachments: NormalizedAttachment[];
+  createdAt: string;
+  guid: string;
+  id: number;
+  isFromMe: boolean;
+  recipients: string[];
+  replyToGuid?: string;
+  sender: string;
+  text: string;
+  thread: IMessageChat;
+  threadOriginatorGuid?: string;
+};
+
+type NormalizedAttachment = {
+  byteSize?: number;
+  filename?: string;
+  isSticker?: boolean;
+  mimeType?: string;
+  missing?: boolean;
+  transferName?: string;
+  uti?: string;
+};
+
+const definition: ConnectorDefinition = {
+  backend: "local-cli",
+  description:
+    "Reads explicitly scoped local Messages conversations through imsg.",
+  displayName: "iMessage",
+  id: "imessage",
+  requiredEnv: [],
+  supportsAgenticDiscovery: false,
+};
+
+export function createIMessageConnector(): ConnectorRuntime {
+  return { ...definition, ingest };
+}
+
+async function ingest(
+  options: ConnectorIngestOptions = {},
+): Promise<ConnectorIngestResult> {
+  const runId = createRunId();
+  const config = normalizeConfig({
+    ...(await readConnectorConfig<IMessageConfig>("imessage", {
+      enabled: true,
+      chatIds: [],
+      participants: [],
+      windowHours: options.windowHours ?? 24,
+      maxMessagesPerChat: 500,
+    })),
+    ...((options.connectorConfig ?? {}) as IMessageConfig),
+  });
+  const rawFiles: string[] = [];
+  const warnings: string[] = [];
+
+  if (!config.enabled) {
+    return result(
+      runId,
+      "skipped",
+      rawFiles,
+      warnings,
+      "iMessage connector is disabled.",
+    );
+  }
+
+  if (config.chatIds.length === 0 && config.participants.length === 0) {
+    return result(
+      runId,
+      "error",
+      rawFiles,
+      warnings,
+      "iMessage ingestion requires at least one chatIds or participants scope in ~/.openwiki/connectors/imessage/config.json.",
+    );
+  }
+
+  const state = await readConnectorState("imessage");
+  const end = new Date();
+  const start = new Date(end.getTime() - config.windowHours * 60 * 60 * 1000);
+  const previousRunAt = Date.parse(state.lastRunAt ?? "");
+  if (Number.isFinite(previousRunAt) && previousRunAt < start.getTime()) {
+    const requiredHours = Math.ceil(
+      (end.getTime() - previousRunAt) / (60 * 60 * 1000),
+    );
+    const message =
+      requiredHours > MAX_WINDOW_HOURS
+        ? `The previous successful iMessage ingest is ${requiredHours} hours old, but windowHours is capped at ${MAX_WINDOW_HOURS}. To recover the most recent ${MAX_WINDOW_HOURS} hours and deliberately accept the older gap, set windowHours=${MAX_WINDOW_HOURS}, move ~/.openwiki/connectors/imessage/state.json aside, and rerun.`
+        : `The previous successful iMessage ingest predates windowHours=${config.windowHours}; increase windowHours to at least ${requiredHours} to catch up without gaps.`;
+    return result(runId, "error", rawFiles, warnings, message);
+  }
+  let chats: IMessageChat[];
+
+  try {
+    chats = parseChats(await runImsg(["chats", "--limit", "10000", "--json"]));
+  } catch (error) {
+    return result(
+      runId,
+      "error",
+      rawFiles,
+      warnings,
+      mapImsgError(error, "chats"),
+    );
+  }
+
+  const selectedChats = chats.filter(
+    (chat) =>
+      (config.chatIds.length === 0 || config.chatIds.includes(chat.id)) &&
+      (config.participants.length === 0 ||
+        includesAllParticipants(chat.participants, config.participants)),
+  );
+
+  if (config.chatIds.length > 0) {
+    const matchedIds = new Set(selectedChats.map((chat) => chat.id));
+    const unmatchedIds = config.chatIds.filter((id) => !matchedIds.has(id));
+    if (unmatchedIds.length > 0 && selectedChats.length > 0) {
+      warnings.push(`Unmatched iMessage chat IDs: ${unmatchedIds.join(", ")}.`);
+    }
+  }
+
+  if (selectedChats.length === 0) {
+    return result(
+      runId,
+      "error",
+      rawFiles,
+      warnings,
+      "No iMessage chat matched the configured chatIds/participants scope.",
+    );
+  }
+
+  const rowsByChat = new Map<number, IMessageRow[]>();
+  for (const chat of selectedChats) {
+    let rows: IMessageRow[];
+    try {
+      rows = parseMessages(
+        await runImsg([
+          "history",
+          "--chat-id",
+          String(chat.id),
+          "--limit",
+          String(config.maxMessagesPerChat),
+          "--attachments",
+          "--start",
+          start.toISOString(),
+          "--end",
+          end.toISOString(),
+          "--json",
+        ]),
+      );
+    } catch (error) {
+      return result(
+        runId,
+        "error",
+        rawFiles,
+        warnings,
+        mapImsgError(error, "history", chat.id),
+      );
+    }
+
+    const cursor = readCursor(state, chat.id);
+    if (
+      rows.length === config.maxMessagesPerChat &&
+      rows.some((row) => row.id > cursor)
+    ) {
+      return result(
+        runId,
+        "error",
+        rawFiles,
+        warnings,
+        `iMessage history reached maxMessagesPerChat=${config.maxMessagesPerChat} for chat ${chat.id}; increase the limit or narrow the time window.`,
+      );
+    }
+    rowsByChat.set(
+      chat.id,
+      rows.filter((row) => row.id > cursor),
+    );
+  }
+
+  const messages = deduplicateAndSort(selectedChats, rowsByChat);
+  if (messages.length === 0) {
+    const nextState = updateStateWithRun(state, {
+      at: end.toISOString(),
+      rawFiles,
+      runId,
+      status: "skipped",
+      warnings,
+    });
+    await writeConnectorState("imessage", nextState);
+    return result(
+      runId,
+      "skipped",
+      rawFiles,
+      warnings,
+      "No new iMessage messages in the configured scope.",
+    );
+  }
+
+  const nextCursors = getNextCursors(state, selectedChats, rowsByChat);
+  const messagesPath = await writeRawJson("imessage", runId, "messages.json", {
+    schemaVersion: 1,
+    messages,
+  });
+  const manifestPath = await writeRawJson("imessage", runId, "manifest.json", {
+    schemaVersion: 1,
+    connectorId: "imessage",
+    generatedAt: end.toISOString(),
+    window: {
+      start: start.toISOString(),
+      end: end.toISOString(),
+      hours: config.windowHours,
+    },
+    scope: {
+      chatIds: config.chatIds,
+      participants: config.participants,
+    },
+    threads: selectedChats.map((chat) => ({
+      id: chat.id,
+      identifier: chat.identifier,
+      guid: chat.guid,
+      messageCount: messages.filter((message) => message.thread.id === chat.id)
+        .length,
+      cursorBefore: state.latestIds?.[`chat:${chat.id}`] ?? null,
+      cursorAfter:
+        nextCursors[`chat:${chat.id}`] ??
+        state.latestIds?.[`chat:${chat.id}`] ??
+        null,
+    })),
+    messageCount: messages.length,
+    dataFiles: ["messages.json"],
+  });
+  rawFiles.push(messagesPath, manifestPath);
+
+  const nextState = updateStateWithRun(state, {
+    at: end.toISOString(),
+    rawFiles,
+    runId,
+    status: "success",
+    warnings,
+  });
+  nextState.latestIds = { ...(state.latestIds ?? {}), ...nextCursors };
+  await writeConnectorState("imessage", nextState);
+
+  return result(
+    runId,
+    "success",
+    rawFiles,
+    warnings,
+    `Wrote ${messages.length} iMessage message(s).`,
+  );
+}
+
+function normalizeConfig(config: IMessageConfig): Required<IMessageConfig> {
+  return {
+    enabled: config.enabled !== false,
+    chatIds: uniquePositiveIntegers(config.chatIds),
+    participants: uniqueHandles(config.participants),
+    windowHours: clampInteger(config.windowHours, 1, MAX_WINDOW_HOURS, 24),
+    maxMessagesPerChat: clampInteger(config.maxMessagesPerChat, 1, 5000, 500),
+  };
+}
+
+function uniquePositiveIntegers(values: unknown): number[] {
+  if (!Array.isArray(values)) return [];
+  return [
+    ...new Set(
+      values.filter(
+        (value): value is number => Number.isInteger(value) && value > 0,
+      ),
+    ),
+  ];
+}
+
+function uniqueHandles(values: unknown): string[] {
+  if (!Array.isArray(values)) return [];
+  const handles = new Map<string, string>();
+  for (const value of values) {
+    if (typeof value !== "string" || value.trim().length === 0) continue;
+    const trimmed = value.trim();
+    const key = trimmed.toLocaleLowerCase("en-US");
+    if (!handles.has(key)) handles.set(key, trimmed);
+  }
+  return [...handles.values()];
+}
+
+function clampInteger(
+  value: number | undefined,
+  minimum: number,
+  maximum: number,
+  fallback: number,
+): number {
+  if (!Number.isFinite(value)) return fallback;
+  return Math.min(maximum, Math.max(minimum, Math.trunc(value!)));
+}
+
+async function runImsg(args: string[]): Promise<string> {
+  const { stdout } = await execFileAsync("imsg", args, {
+    maxBuffer: MAX_BUFFER_BYTES,
+  });
+  return String(stdout).trim();
+}
+
+function parseChats(output: string): IMessageChat[] {
+  return parseNdjson(output).flatMap((row) => {
+    const id = row.id;
+    if (typeof id !== "number" || !Number.isFinite(id)) return [];
+    return [
+      {
+        guid: typeof row.guid === "string" ? row.guid : "",
+        id,
+        identifier: typeof row.identifier === "string" ? row.identifier : "",
+        isGroup: row.is_group === true,
+        participants: uniqueHandles(row.participants),
+      },
+    ];
+  });
+}
+
+function parseMessages(output: string): IMessageRow[] {
+  return parseNdjson(output).map((row) => {
+    if (
+      typeof row.id !== "number" ||
+      !Number.isFinite(row.id) ||
+      typeof row.chat_id !== "number" ||
+      !Number.isFinite(row.chat_id) ||
+      typeof row.guid !== "string" ||
+      typeof row.created_at !== "string" ||
+      typeof row.text !== "string"
+    ) {
+      throw new Error("Invalid iMessage history row.");
+    }
+    return row as IMessageRow;
+  });
+}
+
+function parseNdjson(output: string): Record<string, unknown>[] {
+  if (!output) return [];
+  return output.split(/\r?\n/u).map((line) => {
+    const value: unknown = JSON.parse(line);
+    if (!value || typeof value !== "object" || Array.isArray(value)) {
+      throw new Error("Invalid iMessage NDJSON row.");
+    }
+    return value as Record<string, unknown>;
+  });
+}
+
+function includesAllParticipants(
+  chatParticipants: string[],
+  configuredParticipants: string[],
+): boolean {
+  const participants = new Set(
+    chatParticipants.map((value) => value.toLocaleLowerCase("en-US")),
+  );
+  return configuredParticipants.every((value) =>
+    participants.has(value.toLocaleLowerCase("en-US")),
+  );
+}
+
+function readCursor(state: ConnectorState, chatId: number): number {
+  const value = Number(state.latestIds?.[`chat:${chatId}`] ?? 0);
+  return Number.isSafeInteger(value) && value > 0 ? value : 0;
+}
+
+function deduplicateAndSort(
+  chats: IMessageChat[],
+  rowsByChat: Map<number, IMessageRow[]>,
+): NormalizedMessage[] {
+  const chatsById = new Map(chats.map((chat) => [chat.id, chat]));
+  const messages = new Map<string, NormalizedMessage>();
+  for (const rows of rowsByChat.values()) {
+    for (const row of rows) {
+      if (!messages.has(row.guid)) {
+        const chat = chatsById.get(row.chat_id);
+        if (!chat)
+          throw new Error(`Missing selected iMessage chat ${row.chat_id}.`);
+        messages.set(row.guid, normalizeMessage(row, chat));
+      }
+    }
+  }
+  return [...messages.values()].sort(
+    (left, right) =>
+      left.createdAt.localeCompare(right.createdAt) ||
+      left.thread.id - right.thread.id ||
+      left.id - right.id,
+  );
+}
+
+function normalizeMessage(
+  row: IMessageRow,
+  thread: IMessageChat,
+): NormalizedMessage {
+  const isFromMe = row.is_from_me === true;
+  const sender = isFromMe
+    ? "me"
+    : typeof row.sender === "string"
+      ? row.sender
+      : "";
+  const senderKey = sender.toLocaleLowerCase("en-US");
+  const recipients = isFromMe
+    ? thread.participants
+    : uniqueHandles([
+        "me",
+        ...thread.participants.filter(
+          (value) => value.toLocaleLowerCase("en-US") !== senderKey,
+        ),
+      ]);
+  return {
+    attachments: normalizeAttachments(row.attachments),
+    createdAt: row.created_at,
+    guid: row.guid,
+    id: row.id,
+    isFromMe,
+    recipients,
+    ...(typeof row.reply_to_guid === "string"
+      ? { replyToGuid: row.reply_to_guid }
+      : {}),
+    sender,
+    text: row.text,
+    thread,
+    ...(typeof row.thread_originator_guid === "string"
+      ? { threadOriginatorGuid: row.thread_originator_guid }
+      : {}),
+  };
+}
+
+function normalizeAttachments(values: unknown): NormalizedAttachment[] {
+  if (!Array.isArray(values)) return [];
+  return values.flatMap((value) => {
+    if (!value || typeof value !== "object" || Array.isArray(value)) return [];
+    const row = value as Record<string, unknown>;
+    const filename = stringValue(row.filename);
+    return [
+      withoutUndefined({
+        filename: filename ? basename(filename) : undefined,
+        transferName: stringValue(row.transfer_name),
+        uti: stringValue(row.uti),
+        mimeType: stringValue(row.mime_type),
+        byteSize: numberValue(row.byte_size),
+        isSticker: booleanValue(row.is_sticker),
+        missing: booleanValue(row.missing),
+      }),
+    ];
+  });
+}
+
+function withoutUndefined<T extends object>(value: T): T {
+  return Object.fromEntries(
+    Object.entries(value).filter(([, item]) => item !== undefined),
+  ) as T;
+}
+
+function stringValue(value: unknown): string | undefined {
+  return typeof value === "string" ? value : undefined;
+}
+
+function numberValue(value: unknown): number | undefined {
+  return typeof value === "number" && Number.isFinite(value)
+    ? value
+    : undefined;
+}
+
+function booleanValue(value: unknown): boolean | undefined {
+  return typeof value === "boolean" ? value : undefined;
+}
+
+function getNextCursors(
+  state: ConnectorState,
+  chats: IMessageChat[],
+  rowsByChat: Map<number, IMessageRow[]>,
+): Record<string, string> {
+  const cursors: Record<string, string> = {};
+  for (const chat of chats) {
+    const rows = rowsByChat.get(chat.id) ?? [];
+    const highest = rows.reduce((maximum, row) => Math.max(maximum, row.id), 0);
+    if (highest > readCursor(state, chat.id)) {
+      cursors[`chat:${chat.id}`] = String(highest);
+    }
+  }
+  return cursors;
+}
+
+function mapImsgError(
+  error: unknown,
+  operation: "chats" | "history",
+  chatId?: number,
+): string {
+  if (hasErrorCode(error, "ENOENT")) {
+    return "imsg is unavailable; install it and ensure it is on PATH.";
+  }
+  const stderr = getErrorStderr(error).toLocaleLowerCase("en-US");
+  if (
+    stderr.includes("unable to open database file") ||
+    stderr.includes("authorization denied")
+  ) {
+    return "imsg cannot read ~/Library/Messages/chat.db; grant Full Disk Access to the terminal or parent agent, then retry.";
+  }
+  if (operation === "chats" && !stderr) {
+    return "imsg chats failed without diagnostics; if running under launchd, grant Full Disk Access to the launcher's responsible interpreter (for a script, its shebang executable), then retry.";
+  }
+  return operation === "chats"
+    ? "imsg chats failed."
+    : `imsg history failed for chat ${chatId}.`;
+}
+
+function hasErrorCode(error: unknown, code: string): boolean {
+  return Boolean(
+    error &&
+    typeof error === "object" &&
+    "code" in error &&
+    (error as NodeJS.ErrnoException).code === code,
+  );
+}
+
+function getErrorStderr(error: unknown): string {
+  if (!error || typeof error !== "object" || !("stderr" in error)) return "";
+  const stderr = (error as { stderr?: unknown }).stderr;
+  return typeof stderr === "string" || Buffer.isBuffer(stderr)
+    ? String(stderr)
+    : "";
+}
+
+function result(
+  runId: string,
+  status: ConnectorIngestResult["status"],
+  rawFiles: string[],
+  warnings: string[],
+  message: string,
+): ConnectorIngestResult {
+  return {
+    connectorId: "imessage",
+    message,
+    rawFiles,
+    runId,
+    statePath: "~/.openwiki/connectors/imessage/state.json",
+    status,
+    warnings,
+  };
+}
