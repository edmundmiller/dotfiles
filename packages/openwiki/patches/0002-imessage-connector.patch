+const originalHome = process.env.HOME;
+let home: string;
+
+beforeEach(async () => {
+  home = await mkdtemp(path.join(os.tmpdir(), "openwiki-imessage-test-"));
+  process.env.HOME = home;
+  execFileSync("git", ["init", "-q", home]);
+  execFileAsync.mockReset();
+  vi.useFakeTimers();
+  vi.setSystemTime(new Date("2026-07-15T12:00:00.000Z"));
+  vi.resetModules();
+});
+
+afterEach(async () => {
+  vi.useRealTimers();
+  vi.restoreAllMocks();
+  if (originalHome === undefined) delete process.env.HOME;
+  else process.env.HOME = originalHome;
+  await rm(home, { recursive: true, force: true });
+});
+
+async function loadConnector() {
+  const { createIMessageConnector } =
+    await import("../src/connectors/sources/imessage.ts");
+  return createIMessageConnector();
+}
+
+function ndjson(rows: unknown[]): string {
+  return rows.map((row) => JSON.stringify(row)).join("\n");
+}
+
+function chat(
+  id: number,
+  participants: string[],
+  overrides: Record<string, unknown> = {},
+) {
+  return {
+    guid: `chat-guid-${id}`,
+    id,
+    identifier: `chat-${id}`,
+    is_group: participants.length > 1,
+    participants,
+    ...overrides,
+  };
+}
+
+function message(
+  id: number,
+  chatId: number,
+  createdAt: string,
+  overrides: Record<string, unknown> = {},
+) {
+  return {
+    attachments: [],
+    chat_id: chatId,
+    created_at: createdAt,
+    guid: `message-guid-${id}`,
+    id,
+    is_from_me: false,
+    sender: "alice@example.com",
+    text: `message ${id}`,
+    ...overrides,
+  };
+}
+
+function mockImsg(
+  chats: unknown[],
+  histories: Record<number, unknown[]>,
+): void {
+  execFileAsync.mockImplementation(
+    async (_file: string, args: string[], options: { maxBuffer: number }) => {
+      expect(options.maxBuffer).toBe(10 * 1024 * 1024);
+      if (args[0] === "chats") return { stdout: ndjson(chats), stderr: "" };
+      const chatId = Number(args[args.indexOf("--chat-id") + 1]);
+      return { stdout: ndjson(histories[chatId] ?? []), stderr: "" };
+    },
+  );
+}
+
+async function connectorState() {
+  return JSON.parse(
+    await readFile(
+      path.join(home, ".openwiki/connectors/imessage/state.json"),
+      "utf8",
+    ),
+  ) as { latestIds?: Record<string, string>; runs?: unknown[] };
+}
+
+describe("iMessage connector", () => {
