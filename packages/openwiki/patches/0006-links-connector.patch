diff --git a/src/connectors/sources/links.ts b/src/connectors/sources/links.ts
new file mode 100644
index 0000000..7cd5f1b
--- /dev/null
+++ b/src/connectors/sources/links.ts
@@ -0,0 +1,260 @@
+import { createHash } from "node:crypto";
+import {
+  createRunId,
+  readConnectorConfig,
+  readConnectorState,
+  updateStateWithRun,
+  writeConnectorState,
+  writeRawJson,
+} from "../io.js";
+import type {
+  ConnectorDefinition,
+  ConnectorIngestOptions,
+  ConnectorIngestResult,
+  ConnectorRuntime,
+} from "../types.js";
+
+type LinksConfig = {
+  links?: unknown[];
+};
+
+type LinkRecord = {
+  canonicalUrl: string;
+  capturedAt: string;
+  context?: string;
+  originalUrl: string;
+  source?: string;
+  sourceId: string;
+  title?: string;
+};
+
+const definition: ConnectorDefinition = {
+  backend: "local-file",
+  description:
+    "Reads a local queue of captured URLs and writes manifests for new or changed links.",
+  displayName: "Links",
+  id: "links",
+  requiredEnv: [],
+  supportsAgenticDiscovery: false,
+};
+
+const TRACKING_PARAMETER_NAMES = new Set([
+  "dclid",
+  "fbclid",
+  "gclid",
+  "mc_cid",
+  "mc_eid",
+  "msclkid",
+]);
+const SENSITIVE_PARAMETER_NAMES = new Set([
+  "access_token",
+  "api_key",
+  "apikey",
+  "auth",
+  "credential",
+  "key",
+  "password",
+  "secret",
+  "sig",
+  "signature",
+  "token",
+]);
+
+export function createLinksConnector(): ConnectorRuntime {
+  return {
+    ...definition,
+    ingest,
+  };
+}
+
+async function ingest(
+  options: ConnectorIngestOptions = {},
+): Promise<ConnectorIngestResult> {
+  const runId = createRunId();
+  const config = await readConnectorConfig<LinksConfig>("links", { links: [] });
+  const state = await readConnectorState("links");
+  const warnings: string[] = [];
+  const fileLinks = Array.isArray(config.links) ? config.links : [];
+  if (config.links !== undefined && !Array.isArray(config.links)) {
+    warnings.push("Ignored links config: links must be an array.");
+  }
+  const configuredLinks = [
+    ...getConfiguredLinks(options.connectorConfig),
+    ...fileLinks,
+  ];
+  const records = normalizeLinks(configuredLinks, warnings);
+  const fingerprints = Object.fromEntries(
+    records.map((record) => [record.sourceId, fingerprint(record)]),
+  );
+  const changedRecords = records.filter(
+    (record) =>
+      state.latestIds?.[record.sourceId] !== fingerprints[record.sourceId],
+  );
+  const rawFiles: string[] = [];
+
+  if (changedRecords.length > 0) {
+    rawFiles.push(
+      await writeRawJson("links", runId, "links.json", {
+        capturedAt: new Date().toISOString(),
+        links: changedRecords,
+      }),
+    );
+  }
+
+  const status = changedRecords.length > 0 ? "success" : "skipped";
+  const nextState = updateStateWithRun(state, {
+    at: new Date().toISOString(),
+    rawFiles,
+    runId,
+    status,
+    warnings,
+  });
+  nextState.latestIds = {
+    ...(state.latestIds ?? {}),
+    ...fingerprints,
+  };
+  await writeConnectorState("links", nextState);
+
+  return {
+    connectorId: "links",
+    message:
+      changedRecords.length > 0
+        ? `Wrote ${changedRecords.length} new or changed link(s).`
+        : configuredLinks.length === 0
+          ? "No links configured in ~/.openwiki/connectors/links/config.json."
+          : "No new or changed links.",
+    rawFiles,
+    runId,
+    statePath: "~/.openwiki/connectors/links/state.json",
+    status,
+    warnings,
+  };
+}
+
+function getConfiguredLinks(
+  connectorConfig: Record<string, unknown> | undefined,
+): unknown[] {
+  return Array.isArray(connectorConfig?.links) ? connectorConfig.links : [];
+}
+
+function normalizeLinks(values: unknown[], warnings: string[]): LinkRecord[] {
+  const records = new Map<string, LinkRecord>();
+
+  for (const [index, value] of values.entries()) {
+    const normalized = normalizeLink(value, index, warnings);
+    if (!normalized) {
+      continue;
+    }
+
+    const existing = records.get(normalized.canonicalUrl);
+    if (
+      !existing ||
+      Date.parse(normalized.capturedAt) >= Date.parse(existing.capturedAt)
+    ) {
+      records.set(normalized.canonicalUrl, normalized);
+    }
+  }
+
+  return [...records.values()].sort((left, right) =>
+    left.sourceId.localeCompare(right.sourceId),
+  );
+}
+
+function normalizeLink(
+  value: unknown,
+  index: number,
+  warnings: string[],
+): LinkRecord | null {
+  if (!isObject(value)) {
+    warnings.push(`Skipped link ${index + 1}: entry must be an object.`);
+    return null;
+  }
+
+  const originalUrl = getRequiredString(value.url);
+  const capturedAt = getRequiredString(value.capturedAt);
+  if (!originalUrl) {
+    warnings.push(`Skipped link ${index + 1}: url is required.`);
+    return null;
+  }
+  if (!capturedAt || !Number.isFinite(Date.parse(capturedAt))) {
+    warnings.push(
+      `Skipped link ${index + 1}: capture timestamp must be a valid date.`,
+    );
+    return null;
+  }
+
+  const canonicalUrl = canonicalizeUrl(originalUrl);
+  if (!canonicalUrl) {
+    warnings.push(
+      `Skipped link ${index + 1}: URL must use HTTP(S) without embedded credentials.`,
+    );
+    return null;
+  }
+
+  return {
+    canonicalUrl,
+    capturedAt,
+    ...getOptionalStringProperty(value, "context"),
+    originalUrl,
+    ...getOptionalStringProperty(value, "source"),
+    sourceId: `link-${sha256(canonicalUrl)}`,
+    ...getOptionalStringProperty(value, "title"),
+  };
+}
+
+function canonicalizeUrl(value: string): string | null {
+  try {
+    const url = new URL(value);
+    if (
+      (url.protocol !== "http:" && url.protocol !== "https:") ||
+      url.username.length > 0 ||
+      url.password.length > 0 ||
+      [...url.searchParams.keys()].some((name) =>
+        SENSITIVE_PARAMETER_NAMES.has(name.toLowerCase()),
+      )
+    ) {
+      return null;
+    }
+
+    url.hash = "";
+    for (const name of [...url.searchParams.keys()]) {
+      const normalizedName = name.toLowerCase();
+      if (
+        normalizedName.startsWith("utm_") ||
+        TRACKING_PARAMETER_NAMES.has(normalizedName)
+      ) {
+        url.searchParams.delete(name);
+      }
+    }
+    url.searchParams.sort();
+    return url.toString();
+  } catch {
+    return null;
+  }
+}
+
+function fingerprint(record: LinkRecord): string {
+  return sha256(JSON.stringify(record));
+}
+
+function sha256(value: string): string {
+  return createHash("sha256").update(value).digest("hex");
+}
+
+function getRequiredString(value: unknown): string | null {
+  return typeof value === "string" && value.trim().length > 0
+    ? value.trim()
+    : null;
+}
+
+function getOptionalStringProperty<K extends "context" | "source" | "title">(
+  value: Record<string, unknown>,
+  key: K,
+): Partial<Record<K, string>> {
+  const normalized = getRequiredString(value[key]);
+  return normalized ? ({ [key]: normalized } as Record<K, string>) : {};
+}
+
+function isObject(value: unknown): value is Record<string, unknown> {
+  return typeof value === "object" && value !== null && !Array.isArray(value);
+}
