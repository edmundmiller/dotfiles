+export function parseLinksInput(
+  value: string,
+): { urls: string[] } | { error: string } {
+  const urls = value.split(/\s+/u).filter(Boolean);
+  if (urls.length === 0) {
+    return { error: "Enter one or more HTTP(S) URLs." };
+  }
+  if (new Set(urls).size !== urls.length) {
+    return { error: "Remove duplicate URLs." };
+  }
+  for (const value of urls) {
+    try {
+      const url = new URL(value);
+      if (
+        (url.protocol !== "http:" && url.protocol !== "https:") ||
+        url.username.length > 0 ||
+        url.password.length > 0 ||
+        [...url.searchParams.keys()].some((name) =>
+          [
+            "access_token",
+            "api_key",
+            "apikey",
+            "auth",
+            "credential",
+            "key",
+            "password",
+            "secret",
+            "sig",
+            "signature",
+            "token",
+          ].includes(name.toLowerCase()),
+        )
+      ) {
+        return {
+          error: "Every link must use HTTP(S) without embedded credentials.",
+        };
+      }
+    } catch {
+      return { error: "Every link must be a valid HTTP(S) URL." };
+    }
+  }
+  return { urls };
+}
