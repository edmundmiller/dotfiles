+  stat,
+  writeFile,
+} from "node:fs/promises";
+import os from "node:os";
+import path from "node:path";
+import { afterEach, beforeEach, describe, expect, test, vi } from "vitest";
+
+const originalHome = process.env.HOME;
+let home: string;
+
+beforeEach(async () => {
+  home = await mkdtemp(path.join(os.tmpdir(), "openwiki-links-test-"));
+  process.env.HOME = home;
+  execFileSync("git", ["init", "-q", home]);
+  vi.useFakeTimers();
+  vi.setSystemTime(new Date("2026-07-18T12:00:00.000Z"));
+  vi.resetModules();
+});
+
+afterEach(async () => {
+  vi.useRealTimers();
+  if (originalHome === undefined) delete process.env.HOME;
+  else process.env.HOME = originalHome;
+  await rm(home, { recursive: true, force: true });
+});
+
+async function loadConnector() {
+  const { createLinksConnector } =
+    await import("../src/connectors/sources/links.ts");
+  return createLinksConnector();
+}
+
+async function writeConfig(links: unknown[]): Promise<void> {
+  const connectorDir = path.join(home, ".openwiki/connectors/links");
+  await import("node:fs/promises").then(({ mkdir }) =>
+    mkdir(connectorDir, { recursive: true }),
+  );
+  await writeFile(
+    path.join(connectorDir, "config.json"),
+    `${JSON.stringify({ links }, null, 2)}\n`,
+  );
+}
+
+async function readManifest(filePath: string) {
+  return JSON.parse(await readFile(filePath, "utf8")) as {
+    capturedAt: string;
+    links: Record<string, unknown>[];
+  };
+}
+
+describe("links connector", () => {
+  test("writes a canonical, allowlisted, deterministically sorted manifest", async () => {
+    await writeConfig([
+      {
+        capturedAt: "2026-07-17T10:00:00.000Z",
+        title: "Older title",
+        url: "HTTPS://Example.COM:443/article?b=2&utm_source=inbox&a=1#section",
+      },
+      {
+        capturedAt: "2026-07-18T10:00:00.000Z",
+        context: "Useful connector design reference.",
+        source: "reading-list",
+        title: "Canonical title",
+        unexpectedField: "excluded",
+        url: "https://example.com/article?a=1&b=2",
+      },
+      {
+        capturedAt: "2026-07-18T11:00:00.000Z",
+        url: "https://example.com/other",
+      },
+    ]);
+    const connector = await loadConnector();
+
+    const result = await connector.ingest();
+
+    expect(result).toMatchObject({ status: "success", warnings: [] });
+    expect(result.rawFiles).toHaveLength(1);
+    const manifest = await readManifest(result.rawFiles[0]);
+    expect(manifest).toMatchObject({
+      capturedAt: "2026-07-18T12:00:00.000Z",
+    });
+    expect(manifest.links).toHaveLength(2);
+    expect(manifest.links.map((link) => link.sourceId)).toEqual(
+      [...manifest.links.map((link) => link.sourceId)].sort(),
+    );
+    const canonicalRecord = manifest.links.find(
+      (link) => link.canonicalUrl === "https://example.com/article?a=1&b=2",
+    );
+    expect(canonicalRecord).toEqual({
+      canonicalUrl: "https://example.com/article?a=1&b=2",
+      capturedAt: "2026-07-18T10:00:00.000Z",
+      context: "Useful connector design reference.",
+      originalUrl: "https://example.com/article?a=1&b=2",
+      source: "reading-list",
+      sourceId: canonicalRecord?.sourceId,
+      title: "Canonical title",
+    });
+    expect(canonicalRecord?.sourceId).toMatch(/^link-[a-f0-9]{64}$/u);
+    expect(JSON.stringify(manifest)).not.toContain("unexpectedField");
+
+    const connectorDir = path.join(home, ".openwiki/connectors/links");
+    expect((await stat(connectorDir)).mode & 0o777).toBe(0o700);
+    expect((await stat(result.rawFiles[0])).mode & 0o777).toBe(0o600);
+    expect(
+      (await stat(path.join(connectorDir, "state.json"))).mode & 0o777,
+    ).toBe(0o600);
+    expect(await readFile(path.join(connectorDir, ".gitignore"), "utf8")).toBe(
+      "*\n!.gitignore\n",
+    );
+  });
+
+  test("is idempotent and emits only changed links with stable source IDs", async () => {
+    const initial = {
+      capturedAt: "2026-07-18T10:00:00.000Z",
+      title: "Initial title",
+      url: "https://example.com/article?utm_medium=email&a=1",
+    };
+    await writeConfig([initial]);
+    const connector = await loadConnector();
+
+    const first = await connector.ingest();
+    const firstManifest = await readManifest(first.rawFiles[0]);
+    const sourceId = firstManifest.links[0].sourceId;
+    const repeated = await connector.ingest();
+
+    expect(repeated).toMatchObject({
+      message: "No new or changed links.",
+      rawFiles: [],
+      status: "skipped",
+    });
+    expect(
+      await readdir(path.join(home, ".openwiki/connectors/links/raw")),
+    ).toHaveLength(1);
+
+    await writeConfig([{ ...initial, title: "Revised title" }]);
+    vi.setSystemTime(new Date("2026-07-18T12:00:01.000Z"));
+    const changed = await connector.ingest();
+    const changedManifest = await readManifest(changed.rawFiles[0]);
+
+    expect(changedManifest.links).toEqual([
+      expect.objectContaining({ sourceId, title: "Revised title" }),
+    ]);
+  });
+
+  test("rejects unsafe or incomplete entries without echoing input URLs", async () => {
+    await writeConfig([
+      {
+        capturedAt: "not-a-date",
+        url: "https://example.com/bad-date",
+      },
+      {
+        capturedAt: "2026-07-18T10:00:00.000Z",
+        url: "ftp://example.com/file",
+      },
+      {
+        capturedAt: "2026-07-18T10:00:00.000Z",
+        url: "https://user@example.com/private",
+      },
+      {
+        capturedAt: "2026-07-18T10:00:00.000Z",
+        url: "https://example.com/private?access_token=placeholder",
+      },
+    ]);
+    const connector = await loadConnector();
+
+    const result = await connector.ingest();
+
+    expect(result).toMatchObject({ rawFiles: [], status: "skipped" });
+    expect(result.warnings).toHaveLength(4);
+    expect(result.warnings.join(" ")).not.toContain("example.com");
+  });
+});
