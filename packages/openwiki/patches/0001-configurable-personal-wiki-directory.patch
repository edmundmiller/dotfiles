+export function resolveOpenWikiLocalWikiDir(
+  environment: NodeJS.ProcessEnv = process.env,
+): string {
+  const configuredPath = environment[OPENWIKI_WIKI_DIR_ENV_KEY];
+  if (!configuredPath) {
+    return path.join(openWikiHomeDir, "wiki");
+  }
+
+  if (!path.isAbsolute(configuredPath)) {
+    throw new Error(`${OPENWIKI_WIKI_DIR_ENV_KEY} must be an absolute path.`);
+  }
