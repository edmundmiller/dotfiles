+++ b/test/openwiki-home.test.ts
@@ -0,0 +1,44 @@
+import os from "node:os";
+import path from "node:path";
+import { describe, expect, it } from "vitest";
+
+import {
+  getOpenWikiLocalWikiDir,
+  resolveOpenWikiLocalWikiDir,
+} from "../src/openwiki-home.js";
+
+describe("resolveOpenWikiLocalWikiDir", () => {
+  it("defaults to the OpenWiki home wiki directory", () => {
+    expect(resolveOpenWikiLocalWikiDir({})).toBe(
+      path.join(os.homedir(), ".openwiki", "wiki"),
+    );
+  });
+
+  it("uses an absolute OPENWIKI_WIKI_DIR", () => {
+    expect(
+      resolveOpenWikiLocalWikiDir({
+        OPENWIKI_WIKI_DIR: "/vault/Knowledge/OpenWiki",
+      }),
+    ).toBe("/vault/Knowledge/OpenWiki");
+  });
+
+  it("reads OPENWIKI_WIKI_DIR at call time", () => {
+    const previous = process.env.OPENWIKI_WIKI_DIR;
+    process.env.OPENWIKI_WIKI_DIR = "/vault/after-env-load";
+    try {
+      expect(getOpenWikiLocalWikiDir()).toBe("/vault/after-env-load");
+    } finally {
+      if (previous === undefined) {
+        delete process.env.OPENWIKI_WIKI_DIR;
+      } else {
+        process.env.OPENWIKI_WIKI_DIR = previous;
+      }
+    }
+  });
+
+  it("rejects a relative OPENWIKI_WIKI_DIR", () => {
+    expect(() =>
+      resolveOpenWikiLocalWikiDir({ OPENWIKI_WIKI_DIR: "vault/wiki" }),
+    ).toThrow("OPENWIKI_WIKI_DIR must be an absolute path");
+  });
+});
