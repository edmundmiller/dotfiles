diff --git a/src/connectors/sources/rss.ts b/src/connectors/sources/rss.ts
new file mode 100644
index 0000000..e654e26
--- /dev/null
+++ b/src/connectors/sources/rss.ts
@@ -0,0 +1,656 @@
+import { createHash } from "node:crypto";
+import type { ReadableStream, ReadableStreamReadResult } from "node:stream/web";
+import { XMLParser } from "fast-xml-parser";
+import {
+  createRunId,
+  readConnectorConfig,
+  readConnectorState,
+  updateStateWithRun,
+  writeConnectorState,
+  writeRawJson,
+} from "../io.js";
+import type {
+  ConnectorDefinition,
+  ConnectorIngestOptions,
+  ConnectorIngestResult,
+  ConnectorRuntime,
+  ConnectorState,
+} from "../types.js";
+
+export type RssConfig = {
+  enabled?: boolean;
+  feedUrl?: string;
+  maxBytes?: number;
+  maxItems?: number;
+  timeoutMs?: number;
+};
+
+type RssEntryCursor = {
+  contentHash: string;
+  lastSeenAt: string;
+};
+
+type RssInstanceState = {
+  entries: Record<string, RssEntryCursor>;
+  etag?: string;
+  feedUrl: string;
+  lastModified?: string;
+  lastPublishedAt?: string;
+  lastSuccessAt: string;
+};
+
+type RssConnectorState = ConnectorState & {
+  rss?: {
+    instances: Record<string, RssInstanceState>;
+  };
+};
+
+type ParsedFeed = {
+  author: string | null;
+  entries: ParsedEntry[];
+  format: "atom" | "rss";
+  title: string | null;
+};
+
+type ParsedEntry = {
+  author: string | null;
+  content: string | null;
+  entryGuid: string | null;
+  entryUrl: string | null;
+  identity: string;
+  publishedAt: string | null;
+  title: string | null;
+};
+
+type EmittedEntry = ParsedEntry & {
+  capturedAt: string;
+  changeType: "changed" | "new";
+  feedUrl: string;
+  provenance: {
+    connectorId: "rss";
+    feedUrl: string;
+    sourceInstanceId: string;
+  };
+};
+
+const DEFAULT_MAX_BYTES = 2 * 1024 * 1024;
+const DEFAULT_MAX_ITEMS = 100;
+const DEFAULT_TIMEOUT_MS = 15_000;
+const MAX_MAX_BYTES = 10 * 1024 * 1024;
+const MAX_MAX_ITEMS = 500;
+const MAX_TIMEOUT_MS = 30_000;
+const MAX_STATE_ENTRIES = 5_000;
+const MIN_MAX_BYTES = 128;
+const MIN_TIMEOUT_MS = 100;
+const SECRET_QUERY_KEY =
+  /(?:^|[-_])(?:api[-_]?key|access[-_]?token|auth|authorization|credential|password|secret|signature|sig)(?:$|[-_])/iu;
+
+const definition: ConnectorDefinition = {
+  backend: "direct-api",
+  description:
+    "Fetches configured RSS and Atom subscriptions with conditional HTTP and entry cursors.",
+  displayName: "RSS / Atom",
+  id: "rss",
+  requiredEnv: [],
+  supportsAgenticDiscovery: false,
+};
+
+export function createRssConnector(): ConnectorRuntime {
+  return { ...definition, ingest };
+}
+
+export function normalizeRssFeedUrl(value: unknown): string {
+  if (typeof value !== "string" || value.trim().length === 0) {
+    throw new Error("Enter an RSS or Atom feed URL.");
+  }
+
+  let url: URL;
+  try {
+    url = new URL(value.trim());
+  } catch {
+    throw new Error("Enter a valid RSS or Atom feed URL.");
+  }
+
+  if (url.protocol !== "https:" && url.protocol !== "http:") {
+    throw new Error("RSS/Atom feed URLs must use HTTP or HTTPS.");
+  }
+  if (
+    url.username.length > 0 ||
+    url.password.length > 0 ||
+    [...url.searchParams.keys()].some((key) => SECRET_QUERY_KEY.test(key))
+  ) {
+    throw new Error(
+      "RSS/Atom feed URLs must not contain credentials or secret query parameters.",
+    );
+  }
+
+  url.hash = "";
+  return url.toString();
+}
+
+async function ingest(
+  options: ConnectorIngestOptions = {},
+): Promise<ConnectorIngestResult> {
+  const capturedAt = new Date().toISOString();
+  const runId = createRunId();
+  const rawFiles: string[] = [];
+  const warnings: string[] = [];
+  const instanceId = normalizeInstanceId(options.instanceId);
+  const baseConfig = await readConnectorConfig<RssConfig>("rss", {
+    enabled: true,
+    maxBytes: DEFAULT_MAX_BYTES,
+    maxItems: DEFAULT_MAX_ITEMS,
+    timeoutMs: DEFAULT_TIMEOUT_MS,
+  });
+  const config = normalizeConfig({
+    ...baseConfig,
+    ...((options.connectorConfig ?? {}) as RssConfig),
+    ...(options.limit === undefined ? {} : { maxItems: options.limit }),
+  });
+
+  if (!config.enabled) {
+    return result(
+      runId,
+      "skipped",
+      rawFiles,
+      warnings,
+      "RSS/Atom connector is disabled.",
+    );
+  }
+
+  let feedUrl: string;
+  try {
+    feedUrl = normalizeRssFeedUrl(config.feedUrl);
+  } catch (error) {
+    return result(
+      runId,
+      "error",
+      rawFiles,
+      warnings,
+      getSafeConfigurationError(error),
+    );
+  }
+
+  const state = (await readConnectorState("rss")) as RssConnectorState;
+  const instances = state.rss?.instances ?? {};
+  const previous = instances[instanceId];
+  const cursor = previous?.feedUrl === feedUrl ? previous : undefined;
+  const headers = new Headers({
+    accept:
+      "application/atom+xml, application/rss+xml, application/xml, text/xml;q=0.9",
+    "user-agent": "OpenWiki RSS connector/1",
+  });
+  if (cursor?.etag) headers.set("if-none-match", cursor.etag);
+  if (cursor?.lastModified) {
+    headers.set("if-modified-since", cursor.lastModified);
+  }
+
+  let response: Response;
+  try {
+    response = await fetch(feedUrl, {
+      headers,
+      redirect: "follow",
+      signal: AbortSignal.timeout(config.timeoutMs),
+    });
+  } catch {
+    return result(
+      runId,
+      "error",
+      rawFiles,
+      warnings,
+      `RSS/Atom fetch failed within timeoutMs=${config.timeoutMs}.`,
+    );
+  }
+
+  if (response.status === 304) {
+    await saveState(state, instances, instanceId, cursor, {
+      at: capturedAt,
+      rawFiles,
+      runId,
+      status: "skipped",
+      warnings,
+    });
+    return result(
+      runId,
+      "skipped",
+      rawFiles,
+      warnings,
+      "RSS/Atom feed was not modified.",
+    );
+  }
+
+  if (!response.ok) {
+    return result(
+      runId,
+      "error",
+      rawFiles,
+      warnings,
+      `RSS/Atom fetch failed with HTTP ${response.status}.`,
+    );
+  }
+
+  let xml: string;
+  try {
+    xml = await readBoundedBody(response, config.maxBytes);
+  } catch (error) {
+    return result(
+      runId,
+      "error",
+      rawFiles,
+      warnings,
+      error instanceof FeedSizeError
+        ? `RSS/Atom feed exceeded maxBytes=${config.maxBytes}.`
+        : "RSS/Atom feed body could not be read.",
+    );
+  }
+
+  let feed: ParsedFeed;
+  try {
+    feed = parseFeed(xml, feedUrl, config.maxItems);
+  } catch {
+    return result(
+      runId,
+      "error",
+      rawFiles,
+      warnings,
+      "RSS/Atom feed could not be parsed.",
+    );
+  }
+
+  const previousEntries = cursor?.entries ?? {};
+  const nextEntries = { ...previousEntries };
+  const emittedEntries: EmittedEntry[] = [];
+  let changedEntries = 0;
+  let newEntries = 0;
+
+  for (const entry of feed.entries) {
+    const contentHash = hashEntry(entry);
+    const previousEntry = previousEntries[entry.identity];
+    const changeType = previousEntry
+      ? previousEntry.contentHash === contentHash
+        ? null
+        : "changed"
+      : "new";
+    nextEntries[entry.identity] = { contentHash, lastSeenAt: capturedAt };
+    if (changeType === null) continue;
+    if (changeType === "new") newEntries += 1;
+    else changedEntries += 1;
+    emittedEntries.push({
+      ...entry,
+      capturedAt,
+      changeType,
+      feedUrl,
+      provenance: {
+        connectorId: "rss",
+        feedUrl,
+        sourceInstanceId: instanceId,
+      },
+    });
+  }
+
+  const etag = response.headers.get("etag") ?? undefined;
+  const lastModified = response.headers.get("last-modified") ?? undefined;
+  const lastPublishedAt = getLatestPublishedAt(feed.entries);
+  const nextInstanceState: RssInstanceState = {
+    entries: trimEntryState(nextEntries),
+    ...(etag ? { etag } : {}),
+    feedUrl,
+    ...(lastModified ? { lastModified } : {}),
+    ...(lastPublishedAt ? { lastPublishedAt } : {}),
+    lastSuccessAt: capturedAt,
+  };
+
+  if (emittedEntries.length > 0) {
+    rawFiles.push(
+      await writeRawJson("rss", runId, `entries-${instanceId}.json`, {
+        capturedAt,
+        connectorId: "rss",
+        entries: emittedEntries,
+        feedUrl,
+        schemaVersion: 1,
+        sourceInstanceId: instanceId,
+      }),
+    );
+    rawFiles.push(
+      await writeRawJson("rss", runId, `manifest-${instanceId}.json`, {
+        capturedAt,
+        changedEntries,
+        connectorId: "rss",
+        emittedEntries: emittedEntries.length,
+        ...(etag ? { etag } : {}),
+        feedAuthor: feed.author,
+        feedFormat: feed.format,
+        feedTitle: feed.title,
+        feedUrl,
+        ...(lastModified ? { lastModified } : {}),
+        newEntries,
+        provenance: {
+          connectorId: "rss",
+          feedUrl,
+          sourceInstanceId: instanceId,
+        },
+        schemaVersion: 1,
+        sourceInstanceId: instanceId,
+      }),
+    );
+  }
+
+  const status = rawFiles.length > 0 ? "success" : "skipped";
+  await saveState(state, instances, instanceId, nextInstanceState, {
+    at: capturedAt,
+    rawFiles,
+    runId,
+    status,
+    warnings,
+  });
+
+  return result(
+    runId,
+    status,
+    rawFiles,
+    warnings,
+    emittedEntries.length > 0
+      ? `Captured ${emittedEntries.length} new or changed RSS/Atom entr${
+          emittedEntries.length === 1 ? "y" : "ies"
+        }.`
+      : "No new or changed RSS/Atom entries.",
+  );
+}
+
+function normalizeConfig(
+  config: RssConfig,
+): Required<
+  Pick<RssConfig, "enabled" | "maxBytes" | "maxItems" | "timeoutMs">
+> &
+  Pick<RssConfig, "feedUrl"> {
+  return {
+    enabled: config.enabled !== false,
+    feedUrl: config.feedUrl,
+    maxBytes: boundedInteger(
+      config.maxBytes,
+      DEFAULT_MAX_BYTES,
+      MIN_MAX_BYTES,
+      MAX_MAX_BYTES,
+    ),
+    maxItems: boundedInteger(
+      config.maxItems,
+      DEFAULT_MAX_ITEMS,
+      1,
+      MAX_MAX_ITEMS,
+    ),
+    timeoutMs: boundedInteger(
+      config.timeoutMs,
+      DEFAULT_TIMEOUT_MS,
+      MIN_TIMEOUT_MS,
+      MAX_TIMEOUT_MS,
+    ),
+  };
+}
+
+function boundedInteger(
+  value: number | undefined,
+  fallback: number,
+  minimum: number,
+  maximum: number,
+): number {
+  if (typeof value !== "number" || !Number.isFinite(value)) return fallback;
+  return Math.max(minimum, Math.min(maximum, Math.trunc(value)));
+}
+
+function normalizeInstanceId(value: string | undefined): string {
+  if (value === undefined) return "rss-1";
+  if (!/^[A-Za-z0-9][A-Za-z0-9._-]{0,119}$/u.test(value)) {
+    throw new Error("Invalid RSS/Atom source instance ID.");
+  }
+  return value;
+}
+
+class FeedSizeError extends Error {}
+
+async function readBoundedBody(
+  response: Response,
+  maxBytes: number,
+): Promise<string> {
+  const declaredLength = Number(response.headers.get("content-length"));
+  if (Number.isFinite(declaredLength) && declaredLength > maxBytes) {
+    throw new FeedSizeError();
+  }
+  if (!response.body) return "";
+
+  // Node's fetch body is the same Web stream but DOM and node:stream/web
+  // declarations are not structurally linked in every supported TS version.
+  const body = response.body as unknown as ReadableStream<Uint8Array>;
+  const reader = body.getReader();
+  const chunks: Uint8Array[] = [];
+  let totalBytes = 0;
+  while (true) {
+    const readResult: ReadableStreamReadResult<Uint8Array> =
+      await reader.read();
+    if (readResult.done) break;
+    const chunk = readResult.value;
+    totalBytes += chunk.byteLength;
+    if (totalBytes > maxBytes) {
+      await reader.cancel();
+      throw new FeedSizeError();
+    }
+    chunks.push(chunk);
+  }
+
+  const bytes = new Uint8Array(totalBytes);
+  let offset = 0;
+  for (const chunk of chunks) {
+    bytes.set(chunk, offset);
+    offset += chunk.byteLength;
+  }
+  return new TextDecoder("utf-8", { fatal: true }).decode(bytes);
+}
+
+function parseFeed(xml: string, feedUrl: string, maxItems: number): ParsedFeed {
+  const parser = new XMLParser({
+    attributeNamePrefix: "@_",
+    cdataPropName: "#cdata",
+    ignoreAttributes: false,
+    parseAttributeValue: false,
+    parseTagValue: false,
+    processEntities: false,
+    removeNSPrefix: true,
+    trimValues: true,
+  });
+  const document = parser.parse(xml) as Record<string, unknown>;
+  const atom = asRecord(document.feed);
+  const rssRoot = asRecord(document.rss);
+  const rssChannel = asRecord(rssRoot?.channel);
+  const rdf = asRecord(document.RDF);
+  const format = atom ? "atom" : "rss";
+  const feedNode = atom ?? rssChannel ?? rdf;
+  if (!feedNode) throw new Error("Missing feed root.");
+  const rawEntries = asArray(
+    format === "atom" ? feedNode.entry : (rssChannel?.item ?? rdf?.item),
+  ).slice(0, maxItems);
+
+  return {
+    author: extractAuthor(feedNode.author ?? feedNode.creator),
+    entries: rawEntries.map((rawEntry) =>
+      parseEntry(rawEntry, format, feedUrl),
+    ),
+    format,
+    title: extractText(feedNode.title),
+  };
+}
+
+function parseEntry(
+  value: unknown,
+  format: ParsedFeed["format"],
+  feedUrl: string,
+): ParsedEntry {
+  const entry = asRecord(value);
+  if (!entry) throw new Error("Invalid feed entry.");
+  const entryGuid = extractText(entry.guid ?? entry.id);
+  const entryUrl = extractEntryUrl(entry.link, format, feedUrl);
+  const title = extractText(entry.title);
+  const author = extractAuthor(entry.author ?? entry.creator);
+  const publishedAt = normalizeTimestamp(
+    extractText(
+      entry.published ?? entry.pubDate ?? entry.updated ?? entry.date,
+    ),
+  );
+  const content = extractText(
+    entry.content ?? entry.encoded ?? entry.description ?? entry.summary,
+  );
+  const identity = entryGuid
+    ? `guid:${entryGuid}`
+    : entryUrl
+      ? `url:${entryUrl}`
+      : `content:${hashValue({ author, content, publishedAt, title })}`;
+
+  return {
+    author,
+    content,
+    entryGuid,
+    entryUrl,
+    identity,
+    publishedAt,
+    title,
+  };
+}
+
+function extractEntryUrl(
+  value: unknown,
+  format: ParsedFeed["format"],
+  feedUrl: string,
+): string | null {
+  if (format === "rss") return resolveUrl(extractText(value), feedUrl);
+  const links = asArray(value);
+  const selected =
+    links.find((link) => {
+      const record = asRecord(link);
+      return record?.["@_rel"] === "alternate";
+    }) ?? links.find((link) => asRecord(link)?.["@_rel"] === undefined);
+  const record = asRecord(selected);
+  return resolveUrl(
+    extractText(record?.["@_href"] ?? record?.href ?? selected),
+    feedUrl,
+  );
+}
+
+function resolveUrl(value: string | null, feedUrl: string): string | null {
+  if (!value) return null;
+  try {
+    return new URL(value, feedUrl).toString();
+  } catch {
+    return value;
+  }
+}
+
+function extractAuthor(value: unknown): string | null {
+  const first = asArray(value)[0];
+  const record = asRecord(first);
+  return extractText(record?.name ?? first);
+}
+
+function extractText(value: unknown): string | null {
+  if (typeof value === "string" || typeof value === "number") {
+    const text = String(value).trim();
+    return text.length > 0 ? text : null;
+  }
+  if (Array.isArray(value)) {
+    for (const item of value) {
+      const text = extractText(item);
+      if (text) return text;
+    }
+    return null;
+  }
+  const record = asRecord(value);
+  if (!record) return null;
+  return extractText(record["#text"] ?? record["#cdata"]);
+}
+
+function normalizeTimestamp(value: string | null): string | null {
+  if (!value) return null;
+  const milliseconds = Date.parse(value);
+  return Number.isFinite(milliseconds)
+    ? new Date(milliseconds).toISOString()
+    : value;
+}
+
+function hashEntry(entry: ParsedEntry): string {
+  return hashValue(entry);
+}
+
+function hashValue(value: unknown): string {
+  return createHash("sha256").update(JSON.stringify(value)).digest("hex");
+}
+
+function getLatestPublishedAt(entries: ParsedEntry[]): string | undefined {
+  return entries
+    .map((entry) => entry.publishedAt)
+    .filter((value): value is string => Boolean(value))
+    .sort()
+    .at(-1);
+}
+
+function trimEntryState(
+  entries: Record<string, RssEntryCursor>,
+): Record<string, RssEntryCursor> {
+  return Object.fromEntries(
+    Object.entries(entries)
+      .sort(
+        ([leftId, left], [rightId, right]) =>
+          right.lastSeenAt.localeCompare(left.lastSeenAt) ||
+          leftId.localeCompare(rightId),
+      )
+      .slice(0, MAX_STATE_ENTRIES),
+  );
+}
+
+async function saveState(
+  state: RssConnectorState,
+  instances: Record<string, RssInstanceState>,
+  instanceId: string,
+  instance: RssInstanceState | undefined,
+  run: NonNullable<ConnectorState["runs"]>[number],
+): Promise<void> {
+  const nextInstances = instance
+    ? { ...instances, [instanceId]: instance }
+    : instances;
+  await writeConnectorState("rss", {
+    ...updateStateWithRun(state, run),
+    rss: { instances: nextInstances },
+  } as RssConnectorState);
+}
+
+function result(
+  runId: string,
+  status: ConnectorIngestResult["status"],
+  rawFiles: string[],
+  warnings: string[],
+  message: string,
+): ConnectorIngestResult {
+  return {
+    connectorId: "rss",
+    message,
+    rawFiles,
+    runId,
+    statePath: "~/.openwiki/connectors/rss/state.json",
+    status,
+    warnings,
+  };
+}
+
+function getSafeConfigurationError(error: unknown): string {
+  const message = error instanceof Error ? error.message : "";
+  return message.startsWith("RSS/Atom") || message.startsWith("Enter an")
+    ? message
+    : "RSS/Atom feed configuration is invalid.";
+}
+
+function asRecord(value: unknown): Record<string, unknown> | null {
+  return typeof value === "object" && value !== null && !Array.isArray(value)
+    ? (value as Record<string, unknown>)
+    : null;
+}
+
+function asArray(value: unknown): unknown[] {
+  if (value === undefined || value === null) return [];
+  return Array.isArray(value) ? value : [value];
+}
