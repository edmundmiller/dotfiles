diff --git c/src/connectors/sources/discord.ts i/src/connectors/sources/discord.ts
new file mode 100644
index 0000000..6b8b36a
--- /dev/null
+++ i/src/connectors/sources/discord.ts
@@ -0,0 +1,482 @@
+import { execFile } from "node:child_process";
+import { promisify } from "node:util";
+import {
+  createRunId,
+  readConnectorConfig,
+  readConnectorState,
+  updateStateWithRun,
+  writeConnectorState,
+  writeRawJson,
+} from "../io.js";
+import type {
+  ConnectorDefinition,
+  ConnectorIngestOptions,
+  ConnectorIngestResult,
+  ConnectorRuntime,
+  ConnectorState,
+} from "../types.js";
+
+const execFileAsync = promisify(execFile);
+const DISCRAWL_EXECUTABLE_ENV_KEY = "OPENWIKI_DISCRAWL_EXECUTABLE";
+const MAX_BUFFER_BYTES = 10 * 1024 * 1024;
+const MAX_WINDOW_HOURS = 720;
+
+export type DiscordConfig = {
+  channelIds?: string[];
+  enabled?: boolean;
+  guildIds?: string[];
+  includeDms?: boolean;
+  maxMessages?: number;
+  windowHours?: number;
+};
+
+type DiscrawlMessage = {
+  author_id: string;
+  author_name: string;
+  channel_id: string;
+  channel_name: string;
+  content: string;
+  created_at: string;
+  display_content: string;
+  guild_id: string;
+  guild_name: string;
+  has_attachments: boolean;
+  message_id: string;
+  pinned: boolean;
+  source: string;
+};
+
+type NormalizedDiscordMessage = {
+  authorId: string;
+  authorName: string;
+  channelId: string;
+  channelName: string;
+  content: string;
+  createdAt: string;
+  displayContent: string;
+  guildId: string;
+  guildName: string;
+  hasAttachments: boolean;
+  messageId: string;
+  pinned: boolean;
+  source: string;
+};
+
+const definition: ConnectorDefinition = {
+  backend: "local-cli",
+  description:
+    "Reads explicitly scoped Discord history from a local Discrawl archive.",
+  displayName: "Discord",
+  id: "discord",
+  requiredEnv: [],
+  supportsAgenticDiscovery: false,
+};
+
+export function createDiscordConnector(): ConnectorRuntime {
+  return { ...definition, ingest };
+}
+
+async function ingest(
+  options: ConnectorIngestOptions = {},
+): Promise<ConnectorIngestResult> {
+  const runId = createRunId();
+  const config = normalizeConfig({
+    ...(await readConnectorConfig<DiscordConfig>("discord", {
+      channelIds: [],
+      enabled: true,
+      guildIds: [],
+      includeDms: false,
+      maxMessages: 500,
+      windowHours: options.windowHours ?? 24,
+    })),
+    ...((options.connectorConfig ?? {}) as DiscordConfig),
+  });
+  const rawFiles: string[] = [];
+  const warnings: string[] = [];
+
+  if (!config.enabled) {
+    return result(
+      runId,
+      "skipped",
+      rawFiles,
+      warnings,
+      "Discord connector is disabled.",
+    );
+  }
+
+  if (
+    config.guildIds.length === 0 &&
+    config.channelIds.length === 0 &&
+    !config.includeDms
+  ) {
+    return result(
+      runId,
+      "error",
+      rawFiles,
+      warnings,
+      "Discord ingestion requires at least one guildIds, channelIds, or includeDms scope in ~/.openwiki/connectors/discord/config.json.",
+    );
+  }
+
+  const state = await readConnectorState("discord");
+  const end = new Date();
+  const start = new Date(end.getTime() - config.windowHours * 60 * 60 * 1000);
+  const gapError = getCatchUpGapError(state, start, end, config.windowHours);
+  if (gapError) {
+    return result(runId, "error", rawFiles, warnings, gapError);
+  }
+
+  let rows: DiscrawlMessage[];
+  try {
+    rows = deduplicateMessages(await readScopedMessages(config));
+  } catch (error) {
+    return result(runId, "error", rawFiles, warnings, mapDiscrawlError(error));
+  }
+
+  const newRows = rows.filter(
+    (row) =>
+      compareSnowflakes(row.message_id, readCursor(state, row.channel_id)) > 0,
+  );
+  const nextCursors = getNextCursors(state, rows);
+
+  if (newRows.length === 0) {
+    const nextState = updateStateWithRun(state, {
+      at: end.toISOString(),
+      rawFiles,
+      runId,
+      status: "skipped",
+      warnings,
+    });
+    nextState.latestIds = { ...(state.latestIds ?? {}), ...nextCursors };
+    await writeConnectorState("discord", nextState);
+    return result(
+      runId,
+      "skipped",
+      rawFiles,
+      warnings,
+      "No new Discord messages in the configured Discrawl scope.",
+    );
+  }
+
+  const messages = newRows.map(normalizeMessage).sort(compareMessages);
+  const messagesPath = await writeRawJson("discord", runId, "messages.json", {
+    messages,
+    schemaVersion: 1,
+  });
+  const manifestPath = await writeRawJson("discord", runId, "manifest.json", {
+    connectorId: "discord",
+    dataFiles: ["messages.json"],
+    generatedAt: end.toISOString(),
+    messageCount: messages.length,
+    schemaVersion: 1,
+    scope: {
+      channelIds: config.channelIds,
+      guildIds: config.guildIds,
+      includeDms: config.includeDms,
+    },
+    channels: summarizeChannels(messages, state, nextCursors),
+    window: {
+      end: end.toISOString(),
+      hours: config.windowHours,
+      start: start.toISOString(),
+    },
+  });
+  rawFiles.push(messagesPath, manifestPath);
+
+  const nextState = updateStateWithRun(state, {
+    at: end.toISOString(),
+    rawFiles,
+    runId,
+    status: "success",
+    warnings,
+  });
+  nextState.latestIds = { ...(state.latestIds ?? {}), ...nextCursors };
+  await writeConnectorState("discord", nextState);
+
+  return result(
+    runId,
+    "success",
+    rawFiles,
+    warnings,
+    `Wrote ${messages.length} Discord message(s) from Discrawl.`,
+  );
+}
+
+function normalizeConfig(config: DiscordConfig): Required<DiscordConfig> {
+  return {
+    channelIds: uniqueSnowflakes(config.channelIds),
+    enabled: config.enabled !== false,
+    guildIds: uniqueSnowflakes(config.guildIds),
+    includeDms: config.includeDms === true,
+    maxMessages: clampInteger(config.maxMessages, 1, 5000, 500),
+    windowHours: clampInteger(config.windowHours, 1, MAX_WINDOW_HOURS, 24),
+  };
+}
+
+function uniqueSnowflakes(values: unknown): string[] {
+  if (!Array.isArray(values)) return [];
+  return [
+    ...new Set(
+      values.filter(
+        (value): value is string =>
+          typeof value === "string" && /^\d{1,20}$/u.test(value),
+      ),
+    ),
+  ];
+}
+
+function clampInteger(
+  value: number | undefined,
+  minimum: number,
+  maximum: number,
+  fallback: number,
+): number {
+  if (!Number.isFinite(value)) return fallback;
+  return Math.min(maximum, Math.max(minimum, Math.trunc(value!)));
+}
+
+async function readScopedMessages(
+  config: Required<DiscordConfig>,
+): Promise<DiscrawlMessage[]> {
+  const scopes: string[][] = [];
+  const guildArgs =
+    config.guildIds.length > 0 ? ["--guilds", config.guildIds.join(",")] : [];
+
+  if (config.channelIds.length > 0) {
+    for (const channelId of config.channelIds) {
+      scopes.push([...guildArgs, "--channel", channelId]);
+    }
+  } else if (config.guildIds.length > 0) {
+    scopes.push(guildArgs);
+  }
+
+  if (config.includeDms) scopes.push(["--dm"]);
+
+  const rows: DiscrawlMessage[] = [];
+  for (const scope of scopes) {
+    const parsed = parseDiscrawlMessages(
+      await runDiscrawl([
+        "--json",
+        "messages",
+        ...scope,
+        "--hours",
+        String(config.windowHours),
+        "--limit",
+        String(config.maxMessages),
+      ]),
+    );
+    if (parsed.length === config.maxMessages) {
+      throw new Error(
+        `Discrawl reached maxMessages=${config.maxMessages}; increase the limit or narrow the Discord scope.`,
+      );
+    }
+    rows.push(...parsed);
+  }
+  return rows;
+}
+
+async function runDiscrawl(args: string[]): Promise<string> {
+  const executable = process.env[DISCRAWL_EXECUTABLE_ENV_KEY] ?? "discrawl";
+  const { stdout } = await execFileAsync(executable, args, {
+    maxBuffer: MAX_BUFFER_BYTES,
+  });
+  return String(stdout).trim();
+}
+
+function parseDiscrawlMessages(output: string): DiscrawlMessage[] {
+  const value: unknown = output.length === 0 ? null : JSON.parse(output);
+  if (value === null) return [];
+  if (!Array.isArray(value)) {
+    throw new Error("Discrawl returned an invalid JSON message array.");
+  }
+  return value.map(parseDiscrawlMessage);
+}
+
+function parseDiscrawlMessage(value: unknown): DiscrawlMessage {
+  if (!isRecord(value)) {
+    throw new Error("Discrawl returned an invalid JSON message row.");
+  }
+  const stringKeys = [
+    "author_id",
+    "author_name",
+    "channel_id",
+    "channel_name",
+    "content",
+    "created_at",
+    "display_content",
+    "guild_id",
+    "guild_name",
+    "message_id",
+    "source",
+  ] as const;
+  for (const key of stringKeys) {
+    if (typeof value[key] !== "string") {
+      throw new Error(`Discrawl message row has invalid ${key}.`);
+    }
+  }
+  if (
+    typeof value.has_attachments !== "boolean" ||
+    typeof value.pinned !== "boolean" ||
+    !/^\d{1,20}$/u.test(value.message_id as string) ||
+    !/^\d{1,20}$/u.test(value.channel_id as string)
+  ) {
+    throw new Error("Discrawl returned an invalid JSON message row.");
+  }
+  return value as DiscrawlMessage;
+}
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === "object" && value !== null && !Array.isArray(value);
+}
+
+function normalizeMessage(row: DiscrawlMessage): NormalizedDiscordMessage {
+  return {
+    authorId: row.author_id,
+    authorName: row.author_name,
+    channelId: row.channel_id,
+    channelName: row.channel_name,
+    content: row.content,
+    createdAt: row.created_at,
+    displayContent: row.display_content,
+    guildId: row.guild_id,
+    guildName: row.guild_name,
+    hasAttachments: row.has_attachments,
+    messageId: row.message_id,
+    pinned: row.pinned,
+    source: row.source,
+  };
+}
+
+function deduplicateMessages(rows: DiscrawlMessage[]): DiscrawlMessage[] {
+  const byId = new Map<string, DiscrawlMessage>();
+  for (const row of rows) {
+    if (!byId.has(row.message_id)) byId.set(row.message_id, row);
+  }
+  return [...byId.values()];
+}
+
+function readCursor(state: ConnectorState, channelId: string): string {
+  const value = state.latestIds?.[`channel:${channelId}`];
+  return typeof value === "string" && /^\d{1,20}$/u.test(value) ? value : "0";
+}
+
+function getNextCursors(
+  state: ConnectorState,
+  rows: DiscrawlMessage[],
+): Record<string, string> {
+  const cursors: Record<string, string> = {};
+  for (const row of rows) {
+    const key = `channel:${row.channel_id}`;
+    const current = cursors[key] ?? readCursor(state, row.channel_id);
+    if (compareSnowflakes(row.message_id, current) > 0) {
+      cursors[key] = row.message_id;
+    }
+  }
+  return cursors;
+}
+
+function compareSnowflakes(left: string, right: string): number {
+  const leftValue = BigInt(left);
+  const rightValue = BigInt(right);
+  return leftValue < rightValue ? -1 : leftValue > rightValue ? 1 : 0;
+}
+
+function compareMessages(
+  left: NormalizedDiscordMessage,
+  right: NormalizedDiscordMessage,
+): number {
+  return (
+    left.createdAt.localeCompare(right.createdAt) ||
+    compareSnowflakes(left.messageId, right.messageId)
+  );
+}
+
+function summarizeChannels(
+  messages: NormalizedDiscordMessage[],
+  state: ConnectorState,
+  nextCursors: Record<string, string>,
+) {
+  const byChannel = new Map<
+    string,
+    {
+      channelId: string;
+      channelName: string;
+      guildId: string;
+      guildName: string;
+      messageCount: number;
+    }
+  >();
+  for (const message of messages) {
+    const summary = byChannel.get(message.channelId) ?? {
+      channelId: message.channelId,
+      channelName: message.channelName,
+      guildId: message.guildId,
+      guildName: message.guildName,
+      messageCount: 0,
+    };
+    summary.messageCount += 1;
+    byChannel.set(message.channelId, summary);
+  }
+  return [...byChannel.values()].map((summary) => ({
+    ...summary,
+    cursorAfter:
+      nextCursors[`channel:${summary.channelId}`] ??
+      readCursor(state, summary.channelId),
+    cursorBefore: readCursor(state, summary.channelId),
+  }));
+}
+
+function getCatchUpGapError(
+  state: ConnectorState,
+  start: Date,
+  end: Date,
+  windowHours: number,
+): string | undefined {
+  const previousRunAt = Date.parse(state.lastRunAt ?? "");
+  if (!Number.isFinite(previousRunAt) || previousRunAt >= start.getTime()) {
+    return undefined;
+  }
+  const requiredHours = Math.ceil(
+    (end.getTime() - previousRunAt) / (60 * 60 * 1000),
+  );
+  return requiredHours > MAX_WINDOW_HOURS
+    ? `The previous successful Discord ingest is ${requiredHours} hours old, but windowHours is capped at ${MAX_WINDOW_HOURS}. Move ~/.openwiki/connectors/discord/state.json aside only if you deliberately accept the older gap, then rerun with windowHours=${MAX_WINDOW_HOURS}.`
+    : `The previous successful Discord ingest predates windowHours=${windowHours}; increase windowHours to at least ${requiredHours} to catch up without gaps.`;
+}
+
+function mapDiscrawlError(error: unknown): string {
+  if (hasErrorCode(error, "ENOENT")) {
+    return `Discrawl is unavailable; install it or set ${DISCRAWL_EXECUTABLE_ENV_KEY} to its absolute path.`;
+  }
+  const message = error instanceof Error ? error.message : String(error);
+  if (message.includes("invalid JSON")) return message;
+  if (message.includes("maxMessages=")) return message;
+  return `Discrawl message query failed: ${message}`;
+}
+
+function hasErrorCode(error: unknown, code: string): boolean {
+  return Boolean(
+    error &&
+    typeof error === "object" &&
+    "code" in error &&
+    (error as NodeJS.ErrnoException).code === code,
+  );
+}
+
+function result(
+  runId: string,
+  status: ConnectorIngestResult["status"],
+  rawFiles: string[],
+  warnings: string[],
+  message: string,
+): ConnectorIngestResult {
+  return {
+    connectorId: "discord",
+    message,
+    rawFiles,
+    runId,
+    statePath: "~/.openwiki/connectors/discord/state.json",
+    status,
+    warnings,
+  };
+}
