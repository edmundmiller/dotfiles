diff --git c/test/discord-connector.test.ts i/test/discord-connector.test.ts
new file mode 100644
index 0000000..4baed2b
--- /dev/null
+++ i/test/discord-connector.test.ts
@@ -0,0 +1,264 @@
+import { execFileSync } from "node:child_process";
+import { mkdir, mkdtemp, readFile, rm, writeFile } from "node:fs/promises";
+import os from "node:os";
+import path from "node:path";
+import { afterEach, beforeEach, describe, expect, test, vi } from "vitest";
+
+const execFileAsync = vi.hoisted(() => vi.fn());
+
+vi.mock("node:child_process", async (importOriginal) => {
+  const actual = await importOriginal<typeof import("node:child_process")>();
+  const mockedExecFile = vi.fn();
+  Object.defineProperty(
+    mockedExecFile,
+    Symbol.for("nodejs.util.promisify.custom"),
+    { value: execFileAsync },
+  );
+  return { ...actual, execFile: mockedExecFile };
+});
+
+const originalHome = process.env.HOME;
+const originalExecutable = process.env.OPENWIKI_DISCRAWL_EXECUTABLE;
+let home: string;
+
+beforeEach(async () => {
+  home = await mkdtemp(path.join(os.tmpdir(), "openwiki-discord-test-"));
+  process.env.HOME = home;
+  process.env.OPENWIKI_DISCRAWL_EXECUTABLE = "/test/discrawl";
+  execFileSync("git", ["init", "-q", home]);
+  execFileAsync.mockReset();
+  vi.useFakeTimers();
+  vi.setSystemTime(new Date("2026-07-18T12:00:00.000Z"));
+  vi.resetModules();
+});
+
+afterEach(async () => {
+  vi.useRealTimers();
+  vi.restoreAllMocks();
+  if (originalHome === undefined) delete process.env.HOME;
+  else process.env.HOME = originalHome;
+  if (originalExecutable === undefined)
+    delete process.env.OPENWIKI_DISCRAWL_EXECUTABLE;
+  else process.env.OPENWIKI_DISCRAWL_EXECUTABLE = originalExecutable;
+  await rm(home, { recursive: true, force: true });
+});
+
+async function loadConnector() {
+  const { createDiscordConnector } =
+    await import("../src/connectors/sources/discord.ts");
+  return createDiscordConnector();
+}
+
+function message(
+  id: string,
+  channelId: string,
+  createdAt: string,
+  overrides: Record<string, unknown> = {},
+) {
+  return {
+    author_id: "42",
+    author_name: "Alice",
+    channel_id: channelId,
+    channel_name: "planning",
+    content: `message ${id}`,
+    created_at: createdAt,
+    display_content: `message ${id}`,
+    guild_id: "100",
+    guild_name: "Personal",
+    has_attachments: false,
+    message_id: id,
+    pinned: false,
+    source: "discord",
+    ...overrides,
+  };
+}
+
+async function connectorState() {
+  return JSON.parse(
+    await readFile(
+      path.join(home, ".openwiki/connectors/discord/state.json"),
+      "utf8",
+    ),
+  ) as { latestIds?: Record<string, string> };
+}
+
+describe("Discord connector", () => {
+  test("requires explicit scope and disabled config performs no subprocess work", async () => {
+    const connector = await loadConnector();
+
+    const unscoped = await connector.ingest();
+    expect(unscoped).toMatchObject({ rawFiles: [], status: "error" });
+    expect(unscoped.message).toContain("guildIds, channelIds, or includeDms");
+    await expect(
+      connector.ingest({
+        connectorConfig: { enabled: false, guildIds: ["1"] },
+      }),
+    ).resolves.toMatchObject({ rawFiles: [], status: "skipped" });
+    expect(execFileAsync).not.toHaveBeenCalled();
+  });
+
+  test("uses exact bounded Discrawl JSON calls for guild, channel, and DM scope", async () => {
+    execFileAsync.mockResolvedValue({ stdout: "null\n", stderr: "" });
+    const connector = await loadConnector();
+
+    await connector.ingest({
+      connectorConfig: {
+        channelIds: ["300", "300", "301"],
+        guildIds: ["100", "101", "100"],
+        includeDms: true,
+        maxMessages: 9000,
+        windowHours: 900,
+      },
+    });
+
+    const options = { maxBuffer: 10 * 1024 * 1024 };
+    expect(execFileAsync).toHaveBeenNthCalledWith(
+      1,
+      "/test/discrawl",
+      [
+        "--json",
+        "messages",
+        "--guilds",
+        "100,101",
+        "--channel",
+        "300",
+        "--hours",
+        "720",
+        "--limit",
+        "5000",
+      ],
+      options,
+    );
+    expect(execFileAsync).toHaveBeenNthCalledWith(
+      2,
+      "/test/discrawl",
+      [
+        "--json",
+        "messages",
+        "--guilds",
+        "100,101",
+        "--channel",
+        "301",
+        "--hours",
+        "720",
+        "--limit",
+        "5000",
+      ],
+      options,
+    );
+    expect(execFileAsync).toHaveBeenNthCalledWith(
+      3,
+      "/test/discrawl",
+      ["--json", "messages", "--dm", "--hours", "720", "--limit", "5000"],
+      options,
+    );
+  });
+
+  test("writes normalized new messages and maintains per-channel snowflake cursors", async () => {
+    const oldMessage = message(
+      "1500000000000000001",
+      "300",
+      "2026-07-18T10:00:00.000Z",
+      { ignored_secret: "do not persist" },
+    );
+    const newMessage = message(
+      "1500000000000000002",
+      "300",
+      "2026-07-18T11:00:00.000Z",
+      { has_attachments: true, pinned: true },
+    );
+    execFileAsync.mockResolvedValue({
+      stdout: `${JSON.stringify([oldMessage, newMessage])}\n`,
+      stderr: "",
+    });
+    const connector = await loadConnector();
+
+    const first = await connector.ingest({
+      connectorConfig: { guildIds: ["100"], maxMessages: 50 },
+    });
+    expect(first).toMatchObject({ status: "success" });
+    const messagesPath = first.rawFiles.find((file) =>
+      file.endsWith("messages.json"),
+    )!;
+    const raw = JSON.parse(await readFile(messagesPath, "utf8")) as {
+      messages: Record<string, unknown>[];
+    };
+    expect(raw.messages).toEqual([
+      {
+        authorId: "42",
+        authorName: "Alice",
+        channelId: "300",
+        channelName: "planning",
+        content: "message 1500000000000000001",
+        createdAt: "2026-07-18T10:00:00.000Z",
+        displayContent: "message 1500000000000000001",
+        guildId: "100",
+        guildName: "Personal",
+        hasAttachments: false,
+        messageId: "1500000000000000001",
+        pinned: false,
+        source: "discord",
+      },
+      {
+        authorId: "42",
+        authorName: "Alice",
+        channelId: "300",
+        channelName: "planning",
+        content: "message 1500000000000000002",
+        createdAt: "2026-07-18T11:00:00.000Z",
+        displayContent: "message 1500000000000000002",
+        guildId: "100",
+        guildName: "Personal",
+        hasAttachments: true,
+        messageId: "1500000000000000002",
+        pinned: true,
+        source: "discord",
+      },
+    ]);
+    expect(JSON.stringify(raw)).not.toContain("ignored_secret");
+    expect(await connectorState()).toMatchObject({
+      latestIds: { "channel:300": "1500000000000000002" },
+    });
+
+    const second = await connector.ingest({
+      connectorConfig: { guildIds: ["100"], maxMessages: 50 },
+    });
+    expect(second).toMatchObject({ rawFiles: [], status: "skipped" });
+  });
+
+  test("maps missing Discrawl and rejects malformed output", async () => {
+    const connector = await loadConnector();
+    execFileAsync.mockRejectedValueOnce(
+      Object.assign(new Error("missing"), { code: "ENOENT" }),
+    );
+    const missing = await connector.ingest({
+      connectorConfig: { guildIds: ["100"] },
+    });
+    expect(missing).toMatchObject({ status: "error" });
+    expect(missing.message).toContain("Discrawl is unavailable");
+
+    execFileAsync.mockResolvedValueOnce({ stdout: "{}", stderr: "" });
+    const malformed = await connector.ingest({
+      connectorConfig: { guildIds: ["100"] },
+    });
+    expect(malformed).toMatchObject({ status: "error" });
+    expect(malformed.message).toContain("invalid JSON message array");
+  });
+
+  test("refuses a catch-up gap larger than the configured window", async () => {
+    const connector = await loadConnector();
+    const stateDir = path.join(home, ".openwiki/connectors/discord");
+    await mkdir(stateDir, { recursive: true });
+    await writeFile(
+      path.join(stateDir, "state.json"),
+      `${JSON.stringify({ lastRunAt: "2026-07-16T00:00:00.000Z", version: 1 })}\n`,
+    );
+
+    const result = await connector.ingest({
+      connectorConfig: { guildIds: ["100"], windowHours: 24 },
+    });
+    expect(result).toMatchObject({ status: "error" });
+    expect(result.message).toContain("increase windowHours to at least 60");
+    expect(execFileAsync).not.toHaveBeenCalled();
+  });
+});
