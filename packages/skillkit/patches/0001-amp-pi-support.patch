new file mode 100644
index 0000000..3742018
--- /dev/null
+++ b/b/src/scanner/connectors/pi.ts
@@ -0,0 +1,173 @@
+import type { Database } from "bun:sqlite";
+import { existsSync, readFileSync } from "node:fs";
+import { homedir } from "node:os";
+import { basename, join } from "node:path";
+import type { Invocation } from "../index";
+import { recordNewInvocations } from "../index";
+
+const PI_SKILL_PATH_RE = /(?:^|[\\/])skills[\\/]([^\\/]+)[\\/]SKILL\.md/g;
+const VALID_PI_SKILL_RE = /^[A-Za-z0-9][A-Za-z0-9._:-]*$/;
+
+function collectStrings(value: unknown, out: string[]): void {
+	if (typeof value === "string") {
+		out.push(value);
+		return;
+	}
+	if (Array.isArray(value)) {
+		for (const v of value) collectStrings(v, out);
+		return;
+	}
+	if (typeof value === "object" && value !== null) {
+		for (const v of Object.values(value as Record<string, unknown>)) {
+			collectStrings(v, out);
+		}
+	}
+}
+
+function extractSkillNamesFromArgs(args: unknown): string[] {
+	const names: string[] = [];
+	const strings: string[] = [];
+	collectStrings(args, strings);
+
+	for (const text of strings) {
+		let match: RegExpExecArray | null;
+		while ((match = PI_SKILL_PATH_RE.exec(text)) !== null) {
+			const name = match[1]?.trim();
+			if (!name) continue;
+			if (!VALID_PI_SKILL_RE.test(name)) continue;
+			names.push(name);
+		}
+		PI_SKILL_PATH_RE.lastIndex = 0;
+	}
+
+	return names;
+}
+
+export function parsePiSessionFile(
+	filePath: string,
+	knownSkills: Set<string> = new Set(),
+): Invocation[] {
+	const invocations: Invocation[] = [];
+	const sessionId = `pi:${basename(filePath, ".jsonl")}`;
+
+	let content: string;
+	try {
+		content = readFileSync(filePath, "utf-8");
+	} catch {
+		return invocations;
+	}
+
+	const lines = content.split("\n");
+	let eventOffset = 0;
+
+	for (const line of lines) {
+		if (!line.trim()) continue;
+
+		let entry: unknown;
+		try {
+			entry = JSON.parse(line);
+		} catch {
+			continue;
+		}
+		if (typeof entry !== "object" || entry === null) continue;
+
+		const obj = entry as Record<string, unknown>;
+		if (obj.type !== "message") continue;
+
+		const baseTimestamp =
+			typeof obj.timestamp === "string" ? obj.timestamp : new Date().toISOString();
+		const baseTsMs = Date.parse(baseTimestamp);
+
+		const message = obj.message as Record<string, unknown> | undefined;
+		if (!message) continue;
+
+		const blocks = message.content as Array<Record<string, unknown>> | undefined;
+		if (!Array.isArray(blocks)) continue;
+
+		for (const block of blocks) {
+			const bType = block.type as string | undefined;
+			if (!bType || !["toolCall", "tool_use", "function_call"].includes(bType)) {
+				continue;
+			}
+
+			const args =
+				block.arguments ?? block.input ?? block.args ?? ({} as Record<string, unknown>);
+
+			// Direct skill tool use: { name: "skill", arguments: { name: "..." } }
+			if (typeof block.name === "string" && block.name.toLowerCase() === "skill") {
+				const a = args as Record<string, unknown>;
+				const explicit = a.name ?? a.skill ?? a.skillName;
+				if (typeof explicit === "string" && explicit.trim()) {
+					const skillName = explicit.trim();
+					if (knownSkills.size === 0 || knownSkills.has(skillName)) {
+						const ts = Number.isFinite(baseTsMs)
+							? new Date(baseTsMs + eventOffset).toISOString()
+							: new Date().toISOString();
+						eventOffset += 1;
+						invocations.push({
+							skillName,
+							timestamp: ts,
+							sessionId,
+							agent: "pi",
+						});
+					}
+				}
+			}
+
+			// Skill references via SKILL.md path in tool args/command strings.
+			for (const skillName of extractSkillNamesFromArgs(args)) {
+				if (knownSkills.size > 0 && !knownSkills.has(skillName)) continue;
+
+				const ts = Number.isFinite(baseTsMs)
+					? new Date(baseTsMs + eventOffset).toISOString()
+					: new Date().toISOString();
+				eventOffset += 1;
+
+				invocations.push({
+					skillName,
+					timestamp: ts,
+					sessionId,
+					agent: "pi",
+				});
+			}
+		}
+	}
+
+	return invocations;
+}
+
+export function countPiSessions(): number {
+	const sessionsDir = join(homedir(), ".pi", "agent", "sessions");
+	if (!existsSync(sessionsDir)) return 0;
+
+	let count = 0;
+	const glob = new Bun.Glob("**/*.jsonl");
+	for (const _ of glob.scanSync({ cwd: sessionsDir })) {
+		count++;
+	}
+	return count;
+}
+
+export async function scanPiSessions(
+	db: Database,
+	trackedSet: Set<string>,
+	knownSkills: Set<string> = new Set(),
+): Promise<number> {
+	const sessionsDir = join(homedir(), ".pi", "agent", "sessions");
+	if (!existsSync(sessionsDir)) return 0;
+
+	const glob = new Bun.Glob("**/*.jsonl");
+	const files: string[] = [];
+	for await (const file of glob.scan({ cwd: sessionsDir, absolute: true })) {
+		files.push(file);
+	}
+
+	let total = 0;
+	for (const file of files) {
+		const invocations = parsePiSessionFile(file, knownSkills);
+		total += recordNewInvocations(db, trackedSet, invocations);
+	}
+
+	return total;
+}
+
