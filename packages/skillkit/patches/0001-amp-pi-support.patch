diff --git a/b/src/scanner/connectors/amp.ts b/b/src/scanner/connectors/amp.ts
new file mode 100644
index 0000000..1d66649
--- /dev/null
+++ b/b/src/scanner/connectors/amp.ts
@@ -0,0 +1,144 @@
+import type { Database } from "bun:sqlite";
+import { existsSync, readFileSync, statSync } from "node:fs";
+import { homedir, platform } from "node:os";
+import { basename, join } from "node:path";
+import type { Invocation } from "../index";
+import { recordNewInvocations } from "../index";
+
+interface AmpMessage {
+	role?: string;
+	content?: Array<Record<string, unknown>>;
+}
+
+interface AmpThread {
+	id?: string;
+	created?: number;
+	messages?: AmpMessage[];
+}
+
+function getThreadsDirs(): string[] {
+	const os = platform();
+	const home = homedir();
+	const xdgData = process.env.XDG_DATA_HOME || join(home, ".local", "share");
+
+	if (os === "darwin") {
+		return [
+			join(xdgData, "amp", "threads"),
+			join(home, "Library", "Application Support", "amp", "threads"),
+			join(home, ".amp", "threads"),
+		];
+	}
+
+	if (os === "win32") {
+		const localAppData = process.env.LOCALAPPDATA || join(home, "AppData", "Local");
+		return [join(localAppData, "amp", "threads")];
+	}
+
+	return [join(xdgData, "amp", "threads"), join(home, ".amp", "threads")];
+}
+
+function getThreadFiles(): string[] {
+	const files = new Set<string>();
+	for (const dir of getThreadsDirs()) {
+		if (!existsSync(dir)) continue;
+		const glob = new Bun.Glob("*.json");
+		for (const rel of glob.scanSync({ cwd: dir })) {
+			files.add(join(dir, rel));
+		}
+	}
+	return [...files];
+}
+
+export function parseAmpThreadFile(
+	filePath: string,
+	knownSkills: Set<string> = new Set(),
+): Invocation[] {
+	const invocations: Invocation[] = [];
+
+	let raw: string;
+	try {
+		raw = readFileSync(filePath, "utf-8");
+	} catch {
+		return invocations;
+	}
+
+	let thread: AmpThread;
+	try {
+		thread = JSON.parse(raw) as AmpThread;
+	} catch {
+		return invocations;
+	}
+
+	const sessionId = `amp:${thread.id ?? basename(filePath, ".json")}`;
+	const baseTs =
+		typeof thread.created === "number"
+			? thread.created > 1_000_000_000_000
+				? thread.created
+				: thread.created * 1000
+			: (() => {
+					try {
+						return Math.floor(statSync(filePath).mtimeMs);
+					} catch {
+						return Date.now();
+					}
+				})();
+
+	if (!Array.isArray(thread.messages)) return invocations;
+
+	let eventOffset = 0;
+	for (let mi = 0; mi < thread.messages.length; mi++) {
+		const msg = thread.messages[mi];
+		if (!msg || !Array.isArray(msg.content)) continue;
+
+		for (let ci = 0; ci < msg.content.length; ci++) {
+			const item = msg.content[ci];
+			if (typeof item !== "object" || item === null) continue;
+
+			if (item.type !== "tool_use") continue;
+			if (item.name !== "skill") continue;
+
+			const input = item.input as Record<string, unknown> | undefined;
+			if (!input) continue;
+
+			const skillNameRaw = input.name ?? input.skill ?? input.skillName;
+			if (typeof skillNameRaw !== "string") continue;
+
+			const skillName = skillNameRaw.trim();
+			if (!skillName) continue;
+			if (knownSkills.size > 0 && !knownSkills.has(skillName)) continue;
+
+			const timestamp = new Date(baseTs + eventOffset).toISOString();
+			eventOffset += 1;
+
+			invocations.push({
+				skillName,
+				timestamp,
+				sessionId,
+				agent: "amp",
+			});
+		}
+	}
+
+	return invocations;
+}
+
+export function countAmpSessions(): number {
+	return getThreadFiles().length;
+}
+
+export async function scanAmpSessions(
+	db: Database,
+	trackedSet: Set<string>,
+	knownSkills: Set<string> = new Set(),
+): Promise<number> {
+	const files = getThreadFiles();
+	let total = 0;
+
+	for (const file of files) {
+		const invocations = parseAmpThreadFile(file, knownSkills);
+		total += recordNewInvocations(db, trackedSet, invocations);
+	}
+
+	return total;
+}
+
