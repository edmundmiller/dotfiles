+  private parseSessionFile(sessionId: string, filePath: string): SessionNotification[] {
+    const notifications: SessionNotification[] = []
+    const content = fs.readFileSync(filePath, "utf-8")
+    const lines = content.trim().split("\n").filter(Boolean)
+
+    for (const line of lines) {
+      try {
+        const entry = JSON.parse(line)
+
+        // Pi format: type === "message" with message.role
+        if (entry.type === "message" && entry.message) {
+          const role = entry.message.role
+          const msgContent = entry.message.content
+
+          if (role === "user") {
+            const text = this.extractTextFromContent(msgContent)
+            if (text) {
+              notifications.push({
+                sessionId,
+                update: {
+                  sessionUpdate: "user_message_chunk",
+                  content: { type: "text", text },
+                },
+              } as SessionNotification)
+            }
+          }
+
+          if (role === "assistant") {
+            // Process each content part
+            if (Array.isArray(msgContent)) {
+              for (const part of msgContent) {
+                if (part.type === "text" && part.text) {
+                  notifications.push({
+                    sessionId,
+                    update: {
+                      sessionUpdate: "agent_message_chunk",
+                      content: { type: "text", text: part.text },
+                    },
+                  } as SessionNotification)
+                }
+                if (part.type === "thinking" && part.thinking) {
+                  notifications.push({
+                    sessionId,
+                    update: {
+                      sessionUpdate: "agent_thought_chunk",
+                      content: { text: part.thinking },
+                    },
+                  } as SessionNotification)
+                }
+                if (part.type === "toolCall") {
+                  notifications.push({
+                    sessionId,
+                    update: {
+                      sessionUpdate: "tool_call",
+                      title: part.name || "tool",
+                      toolCallId: part.id || "",
+                      kind: part.name || "tool",
+                      locations: [],
+                    },
+                  } as SessionNotification)
+                }
+              }
+            } else if (typeof msgContent === "string") {
+              notifications.push({
+                sessionId,
+                update: {
+                  sessionUpdate: "agent_message_chunk",
+                  content: { type: "text", text: msgContent },
+                },
+              } as SessionNotification)
+            }
+          }
+        }
+
+        // Claude format: type === "user"/"assistant" with message.content
+        if ((entry.type === "user" || entry.type === "assistant") && entry.message?.content) {
+          const text = this.extractTextFromContent(entry.message.content)
+          if (text) {
+            const updateType = entry.type === "user" ? "user_message_chunk" : "agent_message_chunk"
+            notifications.push({
