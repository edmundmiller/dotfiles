diff --git a/packages/runtime/src/session-details.ts b/packages/runtime/src/session-details.ts
--- /dev/null
+++ b/packages/runtime/src/session-details.ts
@@ -0,0 +1,108 @@
+import type { MuxProvider } from "./contracts/mux";
+import type { SessionPaneData, SessionWindowData } from "./shared";
+
+interface SessionWindowInfo {
+  readonly id: string;
+  readonly sessionName: string;
+  readonly index: number;
+  readonly name: string;
+  readonly active: boolean;
+  readonly paneCount: number;
+}
+
+interface SessionPaneInfo {
+  readonly id: string;
+  readonly sessionName: string;
+  readonly windowId: string;
+  readonly windowIndex: number;
+  readonly index: number;
+  readonly active: boolean;
+  readonly cwd: string;
+  readonly command: string;
+  readonly title: string;
+}
+
+interface SessionDetailCapableProvider extends MuxProvider {
+  listSessionWindows(sessionName?: string): SessionWindowInfo[];
+  listSessionPanes(sessionName: string): SessionPaneInfo[];
+}
+
+export function isSessionDetailCapable(provider: MuxProvider): provider is SessionDetailCapableProvider {
+  return (
+    typeof provider.listSessionWindows === "function"
+    && typeof provider.listSessionPanes === "function"
+  );
+}
+
+function compareWindows(a: SessionWindowData, b: SessionWindowData): number {
+  if (a.index !== b.index) return a.index - b.index;
+  return a.name.localeCompare(b.name);
+}
+
+function comparePanes(a: SessionPaneData, b: SessionPaneData): number {
+  if (a.index !== b.index) return a.index - b.index;
+  return a.id.localeCompare(b.id);
+}
+
+function cleanTmuxText(text: string): string {
+  return text
+    .replace(/#\[[^\]]*]/g, "")
+    .replace(/#\{[^}]*}/g, "")
+    .trim();
+}
+
+function cleanPaneCommand(command: string): string {
+  const cleaned = cleanTmuxText(command);
+  return /^[A-Z_][A-Z0-9_]*=/.test(cleaned) ? "" : cleaned;
+}
+
+/** Detect base64 blobs or other binary noise that some tools write to pane_title. */
+function isGarbageTitle(title: string): boolean {
+  if (title.length > 200) return true;
+  if (/^Gm=0;/.test(title)) return true;
+  return false;
+}
+
+/** Returns true for panes that are opensessions infrastructure (REFOCUS helpers, sidebar). */
+function isInfraPane(pane: SessionPaneInfo): boolean {
+  if (/^REFOCUS_WINDOW=/.test(pane.command)) return true;
+  return false;
+}
+
+export function getSessionWindowData(provider: MuxProvider, sessionName: string): SessionWindowData[] {
+  if (!isSessionDetailCapable(provider)) return [];
+
+  const panesByWindow = new Map<string, SessionPaneData[]>();
+  for (const pane of provider.listSessionPanes(sessionName)) {
+    if (isInfraPane(pane)) continue;
+
+    const title = isGarbageTitle(pane.title) ? "" : cleanTmuxText(pane.title);
+    const panes = panesByWindow.get(pane.windowId) ?? [];
+    panes.push({
+      id: pane.id,
+      index: pane.index,
+      windowId: pane.windowId,
+      windowIndex: pane.windowIndex,
+      active: pane.active,
+      cwd: pane.cwd,
+      command: cleanPaneCommand(pane.command),
+      title,
+    });
+    panesByWindow.set(pane.windowId, panes);
+  }
+
+  for (const panes of panesByWindow.values()) {
+    panes.sort(comparePanes);
+  }
+
+  return provider.listSessionWindows(sessionName)
+    .map((window) => ({
+      id: window.id,
+      index: window.index,
+      name: cleanTmuxText(window.name),
+      active: window.active,
+      paneCount: window.paneCount,
+      panes: panesByWindow.get(window.id) ?? [],
+    }))
+    .sort(compareWindows);
+}
diff --git a/packages/runtime/test/session-details.test.ts b/packages/runtime/test/session-details.test.ts
--- /dev/null
+++ b/packages/runtime/test/session-details.test.ts
@@ -0,0 +1,157 @@
+import { describe, expect, test } from "bun:test";
+
+import type { MuxProvider } from "../src/contracts/mux";
+import { getSessionWindowData, isSessionDetailCapable } from "../src/session-details";
+
+function createBaseProvider(): MuxProvider {
+  return {
+    specificationVersion: "v1",
+    name: "test-mux",
+    listSessions: () => [],
+    switchSession: () => {},
+    getCurrentSession: () => null,
+    getSessionDir: () => "",
+    getPaneCount: () => 1,
+    getClientTty: () => "",
+    createSession: () => {},
+    killSession: () => {},
+    setupHooks: () => {},
+    cleanupHooks: () => {},
+  };
+}
+
+describe("session details", () => {
+  test("detects providers with session detail methods", () => {
+    const provider = {
+      ...createBaseProvider(),
+      listSessionWindows: () => [],
+      listSessionPanes: () => [],
+    };
+
+    expect(isSessionDetailCapable(provider)).toBe(true);
+  });
+
+  test("returns no window details when provider lacks session detail methods", () => {
+    expect(getSessionWindowData(createBaseProvider(), "alpha")).toEqual([]);
+  });
+
+  test("groups panes under windows in tmux order", () => {
+    const provider = {
+      ...createBaseProvider(),
+      listSessionWindows: (sessionName?: string) => {
+        if (sessionName !== "alpha") return [];
+
+        return [
+          {
+            id: "@2",
+            sessionName: "alpha",
+            index: 1,
+            name: "#[fg=cyan]●#[default] editor",
+            active: true,
+            paneCount: 2,
+          },
+          {
+            id: "@1",
+            sessionName: "alpha",
+            index: 0,
+            name: "shell",
+            active: false,
+            paneCount: 1,
+          },
+        ];
+      },
+      listSessionPanes: (sessionName: string) => {
+        if (sessionName !== "alpha") return [];
+
+        return [
+          {
+            id: "%3",
+            sessionName: "alpha",
+            windowId: "@2",
+            windowIndex: 1,
+            index: 1,
+            active: false,
+            cwd: "/tmp/logs",
+            command: "REFOCUS_WINDOW=@2",
+            title: "",
+          },
+          {
+            id: "%1",
+            sessionName: "alpha",
+            windowId: "@1",
+            windowIndex: 0,
+            index: 0,
+            active: false,
+            cwd: "/tmp/app",
+            command: "zsh",
+            title: "",
+          },
+          {
+            id: "%2",
+            sessionName: "alpha",
+            windowId: "@2",
+            windowIndex: 1,
+            index: 0,
+            active: true,
+            cwd: "/tmp/app",
+            command: "nvim",
+            title: "#[fg=green]main.ts#[default]",
+          },
+        ];
+      },
+    };
+
+    const result = getSessionWindowData(provider, "alpha");
+    expect(result).toEqual([
+      {
+        id: "@1",
+        index: 0,
+        name: "shell",
+        active: false,
+        paneCount: 1,
+        panes: [{ id: "%1", index: 0, windowId: "@1", windowIndex: 0, active: false, cwd: "/tmp/app", command: "zsh", title: "" }],
+      },
+      {
+        id: "@2",
+        index: 1,
+        name: "● editor",
+        active: true,
+        paneCount: 2,
+        panes: [{ id: "%2", index: 0, windowId: "@2", windowIndex: 1, active: true, cwd: "/tmp/app", command: "nvim", title: "main.ts" }],
+      },
+    ]);
+  });
+
+  test("filters REFOCUS_WINDOW infrastructure panes", () => {
+    const provider = {
+      ...createBaseProvider(),
+      listSessionWindows: () => [
+        { id: "@1", sessionName: "s", index: 0, name: "win", active: true, paneCount: 2 },
+      ],
+      listSessionPanes: () => [
+        { id: "%1", sessionName: "s", windowId: "@1", windowIndex: 0, index: 0, active: true, cwd: "/tmp", command: "zsh", title: "" },
+        { id: "%2", sessionName: "s", windowId: "@1", windowIndex: 0, index: 1, active: false, cwd: "/tmp", command: "REFOCUS_WINDOW=@1", title: "" },
+      ],
+    };
+
+    const result = getSessionWindowData(provider, "s");
+    expect(result[0].panes).toHaveLength(1);
+    expect(result[0].panes[0].id).toBe("%1");
+  });
+
+  test("sanitizes base64 blob pane titles", () => {
+    const blobTitle = "Gm=0;Ta677jpOnTpF13UcHR2xXC5prfHUpz4V2zzkIQ/h5V7u5Tg8PASg6zr" + "A".repeat(200);
+    const provider = {
+      ...createBaseProvider(),
+      listSessionWindows: () => [
+        { id: "@1", sessionName: "s", index: 0, name: "win", active: true, paneCount: 1 },
+      ],
+      listSessionPanes: () => [
+        { id: "%1", sessionName: "s", windowId: "@1", windowIndex: 0, index: 0, active: true, cwd: "/tmp/app", command: "node", title: blobTitle },
+      ],
+    };
+
+    const result = getSessionWindowData(provider, "s");
+    expect(result[0].panes[0].title).toBe("");
+  });
+});
