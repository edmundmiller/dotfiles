diff --git a/packages/runtime/test/session-details.test.ts b/packages/runtime/test/session-details.test.ts
--- /dev/null
+++ b/packages/runtime/test/session-details.test.ts	2026-04-01 23:27:21.732548174 -0500
@@ -0,0 +1,165 @@
+import { describe, expect, test } from "bun:test";
+
+import type { MuxProvider } from "../src/contracts/mux";
+import { getSessionWindowData, isSessionDetailCapable } from "../src/session-details";
+
+function createBaseProvider(): MuxProvider {
+  return {
+    specificationVersion: "v1",
+    name: "test-mux",
+    listSessions: () => [],
+    switchSession: () => {},
+    getCurrentSession: () => null,
+    getSessionDir: () => "",
+    getPaneCount: () => 1,
+    getClientTty: () => "",
+    createSession: () => {},
+    killSession: () => {},
+    setupHooks: () => {},
+    cleanupHooks: () => {},
+  };
+}
+
+describe("session details", () => {
+  test("detects providers with session detail methods", () => {
+    const provider = {
+      ...createBaseProvider(),
+      listSessionWindows: () => [],
+      listSessionPanes: () => [],
+    };
+
+    expect(isSessionDetailCapable(provider)).toBe(true);
+  });
+
+  test("returns no window details when provider lacks session detail methods", () => {
+    expect(getSessionWindowData(createBaseProvider(), "alpha")).toEqual([]);
+  });
+
+  test("groups panes under windows in tmux order", () => {
+    const provider = {
+      ...createBaseProvider(),
+      listSessionWindows: (sessionName?: string) => {
+        if (sessionName !== "alpha") return [];
+
+        return [
+          {
+            id: "@2",
+            sessionName: "alpha",
+            index: 1,
+            name: "#[fg=cyan]●#[default] editor",
+            active: true,
+            paneCount: 2,
+          },
+          {
+            id: "@1",
+            sessionName: "alpha",
+            index: 0,
+            name: "shell",
+            active: false,
+            paneCount: 1,
+          },
+        ];
+      },
+      listSessionPanes: (sessionName: string) => {
+        if (sessionName !== "alpha") return [];
+
+        return [
+          {
+            id: "%3",
+            sessionName: "alpha",
+            windowId: "@2",
+            windowIndex: 1,
+            index: 1,
+            active: false,
+            cwd: "/tmp/project",
+            command: "vim",
+            title: "README.md",
+          },
+          {
+            id: "%1",
+            sessionName: "alpha",
+            windowId: "@1",
+            windowIndex: 0,
+            index: 0,
+            active: true,
+            cwd: "/tmp/project",
+            command: "zsh",
+            title: "shell",
+          },
+          {
+            id: "%2",
+            sessionName: "alpha",
+            windowId: "@2",
+            windowIndex: 1,
+            index: 0,
+            active: true,
+            cwd: "/tmp/project",
+            command: "REFOCUS_WINDOW=@2 helper",
+            title: "ignored",
+          },
+        ];
+      },
+    };
+
+    expect(getSessionWindowData(provider, "alpha")).toEqual([
+      {
+        id: "@1",
+        index: 0,
+        name: "shell",
+        active: false,
+        paneCount: 1,
+        panes: [
+          {
+            id: "%1",
+            index: 0,
+            windowId: "@1",
+            windowIndex: 0,
+            active: true,
+            cwd: "/tmp/project",
+            command: "zsh",
+            title: "shell",
+          },
+        ],
+      },
+      {
+        id: "@2",
+        index: 1,
+        name: "● editor",
+        active: true,
+        paneCount: 2,
+        panes: [
+          {
+            id: "%3",
+            index: 1,
+            windowId: "@2",
+            windowIndex: 1,
+            active: false,
+            cwd: "/tmp/project",
+            command: "vim",
+            title: "README.md",
+          },
+        ],
+      },
+    ]);
+  });
+
+  test("sanitizes base64 blob pane titles", () => {
+    const provider = {
+      ...createBaseProvider(),
+      listSessionWindows: () => [{ id: "@1", sessionName: "alpha", index: 0, name: "shell", active: true, paneCount: 1 }],
+      listSessionPanes: () => [{
+        id: "%1",
+        sessionName: "alpha",
+        windowId: "@1",
+        windowIndex: 0,
+        index: 0,
+        active: true,
+        cwd: "/tmp/project",
+        command: "bash",
+        title: `Gm=0;${"A".repeat(240)}`,
+      }],
+    };
+
+    expect(getSessionWindowData(provider, "alpha")[0]?.panes[0]?.title).toBe("");
+  });
+});
