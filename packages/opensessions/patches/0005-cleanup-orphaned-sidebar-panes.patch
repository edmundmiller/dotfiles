+import type { SidebarPane } from "../contracts/mux";
+
+export function isOrphanedSidebarPane(pane: SidebarPane): boolean {
+  return pane.width != null && pane.windowWidth != null && pane.width >= pane.windowWidth;
+}
+
+export function partitionSidebarPanes(panes: readonly SidebarPane[]): {
+  attached: SidebarPane[];
+  orphaned: SidebarPane[];
+} {
+  const attached: SidebarPane[] = [];
+  const orphaned: SidebarPane[] = [];
+
+  for (const pane of panes) {
+    if (isOrphanedSidebarPane(pane)) orphaned.push(pane);
+    else attached.push(pane);
+  }
+
+  return { attached, orphaned };
+}
