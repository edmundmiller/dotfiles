diff --git a/packages/runtime/test/sidebar-orphans.test.ts b/packages/runtime/test/sidebar-orphans.test.ts
new file mode 100644
--- /dev/null
+++ b/packages/runtime/test/sidebar-orphans.test.ts
@@ -0,0 +1,41 @@
+import { describe, expect, test } from "bun:test";
+
+import type { SidebarPane } from "../src/contracts/mux";
+import { isOrphanedSidebarPane, partitionSidebarPanes } from "../src/server/sidebar-orphans";
+
+describe("sidebar orphan detection", () => {
+  test("detects full-window sidebar panes as orphaned", () => {
+    const pane: SidebarPane = {
+      paneId: "%1",
+      sessionName: "alpha",
+      windowId: "@1",
+      width: 224,
+      windowWidth: 224,
+    };
+
+    expect(isOrphanedSidebarPane(pane)).toBe(true);
+  });
+
+  test("does not flag attached sidebars as orphaned", () => {
+    const pane: SidebarPane = {
+      paneId: "%1",
+      sessionName: "alpha",
+      windowId: "@1",
+      width: 29,
+      windowWidth: 224,
+    };
+
+    expect(isOrphanedSidebarPane(pane)).toBe(false);
+  });
+
+  test("partitions panes into attached and orphaned groups", () => {
+    const panes: SidebarPane[] = [
+      { paneId: "%1", sessionName: "alpha", windowId: "@1", width: 29, windowWidth: 224 },
+      { paneId: "%2", sessionName: "alpha", windowId: "@2", width: 224, windowWidth: 224 },
+    ];
+
+    const { attached, orphaned } = partitionSidebarPanes(panes);
+
+    expect(attached.map((pane) => pane.paneId)).toEqual(["%1"]);
+    expect(orphaned.map((pane) => pane.paneId)).toEqual(["%2"]);
+  });
+});
