Subject: [PATCH 3/4] patch: update help text for Prefix keybindings

---
 src/main.ts | 30 +++++++++++++++---------------
 1 file changed, 15 insertions(+), 15 deletions(-)

diff --git a/src/main.ts b/src/main.ts
index a7fffa3..2ba7282 100644
--- a/src/main.ts
+++ b/src/main.ts
@@ -98,15 +98,15 @@ Agent Control (JSON output):
 
 Keybindings:
   Ctrl-Shift-Up/Down       Switch sessions
-  Ctrl-a n                 New session / worktree
-  Ctrl-a c                 New window
-  Ctrl-a z                 Toggle pane zoom
-  Ctrl-a Arrows            Resize panes
-  Ctrl-a p                 Command palette
-  Ctrl-a g                 Toggle diff panel (on/off)
-  Ctrl-a z                 Zoom diff panel (split ↔ full, when focused)
-  Ctrl-a Tab               Switch focus (tmux ↔ diff)
-  Ctrl-a i                 Settings
+  Prefix M                 New session / worktree
+  Prefix c                 New window
+  Prefix z                 Toggle pane zoom
+  Prefix Arrows            Resize panes
+  Prefix p                 Command palette
+  Prefix g                 Toggle diff panel (on/off)
+  Prefix z                 Zoom diff panel (split ↔ full, when focused)
+  Prefix Tab               Switch focus (tmux ↔ diff)
+  Prefix i                 Settings
   Click sidebar            Switch to session
 
 https://github.com/jarredkenny/jmux`;
@@ -3244,12 +3244,12 @@ async function start(): Promise<void> {
       [{ text: "Essential keybindings", attrs: b }],
       [],
       [{ text: "Ctrl-Shift-Up/Down", attrs: g }, { text: "     Switch between sessions", attrs: n }],
