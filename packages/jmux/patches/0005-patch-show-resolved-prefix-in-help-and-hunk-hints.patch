From: Edmund Miller <git@edmundmiller.dev>
Date: Wed, 29 Apr 2026 12:31:34 -0400
Subject: [PATCH] patch: show resolved prefix in all help and hunk hints

---
 src/diff-panel.ts |  16 ++++-
 src/main.ts       | 153 ++++++++++++++++++++--------------------------
 2 files changed, 80 insertions(+), 89 deletions(-)

diff --git a/src/diff-panel.ts b/src/diff-panel.ts
index 5d4979c..3e0bb39 100644
--- a/src/diff-panel.ts
+++ b/src/diff-panel.ts
@@ -9,7 +9,16 @@ const HINT_KEY: CellAttrs = { fg: 2, fgMode: ColorMode.Palette };
 
 const MIN_PANEL_COLS = 20;
 
+const resolvePrefixLabel = (): string => {
+  const raw = process.env.JMUX_PREFIX_KEY ?? "C-a";
+  const normalized = raw.trim().toLowerCase();
+  const match = normalized.match(/^(?:c|ctrl)-(.+)$/);
+  if (match) return `Ctrl-${match[1]}`;
+  return raw;
+};
+
 export class DiffPanel {
+  private readonly prefixLabel = resolvePrefixLabel();
   private _state: DiffPanelState = "off";
   private _hunkExited = false;
 
@@ -61,14 +70,15 @@ export class DiffPanel {
   getEmptyGrid(cols: number, rows: number): CellGrid {
     const grid = createGrid(cols, rows);
     const centerRow = Math.floor(rows / 2);
-    const line1 = "Press Ctrl-a g to close";
+    const line1 = `Press ${this.prefixLabel} g to close`;
     const line2 = "Switch sessions to reload";
+    const keyHint = `${this.prefixLabel} g`;
     const col1 = Math.max(0, Math.floor((cols - line1.length) / 2));
     const col2 = Math.max(0, Math.floor((cols - line2.length) / 2));
 
     writeString(grid, centerRow - 1, col1, "Press ", HINT_FG);
-    writeString(grid, centerRow - 1, col1 + 6, "Ctrl-a g", HINT_KEY);
-    writeString(grid, centerRow - 1, col1 + 14, " to close", HINT_FG);
+    writeString(grid, centerRow - 1, col1 + 6, keyHint, HINT_KEY);
+    writeString(grid, centerRow - 1, col1 + 6 + keyHint.length, " to close", HINT_FG);
     writeString(grid, centerRow, col2, line2, HINT_FG);
     return grid;
   }
