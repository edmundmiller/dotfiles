+const resolvePrefixLabel = (): string => {
+  const raw = process.env.JMUX_PREFIX_KEY ?? "C-a";
+  const normalized = raw.trim().toLowerCase();
+  const match = normalized.match(/^(?:c|ctrl)-(.+)$/);
+  if (match) return `Ctrl-${match[1]}`;
+  return raw;
+};
+
+const resolveNewSessionKeyLabel = (): string =>
+  (process.env.JMUX_NEW_SESSION_KEY ?? "M").slice(0, 1);
+
+const PREFIX_LABEL = resolvePrefixLabel();
+const NEW_SESSION_KEY_LABEL = resolveNewSessionKeyLabel();
+const prefixCombo = (key: string): string => `${PREFIX_LABEL} ${key}`;
+
 function checkBunVersion(): void {
   // parseInt parses leading digits and stops at the first non-digit, so
   // canary/prerelease suffixes like "1.3.8-pre.1" survive intact.
@@ -98,15 +113,15 @@ Agent Control (JSON output):
 
 Keybindings:
   Ctrl-Shift-Up/Down       Switch sessions
-  Prefix M                 New session / worktree
-  Prefix c                 New window
-  Prefix z                 Toggle pane zoom
-  Prefix Arrows            Resize panes
-  Prefix p                 Command palette
-  Prefix g                 Toggle diff panel (on/off)
-  Prefix z                 Zoom diff panel (split ↔ full, when focused)
-  Prefix Tab               Switch focus (tmux ↔ diff)
-  Prefix i                 Settings
+  ${prefixCombo(NEW_SESSION_KEY_LABEL)}                 New session / worktree
+  ${prefixCombo("c")}                 New window
+  ${prefixCombo("z")}                 Toggle pane zoom
+  ${prefixCombo("Arrows")}            Resize panes
+  ${prefixCombo("p")}                 Command palette
+  ${prefixCombo("g")}                 Toggle diff panel (on/off)
+  ${prefixCombo("z")}                 Zoom diff panel (split ↔ full, when focused)
+  ${prefixCombo("Tab")}               Switch focus (tmux ↔ diff)
+  ${prefixCombo("i")}                 Settings
   Click sidebar            Switch to session
 
 https://github.com/jarredkenny/jmux`;
@@ -2201,6 +2216,47 @@ function getNewSessionProviders(preScannedDirs: string[]): NewSessionProviders {
   };
 }
 
+function buildWelcomeLines(): StyledLine[] {
+  const g: CellAttrs = { fg: 2, fgMode: 1, bg: MODAL_BG, bgMode: 2 };
+  const b: CellAttrs = { bold: true, bg: MODAL_BG, bgMode: 2 };
+  const d: CellAttrs = { fg: 8, fgMode: 1, dim: true, bg: MODAL_BG, bgMode: 2 };
+  const n: CellAttrs = { bg: MODAL_BG, bgMode: 2 };
+  const c: CellAttrs = { fg: 6, fgMode: 1, bg: MODAL_BG, bgMode: 2 };
+  const y: CellAttrs = { fg: 3, fgMode: 1, bg: MODAL_BG, bgMode: 2 };
+
+  const binding = (key: string): string => `${prefixCombo(key)}`.padEnd(28, " ");
+
+  return [
+    [{ text: "The terminal workspace for agentic development", attrs: d }],
+    [],
+    [{ text: "─".repeat(44), attrs: d }],
+    [],
+    [{ text: "Essential keybindings", attrs: b }],
+    [],
+    [{ text: "Ctrl-Shift-Up/Down", attrs: g }, { text: "     Switch between sessions", attrs: n }],
+    [{ text: binding(NEW_SESSION_KEY_LABEL), attrs: g }, { text: "New session", attrs: n }],
+    [{ text: binding("c"), attrs: g }, { text: "New window (tab)", attrs: n }],
+    [{ text: binding("|"), attrs: g }, { text: "Split pane horizontally", attrs: n }],
+    [{ text: binding("-"), attrs: g }, { text: "Split pane vertically", attrs: n }],
+    [{ text: "Shift-Arrow", attrs: g }, { text: "            Move between panes", attrs: n }],
+    [{ text: binding("p"), attrs: g }, { text: "Command palette", attrs: n }],
+    [],
+    [{ text: "─".repeat(44), attrs: d }],
+    [],
+    [{ text: "The sidebar", attrs: b }, { text: " on the left shows all your sessions.", attrs: n }],
+    [{ text: "●", attrs: g }, { text: " Green dot = new output    ", attrs: n }, { text: "!", attrs: y }, { text: " Orange = needs review", attrs: n }],
+    [{ text: "Click a session to switch to it.", attrs: n }],
+    [],
+    [{ text: "─".repeat(44), attrs: d }],
+    [],
+    [{ text: "Next steps", attrs: b }],
+    [],
+    [{ text: "1.", attrs: c }, { text: " Try ", attrs: n }, { text: prefixCombo("p"), attrs: g }, { text: " to open the command palette", attrs: n }],
+    [{ text: "2.", attrs: c }, { text: " Run ", attrs: n }, { text: "jmux --install-agent-hooks", attrs: g }, { text: " for Claude Code notifications", attrs: n }],
+    [{ text: "3.", attrs: c }, { text: " Full guide: ", attrs: n }, { text: "github.com/jarredkenny/jmux", attrs: d }],
+  ];
+}
