{
  // Docs: https://github.com/badlogic/pi-mono/blob/main/packages/coding-agent/docs/settings.md
  "$schema": "./settings-schema.json",
  // Model configuration
  "defaultProvider": "openai-codex",
  "defaultModel": "gpt-5.4",
  "defaultThinkingLevel": "high",
  // Model cycling - Ctrl+P to toggle between these
  "enabledModels": ["gpt-5.4", "gpt-5.3-codex", "claude-opus-4-6", "gpt-5.4-mini"],
  // UI preferences
  "theme": "terminal",
  "quietStartup": false,
  "doubleEscapeAction": "tree",
  "editorPaddingX": 1,
  // Compaction - keep more context for complex tasks
  "compaction": {
    "enabled": true,
    "reserveTokens": 16384,
    "keepRecentTokens": 24000,
  },
  // Retry configuration
  "retry": {
    "enabled": true,
    "maxRetries": 3,
    "baseDelayMs": 2000,
  },
  // Message delivery - one at a time for control
  "steeringMode": "one-at-a-time",
  "followUpMode": "one-at-a-time",
  // Images
  "images": {
    "autoResize": true,
    "blockImages": false,
  },
  // Skills as commands - also registers skills as /skill:name slash commands
  // Docs: https://github.com/badlogic/pi-mono/blob/main/packages/coding-agent/docs/skills.md
  "enableSkillCommands": true,
  // Security guardrails - file policies + permission gate + hook/signing enforcement
  // Config: ~/.pi/agent/extensions/guardrails.json (nix-managed)
  // Docs: https://github.com/aliou/pi-guardrails
  // Packages - https://github.com/badlogic/pi-mono/blob/main/packages/coding-agent/docs/packages.md
  "packages": [
    {
      "source": "shitty-extensions",
      "extensions": [
        "clipboard.ts",
        "oracle.ts",
        "memory-mode.ts",
        "plan-mode.ts",
        "handoff.ts",
        "usage-bar.ts",
        "ultrathink.ts",
        "status-widget.ts",
        "cost-tracker.ts",
        "funny-working-message.ts",
        "speedreading.ts",
        "loop.ts",
        "process-info.ts", // writes PID/tmux pane/session/status into session JSONL (for pi-sessions picker)
      ],
      "skills": [],
    },
    // Git-backed agent memory filesystem (inspired by Letta Code)
    "~/.config/dotfiles/pi-packages/pi-context-repo",
    // Dynamic context pruning - forked from https://github.com/zenobi-us/pi-dcp
    "~/.config/dotfiles/pi-packages/pi-dcp",
    // Agentic context management (/acm, /context, context_* tools) - https://github.com/ttttmr/pi-context
    "npm:pi-context",
    // Repo-local QMD workflow (/qmd, /qp) and qmd-cli-first guidance
    "~/.config/dotfiles/pi-packages/pi-qmd",
    // Secure web fetch – HTML→markdown via mdream, secret scanning, injection detection
    "~/.config/dotfiles/pi-packages/pi-scurl",
    // Auto-load direnv env at session start
    "~/.config/dotfiles/pi-packages/pi-direnv",
    // Force non-interactive bash defaults + block interactive hang patterns
    "~/.config/dotfiles/pi-packages/pi-non-interactive",
    // Agentmap codebase tree in system prompt - https://github.com/remorses/agentmap
    "~/.config/dotfiles/pi-packages/pi-agentmap",

    // Prompt construction toolkit
    "npm:pi-promptsmith",
    // Cross-agent thread reader (agents:// URIs)
    "~/.config/dotfiles/pi-packages/pi-xurl",
    // Rhubarb Pi collection - https://github.com/qualisero/rhubarb-pi
    {
      "source": "https://github.com/qualisero/rhubarb-pi",
      "extensions": [
        "hooks/session-color/**",

        // "extensions/pi-agent-scip/**" // SCIP for typescript/python - requires scip CLI
      ],
    },
    // tmustier extensions - https://github.com/tmustier/pi-extensions
    {
      "source": "git:github.com/tmustier/pi-extensions",
      "extensions": [
        "tab-status/tab-status.ts",
        "files-widget/index.ts",
        "code-actions/index.ts", // /code to pick code blocks from messages
        "raw-paste/index.ts", // /paste for raw clipboard paste
        "agent-guidance/agent-guidance.ts", // Agent guidance/steering
      ],
      "skills": [],
    },
    // Security guardrails - https://github.com/aliou/pi-guardrails
    "npm:@aliou/pi-guardrails",
    // LSP - standalone npm package (extracted from pi-hooks)
    "npm:lsp-pi",
    // Amp-like features (session query, handoff) - https://github.com/pasky/pi-amplike
    {
      "source": "https://github.com/pasky/pi-amplike",
      "extensions": ["extensions/session-query.ts", "extensions/handoff.ts"],
      "skills": ["skills/session-query"],
    },
    // Branch-aware session context rollback + /checkpoint - https://github.com/uriafranko/pi-rollback
    "https://github.com/uriafranko/pi-rollback",
    // GitHub repo tools (read/search/explore) - https://github.com/PriNova/pi-github-tools
    "npm:@prinova/pi-github-tools",
    // Read tool structural maps for large files - https://github.com/Whamp/pi-read-map
    "npm:pi-read-map",
    // Read mode for focused/large-file reading workflows
    "npm:pi-read-mode",
    // Self-updating markdown docs for pi - https://github.com/Michaelliv/pi-magic-docs
    "npm:pi-magic-docs",
    // Task management authority: use @tintinweb/pi-tasks for /tasks + Task* tools
    // Conflict note: pi-beads also registers /tasks; keep disabled unless pi-tasks is removed
    // "~/.config/dotfiles/pi-packages/pi-beads",

    // Usage quota widget (bundles sub-core) - https://github.com/marckrenn/pi-sub
    "npm:@marckrenn/pi-sub-bar",
    // /limits command - provider usage bars via sub-core
    // https://gist.github.com/airtonix/25b4aee6f4a6a775aff028adfdb9936f
    "~/.pi/agent/extensions/sub-limits.ts",
    // Multi-edit extension (edits[]) from gist (SSH git source)
    {
      "source": "git:git@gist.github.com:30c35e985b5ca59f8e6f69a66520d487.git",
      "extensions": ["edit.ts"],
      "skills": [],
    },
    // Semaphore/lock primitives (dep of pi-tmux) - https://github.com/offline-ant/pi-semaphore
    {
      "source": "git:github.com/offline-ant/pi-semaphore",
      "extensions": ["extensions/semaphore-locks.ts"],
      "skills": [],
    },
    // Auto-name tmux windows + session titles from first prompt - https://github.com/default-anton/pi-tmux-window-name
    "npm:pi-tmux-window-name",
    // We're experimenting with tmux pane control for now (bash, capture, send, kill, spawn agents) - https://github.com/ogulcancelik/pi-extensions
    {
      "source": "git:github.com/ogulcancelik/pi-extensions",
      "extensions": ["packages/pi-tmux/index.ts"],
      "skills": [],
    },
    // Side agents in tmux windows + git worktrees - https://github.com/pasky/pi-side-agents
    "https://github.com/pasky/pi-side-agents",
    // Dumb zone - context degradation warning (forked from @aliou/pi-extensions)
    "~/.config/dotfiles/pi-packages/pi-dumb-zone",
    // BUG dotfiles-n579: frontmatter warnings on CHANGELOG.md/README.md
    // "npm:visual-explainer",
    // Thinking timer widget - https://www.npmjs.com/package/pi-thinking-timer
    "npm:pi-thinking-timer",
    // Ghostty title bar, spinner, progress bar - https://github.com/HazAT/pi-ghostty
    "npm:pi-ghostty",
    // Multi-agent messaging/coordination - https://github.com/nicobailon/pi-messenger
    "npm:pi-messenger",
    // Interactive shell tool - https://github.com/nicobailon/pi-interactive-shell
    "npm:pi-interactive-shell",
    // Powerline-style editor footer/statusline - https://github.com/nicobailon/pi-powerline-footer
    "npm:pi-powerline-footer",
    // Multi-functional task list/DAG orchestration - https://www.npmjs.com/package/@tintinweb/pi-tasks
    "npm:@tintinweb/pi-tasks",
    // Subagent delegation with chains, parallel execution, TUI - https://www.npmjs.com/package/@tintinweb/pi-subagents
    "npm:@tintinweb/pi-subagents",
    // MCP adapter - lazy-load MCP servers without burning context - https://github.com/nicobailon/pi-mcp-adapter
    "npm:pi-mcp-adapter",
    // Browser/web access tool - https://github.com/nicobailon/pi-web-access
    "npm:pi-web-access",
    // Perplexity-powered web search (requires Bun + Perplexity Pro/Max) - https://github.com/ivanrvpereira/pi-perplexity
    "npm:pi-perplexity",
    // MCPorter bridge - composable MCP server orchestration - https://github.com/mavam/pi-mcporter
    "npm:pi-mcporter",
    // GitNexus knowledge graph - auto-enriches reads/searches with call chains - https://github.com/tintinweb/pi-gitnexus
    "npm:pi-gitnexus",
    // OpenCode-style tool call/result rendering - https://github.com/MasuRii/pi-tool-display
    "npm:pi-tool-display",
    // Verbosity controls for concise/detailed responses - npm package
    "npm:pi-verbosity-control",
    // RTK token reduction via tool hooks - ~30-40% upload token savings - https://github.com/mcowger/pi-rtk
    "npm:pi-rtk",
    // Web research — clean fetch, pluggable search, scout subagent - https://github.com/iaptsiauri/pi-surf
    // "npm:pi-surf",
    // Programmatic Tool Calling (Python async orchestration) - https://github.com/cegersdoerfer/pi-ptc
    "git:github.com/cegersdoerfer/pi-ptc",
    // Interlude UI/UX enhancements - https://github.com/mjakl/pi-interlude
    "git:github.com/mjakl/pi-interlude",
    // Token burden visualization/management - https://github.com/Whamp/pi-token-burden
    "git:github.com/Whamp/pi-token-burden",
    // OpenAI compaction controls - https://www.npmjs.com/package/@jordyvd/pi-openai-compaction
    // "npm:@jordyvd/pi-openai-compaction",
    // Custom compaction model/template/trigger policy - https://github.com/nicobailon/pi-custom-compaction
    "npm:pi-custom-compaction",
    // Algorithmic conversation compactor - https://www.npmjs.com/package/@sting8k/pi-vcc
    "npm:@sting8k/pi-vcc",
    // Codex conversion helper - https://www.npmjs.com/package/@howaboua/pi-codex-conversion
    // DISABLED: conflicts with pi-web-access on web_search tool
    // "npm:@howaboua/pi-codex-conversion",
    // Kilo provider (300+ models via Kilo Gateway/OpenRouter-compatible)
    // Enables provider id: kilo (e.g., model: kilocode/auto)
    "git:github.com/mrexodia/kilo-pi-provider",
    // Live bash output view enhancements - vendored local copy
    // FIXME: switch back to upstream once signal typing + conflict-free tool naming fix lands in lucasmeijer/pi-bash-live-view
    "~/.config/dotfiles/pi-packages/pi-bash-live-view",
    // Terminal/UI animations - https://www.npmjs.com/package/pi-animations
    "npm:pi-animations",
    // Image attachments helper - vendored local copy to match current pi-tui keybinding API
    "~/.config/dotfiles/pi-packages/pi-image-attachments",
    // Automatic model switching workflows (e.g. Kimi ↔ Codex handoff)
    "npm:pi-model-switch",
    // Autonomous experiment loop (widget + /autoresearch + autoresearch-create skill)
    // FIXME MAKE IT STOP https://github.com/davebcn87/pi-autoresearch/issues/6
    // "https://github.com/davebcn87/pi-autoresearch",
    // WakaTime heartbeats + AI coding metrics - https://www.npmjs.com/package/pi-wakatime
    "npm:pi-wakatime",
    // Credential-injecting curl wrapper CLI for agents - https://www.npmjs.com/package/latchkey
    "npm:latchkey",
    // AskUserQuestion tool — structured clarification before acting - https://github.com/ghoseb/pi-askuserquestion
    {
      "source": "git:github.com/ghoseb/pi-askuserquestion",
      "extensions": ["src/index.ts"],
      "skills": [],
    },
    // Native diff review window with Monaco + annotations - https://github.com/badlogic/pi-diff-review
    "git:https://github.com/badlogic/pi-diff-review",
    // Pierre-themed inline diff rendering for edit/write tool results - https://github.com/tanvesh01/pierre-diffs
    // DISABLED: conflicts with pi-tool-display on edit/write tools
    // "git:github.com/tanvesh01/pierre-diffs",
  ],
}
