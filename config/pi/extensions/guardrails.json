{
  "enabled": true,
  "features": {
    "policies": true,
    "permissionGate": false
  },
  "policies": {
    "rules": [
      {
        "id": "secret-files",
        "description": "Files containing secrets",
        "patterns": [
          { "pattern": ".env" },
          { "pattern": ".env.local" },
          { "pattern": ".env.production" },
          { "pattern": ".env.prod" },
          { "pattern": ".dev.vars" }
        ],
        "allowedPatterns": [
          { "pattern": ".env.example" },
          { "pattern": ".env.sample" },
          { "pattern": ".env.test" }
        ],
        "protection": "noAccess",
        "onlyIfExists": true
      },
      {
        "id": "agenix-keys",
        "description": "Age-encrypted secrets (agenix)",
        "patterns": [{ "pattern": "*.age" }],
        "allowedPatterns": [{ "pattern": "secrets.nix" }],
        "protection": "readOnly",
        "onlyIfExists": true
      }
    ]
  }
}
