{
  "$schema": "https://raw.githubusercontent.com/gotgenes/pi-permission-system/main/schemas/permissions.schema.json",
  "debugLog": false,
  "permissionReviewLog": true,
  "yoloMode": true,
  "permission": {
    "*": "allow",
    "path": {
      "*": "allow",
      "*.env": "deny",
      "*.env.*": "deny",
      "*.env.example": "allow",
      "~/.ssh/*": "deny"
    },
    "external_directory": "allow",
    "doom_loop": "deny",
    "bash": {
      "*": "allow",
      "*darwin-rebuild*switch*": "deny",
      "*nixos-rebuild switch*": "deny",
      "*nixos-rebuild boot*": "deny",
      "*switch-to-configuration switch*": "deny",
      "*switch-to-configuration boot*": "deny",
      "*ssh*nuc*nixos-rebuild*": "deny",
      "*ssh*nuc*switch-to-configuration*": "deny",
      "*home-manager switch*": "deny",
      "*NIXOS_NO_CHECK*": "deny",
      "*deploy-rs*": "deny",
      "*nix run .#deploy-rs*": "deny",
      "*nix*#nixosConfigurations.nuc*": "deny",
      "*nixos-rebuild*--flake*#nuc*": "deny",
      "*--no-verify*": "deny",
      "*--no-gpg-sign*": "deny",
      "*commit.gpgsign=false*": "deny",
      "*core.hooksPath*": "deny",
      "*git commit*--author*": "deny",
      "*-c user.email=*": "deny",
      "*-c user.name=*": "deny",
      "*GIT_AUTHOR_NAME=*": "deny",
      "*GIT_AUTHOR_EMAIL=*": "deny",
      "*GIT_COMMITTER_NAME=*": "deny",
      "*GIT_COMMITTER_EMAIL=*": "deny",
      "*HUSKY=0*": "deny",
      "*SKIP=*": "deny",
      "*SKIP_PREPARE_COMMIT_MSG=*": "deny",
      "*SKIP_PRE_COMMIT=*": "deny",
      "*PRE_COMMIT_ALLOW_NO_CONFIG=*": "deny",
      "*git rebase -i*": "deny",
      "*git rebase --interactive*": "deny",
      "*git add -p*": "deny",
      "*git add --patch*": "deny",
      "*git mergetool*": "deny",
      "*git difftool*": "deny",
      "*git gui*": "deny",
      "*git citool*": "deny",
      "*git -c sequence.editor=: rebase -i*": "allow",
      "*git -c sequence.editor=true rebase -i*": "allow",
      "*GIT_SEQUENCE_EDITOR=:*git rebase -i*": "allow",
      "*GIT_SEQUENCE_EDITOR=true*git rebase -i*": "allow",
      "*GIT_EDITOR=vim*git rebase*": "deny",
      "*GIT_EDITOR=nvim*git rebase*": "deny",
      "*GIT_SEQUENCE_EDITOR=vim*git rebase*": "deny",
      "*GIT_SEQUENCE_EDITOR=nvim*git rebase*": "deny",
      "git commit": "deny",
      "*&& git commit": "deny",
      "*git commit -n*": "deny",
      "*git commit * -n*": "deny",
      "*sudo reboot*": "deny",
      "* reboot*": "deny",
      "reboot*": "deny",
      "*shutdown -r*": "deny",
      "*shutdown now*": "deny",
      "*poweroff*": "deny",
      "*systemctl reboot*": "deny",
      "*systemctl poweroff*": "deny",
      "*ssh*nuc*reboot*": "deny",
      "*ssh*nuc*shutdown*": "deny",
      "*ssh*nuc*poweroff*": "deny",
      "*ssh*nuc*systemctl reboot*": "deny",
      "*ssh*nuc*systemctl poweroff*": "deny",
      "*sudo nix-store --delete*": "deny",
      "*nix-store --delete*": "deny",
      "*nix store delete*": "deny",
      "*sudo rm -rf /nix/store*": "deny",
      "*sudo rm -rf /var/lib/nix*": "deny",
      "*rm -rf ~/.cache/nix*": "deny",
      "*flake-registry.json*": "deny",
      "*nix registry pin*": "deny",
      "*nix-collect-garbage*": "deny",
      "*nix store gc*": "deny",
      "*ssh*nuc*nix-collect-garbage*": "deny",
      "*ssh*nuc*nix store gc*": "deny",
      "*brew bundle*": "deny",
      "*brew link --overwrite*": "deny",
      "*brew unlink*": "deny",
      "*brew install*": "deny",
      "*brew uninstall*": "deny",
      "*nix profile install*": "deny",
      "*nix profile upgrade*": "deny",
      "*nix profile remove*": "deny",
      "*nix-env -i*": "deny",
      "*nix-env --install*": "deny",
      "*npm install -g*": "deny",
      "*npm i -g*": "deny",
      "*pnpm add -g*": "deny",
      "*yarn global add*": "deny",
      "*pip install*": "deny",
      "*pipx install*": "deny",
      "*cargo install*": "deny",
      "*nix flake update skills-catalog*": "allow",
      "*nix flake lock --update-input skills-catalog*": "deny",
      "acpx claude*": "allow",
      "*&& acpx claude*": "allow",
      "hey re*": "allow",
      "*&& hey re*": "allow",
      "hey rebuild*": "allow",
      "*&& hey rebuild*": "allow",
      "hey nuc": "allow",
      "hey deploy *": "allow",
      "hey deploy-dry *": "allow",
      "hey skills-update*": "allow",
      "hey skills-sync*": "allow",
      "hey gc*": "allow",
      "bd": "deny",
      "bd *": "deny",
      "*&& bd *": "deny",
      "br close": "deny",
      "br close *": "deny",
      "*&& br close *": "deny",
      "br close * --reason *": "allow",
      "br close * --reason=*": "allow",
      "*&& br close * --reason *": "allow",
      "*&& br close * --reason=*": "allow",
      "br *": "allow",
      "*&& br *": "allow",
      "pi update*": "deny",
      "*&& pi update*": "deny",
      "pi update --extensions*": "allow",
      "*&& pi update --extensions*": "allow"
    }
  }
}
