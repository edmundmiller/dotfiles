{
  "$schema": "https://opencode.ai/config.json",
  "theme": "catppuccin",
  "tui": {
    "scroll_acceleration": {
      "enabled": true
    }
  },
  "model": "anthropic/claude-sonnet-4-6",
  "small_model": "anthropic/claude-haiku-4-5",
  "autoupdate": false,
  "instructions": ["~/.config/opencode/rules/[0-9]*.md"]
}
