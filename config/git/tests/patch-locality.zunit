#!/usr/bin/env zunit

@setup {
  export SCRIPT="$PWD/bin/check-patch-locality"
}

@test 'allows package-local patches' {
  run bash "$SCRIPT" packages/stack/patches/fix.patch

  assert $state equals 0
}

@test 'allows overlay-local patches' {
  run bash "$SCRIPT" overlays/hunk/patches/fix.patch

  assert $state equals 0
}

@test 'rejects root patch directory' {
  run bash "$SCRIPT" patches/fix.patch

  assert $state equals 1
  assert "$output" contains "Patch must live at packages/<name>/patches/*.patch or overlays/<name>/patches/*.patch: patches/fix.patch"
}

@test 'rejects arbitrary patch locations' {
  run bash "$SCRIPT" misc/fix.patch

  assert $state equals 1
}

@test 'rejects nested package names' {
  run bash "$SCRIPT" packages/group/tool/patches/fix.patch

  assert $state equals 1
}

@test 'rejects a mixed batch when any patch is misplaced' {
  run bash "$SCRIPT" packages/stack/patches/fix.patch misc/fix.patch overlays/hunk/patches/fix.patch

  assert $state equals 1
  assert "$output" contains "misc/fix.patch"
}
