#!/usr/bin/env zunit

# Tests for sesh session picker integration
# Covers: binary existence, zoxide list quality, tmux popup interaction
#
# NOTE: Tests requiring live services (tmux server, sesh sessions, zoxide db)
# are skipped when those services are unavailable (e.g. Nix sandbox / CI).

@setup {
  export ORIG_PWD=$PWD
  export BASH_PATH=$(command -v bash)
  export TEST_DIR=$(mktemp -d /tmp/sesh.zunit.XXXXXX)
  export SESH_SCRIPT="$ORIG_PWD/config/tmux/sesh-picker.sh"
  export SESH_ALL_SCRIPT="$ORIG_PWD/config/tmux/sesh-all.sh"
  export ZOXIDE_SCRIPT="$ORIG_PWD/config/tmux/zoxide-list.sh"
}

@teardown {
  rm -rf "$TEST_DIR"
}

# ── Binary checks ──────────────────────────────────────────────────────────────

@test 'sesh binary is available' {
  command -v sesh > /dev/null 2>&1 || skip "sesh not in PATH"
  run sesh --version
  assert $state equals 0
}

@test 'fzf binary is available' {
  command -v fzf > /dev/null 2>&1 || skip "fzf not in PATH"
  run fzf --version
  assert $state equals 0
}

@test 'zoxide binary is available' {
  command -v zoxide > /dev/null 2>&1 || skip "zoxide not in PATH"
  run zoxide --version
  assert $state equals 0
}

# ── Script checks ──────────────────────────────────────────────────────────────

@test 'sesh-picker.sh is executable' {
  [[ -x "$SESH_SCRIPT" ]]
  assert $state equals 0
}

@test 'zoxide-list.sh is executable' {
  [[ -x "$ZOXIDE_SCRIPT" ]]
  assert $state equals 0
}

# ── sesh list output ───────────────────────────────────────────────────────────

@test 'sesh list returns output' {
  # Requires a running tmux server (doesn't need to be inside one)
  command -v tmux > /dev/null 2>&1 || skip "tmux not in PATH"
  tmux list-sessions > /dev/null 2>&1 || skip "no tmux server running"
  command -v sesh > /dev/null 2>&1 || skip "sesh not in PATH"
  run sesh list
  assert $state equals 0
  assert "$output" is_not_empty
}

@test 'sesh list -t returns only tmux sessions' {
  # Requires a running tmux server (doesn't need to be inside one)
  command -v tmux > /dev/null 2>&1 || skip "tmux not in PATH"
  tmux list-sessions > /dev/null 2>&1 || skip "no tmux server running"
  command -v sesh > /dev/null 2>&1 || skip "sesh not in PATH"
  run sesh list -t
  assert $state equals 0
}

# ── zoxide-list.sh quality ─────────────────────────────────────────────────────

@test 'zoxide-list.sh runs successfully' {
  # Requires a populated zoxide database
  command -v zoxide > /dev/null 2>&1 || skip "zoxide not in PATH"
  local count
  count=$(zoxide query --list 2>/dev/null | wc -l | tr -d ' ')
  [[ "$count" -gt 0 ]] || skip "zoxide database is empty"
  run bash "$ZOXIDE_SCRIPT"
  assert $state equals 0
  # Note: output may be empty in sandbox when all seeded dirs are under filtered paths
}

@test 'zoxide-list.sh returns at most 30 lines' {
  command -v zoxide > /dev/null 2>&1 || skip "zoxide not in PATH"
  local db_count
  db_count=$(zoxide query --list 2>/dev/null | wc -l | tr -d ' ')
  [[ "$db_count" -gt 0 ]] || skip "zoxide database is empty"
  local count=$(bash "$ZOXIDE_SCRIPT" | wc -l | tr -d ' ')
  [[ "$count" -le 30 ]]
  assert $state equals 0
}

@test 'zoxide-list.sh excludes temp and noise dirs' {
  command -v zoxide > /dev/null 2>&1 || skip "zoxide not in PATH"
  local db_count
  db_count=$(zoxide query --list 2>/dev/null | wc -l | tr -d ' ')
  [[ "$db_count" -gt 0 ]] || skip "zoxide database is empty"
  local result=$(bash "$ZOXIDE_SCRIPT")
  # Empty output is fine (all dirs may have been filtered — correct behaviour)
  [[ -z "$result" ]] && return 0
  # Should not include common noise entries when output is non-empty
  local noise=$(echo "$result" | grep -E '^(/tmp|/private/tmp|/private/var/folders|.*\.Trash|.*\.sdkman/tmp)' || true)
  assert "$noise" is_empty
}

@test 'zoxide-list.sh entries are real directories' {
  command -v zoxide > /dev/null 2>&1 || skip "zoxide not in PATH"
  local db_count
  db_count=$(zoxide query --list 2>/dev/null | wc -l | tr -d ' ')
  [[ "$db_count" -gt 0 ]] || skip "zoxide database is empty"
  local output=$(bash "$ZOXIDE_SCRIPT")
  # Empty output is fine (all dirs may have been filtered — correct behaviour)
  [[ -z "$output" ]] && return 0
  while IFS= read -r dir; do
    # Expand ~ to $HOME (zoxide-list.sh substitutes home with ~)
    local expanded="${dir/#\~/$HOME}"
    [[ -d "$expanded" ]] || { echo "Not a directory: $dir (expanded: $expanded)"; return 1; }
  done <<< "$output"
  assert $state equals 0
}

@test 'zoxide-list.sh resolves bare hubs to real worktrees' {
  cd "$TEST_DIR"
  local mock_bin="$TEST_DIR/mock-bin"
  local mock_dotfiles_bin="$TEST_DIR/mock-dotfiles-bin"
  local fixture_root="sesh-zunit-$RANDOM"
  local bare_hub="$fixture_root/hub"
  local main_wt="resolved-sesh-zunit-$RANDOM/hub/main"
  local normal_dir="$fixture_root/normal"
  local bare_hub_out="${bare_hub/#$HOME/~}"
  local main_wt_out="${main_wt/#$HOME/~}"
  mkdir -p "$mock_bin" "$mock_dotfiles_bin" "$bare_hub" "$normal_dir"
  touch "$bare_hub/HEAD"

  {
    printf '#!%s\n' "$BASH_PATH"
    cat <<'EOF'
echo "$BARE_HUB"
echo "$NORMAL_DIR"
EOF
  } > "$mock_bin/zoxide"
  chmod +x "$mock_bin/zoxide"

  {
    printf '#!%s\n' "$BASH_PATH"
    cat <<'EOF'
if [[ "$1" == "$BARE_HUB" ]]; then
  echo "$MAIN_WT"
else
  echo "$1"
fi
EOF
  } > "$mock_dotfiles_bin/git-worktree-cwd"
  chmod +x "$mock_dotfiles_bin/git-worktree-cwd"

  output=$(env BARE_HUB="$bare_hub" NORMAL_DIR="$normal_dir" MAIN_WT="$main_wt" DOTFILES_BIN="$mock_dotfiles_bin" PATH="$mock_bin:$PATH" bash "$ZOXIDE_SCRIPT")
  state=$?

  rm -rf "$fixture_root"

  assert $state equals 0
  if printf "%s\n" "$output" | grep -Fxq "$bare_hub_out"; then
    echo "unexpected bare hub in output: $output"
    return 1
  fi
  assert "$output" contains "$main_wt_out"
}

# ── Regression: fzf reload pipe parsing ───────────────────────────────────────

@test 'zoxide-list.sh uses a script not inline pipe (avoids fzf reload bug)' {
  # Regression: pipe in reload() was parsed as fzf action separator, showing "/"
  # Fix: extract to standalone script, reference by path in reload()
  local result=$(grep 'reload.*|.*head' "$SESH_SCRIPT" || true)
  assert "$result" is_empty
}

@test 'zoxide-list.sh excludes accidental /.git entries' {
  local mock_bin="$TEST_DIR/mock-zoxide-dotgit"
  local fixture_root="$HOME/.cache/sesh-zunit-dotgit-$RANDOM"
  local normal_dir="$fixture_root/normal"
  mkdir -p "$mock_bin" "$fixture_root/repo/.git" "$normal_dir"

  {
    printf '#!%s\n' "$BASH_PATH"
    cat <<'EOF'
echo "$DOTGIT_PATH"
echo "$NORMAL_DIR"
EOF
  } > "$mock_bin/zoxide"
  chmod +x "$mock_bin/zoxide"

  run env DOTGIT_PATH="$fixture_root/repo/.git" NORMAL_DIR="$normal_dir" PATH="$mock_bin:$PATH" bash "$ZOXIDE_SCRIPT"

  rm -rf "$fixture_root"

  assert $state equals 0
  echo "$output" | grep -qE '/\.git$' && return 1 || true
}

# ── Regression: minimal PATH in fzf popup ─────────────────────────────────────

@test 'sesh is NOT in minimal display-popup PATH' {
  local minimal_path="/usr/bin:/bin:/usr/sbin:/sbin"
  local result=$(PATH="$minimal_path" command -v sesh 2>/dev/null || true)
  assert "$result" is_empty
}

@test 'fzf is NOT in minimal display-popup PATH' {
  local minimal_path="/usr/bin:/bin:/usr/sbin:/sbin"
  local result=$(PATH="$minimal_path" command -v fzf 2>/dev/null || true)
  assert "$result" is_empty
}

@test 'sesh-all.sh honors SESH_BIN override (no hardcoded brew path)' {
  local mock_bin="$TEST_DIR/mock-sesh-all"
  local token="__zunit_mock_session__"
  mkdir -p "$mock_bin"

  {
    printf '#!%s\n' "$BASH_PATH"
    cat <<'EOF'
if [[ "$1" == "list" ]]; then
  echo "__zunit_mock_session__"
fi
EOF
  } > "$mock_bin/sesh"
  chmod +x "$mock_bin/sesh"

  run env PATH="/usr/bin:/bin:/usr/sbin:/sbin" BASH_BIN="$BASH_PATH" SESH_BIN="$mock_bin/sesh" TMUX_HOME="$ORIG_PWD/config/tmux" "$BASH_PATH" "$SESH_ALL_SCRIPT"

  assert $state equals 0
  assert "$output" contains "$token"
}

@test 'sesh-picker uses FZF_TMUX_BIN override in minimal PATH' {
  local mock_bin="$TEST_DIR/mock-fzf"
  mkdir -p "$mock_bin"

  {
    printf '#!%s\n' "$BASH_PATH"
    cat <<'EOF'
if [[ "$1" == "list" ]]; then
  exit 0
fi
if [[ "$1" == "connect" ]]; then
  exit 0
fi
EOF
  } > "$mock_bin/sesh"
  chmod +x "$mock_bin/sesh"

  {
    printf '#!%s\n' "$BASH_PATH"
    cat <<'EOF'
# Simulate escape/no selection
exit 0
EOF
  } > "$mock_bin/fzf-tmux"
  chmod +x "$mock_bin/fzf-tmux"

  run env PATH="/usr/bin:/bin:/usr/sbin:/sbin" BASH_BIN="$BASH_PATH" TMUX_HOME="$ORIG_PWD/config/tmux" SESH_BIN="$mock_bin/sesh" FZF_TMUX_BIN="$mock_bin/fzf-tmux" "$BASH_PATH" "$SESH_SCRIPT"

  assert $state equals 0
  echo "$output" | grep -q 'command not found' && return 1 || true
}

# ── tmux popup interaction ─────────────────────────────────────────────────────

@test 'sesh picker popup appears and closes cleanly on escape' {
  # Skip if not inside tmux
  [[ -n "$TMUX" ]] || skip "not inside tmux"

  local test_window
  test_window=$(tmux new-window -d -P -F '#{window_id}')

  # Run the picker in the test window (it will show the fzf-tmux popup)
  tmux send-keys -t "$test_window" "$SESH_SCRIPT" Enter
  sleep 1

  # Capture popup content — should show the sesh border label
  local pane_output
  pane_output=$(tmux capture-pane -t "$test_window" -p 2>/dev/null || true)

  # Send escape to dismiss
  tmux send-keys -t "$test_window" Escape ''
  sleep 0.3
  tmux kill-window -t "$test_window" 2>/dev/null || true

  # Popup should have shown the sesh border or fzf prompt
  echo "$pane_output" | grep -qE 'sesh|> $'
  assert $state equals 0
}

@test 'sesh picker exits 0 when no session selected (escape logic)' {
  # Regression: empty sesh connect returned 127; [ -n ] + exit 0 guards against it
  # Test the guard logic directly without needing a live fzf popup
  run bash -c 'SESSION=""; [ -n "$SESSION" ] && sesh connect "$SESSION"; exit 0'
  assert $state equals 0
}
