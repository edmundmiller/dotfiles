// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run `zed: open default settings` from the
// command palette (cmd-shift-p / ctrl-shift-p)
{
  "git_panel": {
    "tree_view": true
  },
  "agent_servers": {
    "codex-acp": {
      "type": "registry"
    },
    "pi-acp": {
      "type": "registry"
    },
    "hermes-agent": {
      "type": "custom",
      "command": "hermes",
      "args": ["acp"]
    }
  },
  "terminal": {
    "toolbar": {
      "breadcrumbs": true
    }
  },
  "preview_tabs": {
    "enable_preview_from_file_finder": true,
    "enable_keep_preview_on_code_navigation": true
  },
  "prettier": {
    "allowed": true
  },
  "soft_wrap": "none",
  "minimap": {
    "show": "auto"
  },
  "relative_line_numbers": "enabled",
  "autosave": "on_focus_change",
  "helix_mode": false,
  "base_keymap": "Emacs",
  "icon_theme": {
    "mode": "system",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "redact_private_values": true,
  "edit_predictions": {
    "provider": "zed",
    "mode": "subtle"
  },
  "context_servers": {
    "mcp-server-context7": {
      "enabled": false,
      "remote": false,
      "settings": {}
    }
  },
  "agent": {
    "tool_permissions": {
      "default": "allow"
    },
    "play_sound_when_agent_done": "when_hidden",
    "default_model": {
      "provider": "anthropic",
      "model": "claude-sonnet-4-latest"
    }
  },
  "telemetry": {
    "diagnostics": true,
    "metrics": false
  },
  "vim_mode": true,
  "ui_font_size": 16,
  "buffer_font_size": 16,
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "macOS Classic Dark"
  }
}
