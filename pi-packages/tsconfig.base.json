{
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@mariozechner/pi-coding-agent": [
        "./pi-bash-live-view/node_modules/@mariozechner/pi-coding-agent/dist/index.d.ts"
      ],
      "@mariozechner/pi-tui": [
        "./pi-bash-live-view/node_modules/@mariozechner/pi-tui/dist/index.d.ts"
      ]
    },
    "lib": ["ESNext"],
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "noImplicitAny": true,
    "allowImportingTsExtensions": true,
    "esModuleInterop": true,
    "types": ["bun", "node"]
  }
}
