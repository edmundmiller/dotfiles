index 0000000..7cbc3b3
--- /dev/null
+++ w/src/core/resumableReview.test.ts
@@ -0,0 +1,106 @@
+import { existsSync, mkdtempSync, mkdirSync, readFileSync, rmSync, writeFileSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { dirname, join } from "node:path";
+import { afterEach, describe, expect, test } from "bun:test";
+import type { CliInput } from "./types";
+import { loadResumableReview, persistResumableReview } from "./resumableReview";
+
+const tempDirs: string[] = [];
+
+function tempDir(name: string) {
+  const dir = mkdtempSync(join(tmpdir(), name));
+  tempDirs.push(dir);
+  return dir;
+}
+
+function git(cwd: string, ...args: string[]) {
+  const result = Bun.spawnSync(["git", ...args], { cwd, stderr: "pipe", stdout: "pipe" });
+  if (result.exitCode !== 0) throw new Error(result.stderr.toString());
+  return result.stdout.toString().trim();
+}
+
+function createRepo() {
+  const repo = tempDir("hunk-resume-");
+  git(repo, "init");
+  git(repo, "config", "user.email", "test@example.com");
+  git(repo, "config", "user.name", "Test");
+  writeFileSync(join(repo, "tracked.txt"), "base\n");
+  git(repo, "add", "tracked.txt");
+  git(repo, "commit", "-m", "base");
+  return repo;
+}
+
+function markerPath(repo: string) {
+  return join(git(repo, "rev-parse", "--absolute-git-dir"), "hunk", "resume.json");
+}
+
+afterEach(() => {
+  for (const dir of tempDirs.splice(0)) rmSync(dir, { force: true, recursive: true });
+});
+
+describe("resumable review markers", () => {
+  test("persists and reloads every reopenable input shape without dropping source options", () => {
+    const repo = createRepo();
+    const inputs: CliInput[] = [
+      { kind: "vcs", range: "HEAD~1..HEAD", staged: true, pathspecs: ["src"], options: { menuBar: false, mode: "split", watch: true } },
+      { kind: "show", ref: "HEAD", pathspecs: ["tracked.txt"], options: { theme: "dark" } },
+      { kind: "stash-show", ref: "stash@{1}", options: { lineNumbers: false } },
+      { kind: "diff", left: "before", right: "after", options: { wrapLines: true } },
+      { kind: "patch", file: "changes.patch", options: { pager: true } },
+      { kind: "difftool", left: "old", right: "new", path: "tracked.txt", options: { colorMoved: false } },
+    ];
+
+    for (const input of inputs) {
+      persistResumableReview(input, repo);
+      expect(loadResumableReview(repo)).toEqual(input);
+      const marker = JSON.parse(readFileSync(markerPath(repo), "utf8"));
+      expect(marker).toMatchObject({ version: 1, input });
+      expect(new Date(marker.updatedAt).toISOString()).toBe(marker.updatedAt);
+    }
+  });
+
+  test("stores distinct markers for linked worktrees", () => {
+    const repo = createRepo();
+    const linked = tempDir("hunk-resume-linked-");
+    rmSync(linked, { recursive: true });
+    git(repo, "worktree", "add", "-b", "linked", linked);
+
+    persistResumableReview({ kind: "vcs", staged: false, options: {} }, repo);
+    persistResumableReview({ kind: "show", ref: "HEAD", options: {} }, linked);
+
+    expect(markerPath(linked)).not.toBe(markerPath(repo));
+    expect(loadResumableReview(repo)?.kind).toBe("vcs");
+    expect(loadResumableReview(linked)?.kind).toBe("show");
+  });
+
+  test("returns null for missing, malformed, unsupported, or invalid markers", () => {
+    const repo = createRepo();
+    expect(loadResumableReview(repo)).toBeNull();
+
+    const marker = markerPath(repo);
+    mkdirSync(dirname(marker), { recursive: true });
+    for (const contents of [
+      "not json",
+      JSON.stringify({ version: 2, updatedAt: new Date().toISOString(), input: { kind: "vcs", staged: false, options: {} } }),
+      JSON.stringify({ version: 1, updatedAt: "invalid", input: { kind: "vcs", staged: "no", options: {} } }),
+      JSON.stringify({ version: 1, updatedAt: new Date().toISOString(), input: { kind: "patch", text: "diff", options: {} } }),
+    ]) {
+      writeFileSync(marker, contents);
+      expect(loadResumableReview(repo)).toBeNull();
+    }
+  });
+
+  test("stdin-backed inputs remove an existing marker", () => {
+    const repo = createRepo();
+    for (const input of [
+      { kind: "patch", text: "diff --git a/a b/a\n", options: {} },
+      { kind: "vcs", staged: false, options: { agentContext: "-" } },
+    ] satisfies CliInput[]) {
+      persistResumableReview({ kind: "vcs", staged: true, options: {} }, repo);
+      expect(existsSync(markerPath(repo))).toBe(true);
+      persistResumableReview(input, repo);
+      expect(existsSync(markerPath(repo))).toBe(false);
+      expect(loadResumableReview(repo)).toBeNull();
+    }
+  });
+});
diff --git i/src/core/resumableReview.ts w/src/core/resumableReview.ts
new file mode 100644
index 0000000..e61a1ed
--- /dev/null
+++ w/src/core/resumableReview.ts
@@ -0,0 +1,176 @@
+import { mkdirSync, readFileSync, renameSync, rmSync, writeFileSync } from "node:fs";
+import { dirname, join } from "node:path";
+import type { CliInput, CommonOptions } from "./types";
+import { canReloadInput } from "./watch";
+
+const MARKER_VERSION = 1;
+
+function isRecord(value: unknown): value is Record<string, unknown> {
+  return typeof value === "object" && value !== null && !Array.isArray(value);
+}
+
+function readCommonOptions(value: unknown): CommonOptions | null {
+  if (!isRecord(value)) return null;
+
+  const options: CommonOptions = {};
+  if (value.mode !== undefined) {
+    if (value.mode !== "auto" && value.mode !== "split" && value.mode !== "stack") return null;
+    options.mode = value.mode;
+  }
+  for (const key of ["vcs", "theme", "agentContext"] as const) {
+    const option = value[key];
+    if (option !== undefined) {
+      if (typeof option !== "string") return null;
+      options[key] = option;
+    }
+  }
+  for (const key of [
+    "pager",
+    "menuBar",
+    "watch",
+    "excludeUntracked",
+    "lineNumbers",
+    "wrapLines",
+    "hunkHeaders",
+    "agentNotes",
+    "copyDecorations",
+    "transparentBackground",
+    "colorMoved",
+  ] as const) {
+    const option = value[key];
+    if (option !== undefined) {
+      if (typeof option !== "boolean") return null;
+      options[key] = option;
+    }
+  }
+  return options;
+}
+
+function readOptionalString(value: unknown) {
+  return value === undefined || typeof value === "string" ? value : null;
+}
+
+function readOptionalStrings(value: unknown) {
+  if (value === undefined) return undefined;
+  return Array.isArray(value) && value.every((item) => typeof item === "string")
+    ? value
+    : null;
+}
+
+function readCliInput(value: unknown): CliInput | null {
+  if (!isRecord(value) || typeof value.kind !== "string") return null;
+  const options = readCommonOptions(value.options);
+  if (!options) return null;
+
+  switch (value.kind) {
+    case "vcs": {
+      const range = readOptionalString(value.range);
+      const pathspecs = readOptionalStrings(value.pathspecs);
+      if (typeof value.staged !== "boolean" || range === null || pathspecs === null) return null;
+      return {
+        kind: "vcs",
+        ...(range === undefined ? {} : { range }),
+        staged: value.staged,
+        ...(pathspecs === undefined ? {} : { pathspecs }),
+        options,
+      };
+    }
+    case "show": {
+      const ref = readOptionalString(value.ref);
+      const pathspecs = readOptionalStrings(value.pathspecs);
+      if (ref === null || pathspecs === null) return null;
+      return {
+        kind: "show",
+        ...(ref === undefined ? {} : { ref }),
+        ...(pathspecs === undefined ? {} : { pathspecs }),
+        options,
+      };
+    }
+    case "stash-show": {
+      const ref = readOptionalString(value.ref);
+      if (ref === null) return null;
+      return { kind: "stash-show", ...(ref === undefined ? {} : { ref }), options };
+    }
+    case "diff":
+      return typeof value.left === "string" && typeof value.right === "string"
+        ? { kind: "diff", left: value.left, right: value.right, options }
+        : null;
+    case "patch":
+      return typeof value.file === "string" && value.text === undefined
+        ? { kind: "patch", file: value.file, options }
+        : null;
+    case "difftool": {
+      const path = readOptionalString(value.path);
+      if (typeof value.left !== "string" || typeof value.right !== "string" || path === null) {
+        return null;
+      }
+      return {
+        kind: "difftool",
+        left: value.left,
+        right: value.right,
+        ...(path === undefined ? {} : { path }),
+        options,
+      };
+    }
+    default:
+      return null;
+  }
+}
+
+function markerPath(cwd: string) {
+  const result = Bun.spawnSync(["git", "rev-parse", "--absolute-git-dir"], {
+    cwd,
+    stdin: "ignore",
+    stdout: "pipe",
+    stderr: "pipe",
+  });
+  if (result.exitCode !== 0) throw new Error(result.stderr.toString().trim() || "not a Git worktree");
+  return join(result.stdout.toString().trim(), "hunk", "resume.json");
+}
+
+function warn(message: string) {
+  process.stderr.write(`Warning: ${message}\n`);
+}
+
+/** Persist the latest reloadable review source for one Git worktree. */
+export function persistResumableReview(input: CliInput, cwd = process.cwd()): void {
+  let path: string;
+  try {
+    path = markerPath(cwd);
+    const normalized = canReloadInput(input) ? readCliInput(input) : null;
+    if (!normalized) {
+      rmSync(path, { force: true });
+      return;
+    }
+
+    mkdirSync(dirname(path), { recursive: true });
+    const temporaryPath = `${path}.${process.pid}.${crypto.randomUUID()}.tmp`;
+    try {
+      writeFileSync(
+        temporaryPath,
+        `${JSON.stringify({ version: MARKER_VERSION, updatedAt: new Date().toISOString(), input: normalized }, null, 2)}\n`,
+        { flag: "wx" },
+      );
+      renameSync(temporaryPath, path);
+    } finally {
+      rmSync(temporaryPath, { force: true });
+    }
+  } catch (error) {
+    warn(`could not persist resumable review: ${error instanceof Error ? error.message : String(error)}`);
+  }
+}
+
+/** Load the latest validated reloadable review source for one Git worktree. */
+export function loadResumableReview(cwd = process.cwd()): CliInput | null {
+  try {
+    const marker: unknown = JSON.parse(readFileSync(markerPath(cwd), "utf8"));
+    if (!isRecord(marker) || marker.version !== MARKER_VERSION) return null;
+    if (typeof marker.updatedAt !== "string" || new Date(marker.updatedAt).toISOString() !== marker.updatedAt) {
+      return null;
+    }
+    const input = readCliInput(marker.input);
+    return input && canReloadInput(input) ? input : null;
+  } catch {
+    return null;
+  }
+}
