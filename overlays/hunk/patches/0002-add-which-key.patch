diff --git i/src/ui/components/chrome/WhichKeyDock.tsx w/src/ui/components/chrome/WhichKeyDock.tsx
new file mode 100644
index 0000000..42f6e48
--- /dev/null
+++ w/src/ui/components/chrome/WhichKeyDock.tsx
@@ -0,0 +1,95 @@
+import type { AppTheme } from "../../themes";
+import { fitText, padText } from "../../lib/text";
+
+export interface WhichKeyEntry {
+  key: string;
+  label: string;
+  group: string;
+  prefix?: boolean;
+}
+
+export interface WhichKeyViewState {
+  entries: WhichKeyEntry[];
+  pinned: boolean;
+  sequence: string[];
+  title: string;
+  visible: boolean;
+}
+
+function groupedEntries(entries: WhichKeyEntry[]) {
+  const groups: Array<{ group: string; entries: WhichKeyEntry[] }> = [];
+  for (const entry of entries) {
+    const existing = groups.find((item) => item.group === entry.group);
+    if (existing) {
+      existing.entries.push(entry);
+    } else {
+      groups.push({ group: entry.group, entries: [entry] });
+    }
+  }
+  return groups;
+}
+
+/** Render the active leader/keybinding choices as a bottom dock. */
+export function WhichKeyDock({
+  state,
+  terminalWidth,
+  theme,
+}: {
+  state: WhichKeyViewState;
+  terminalWidth: number;
+  theme: AppTheme;
+}) {
+  if (!state.visible || state.entries.length === 0) {
+    return null;
+  }
+
+  const contentWidth = Math.max(20, terminalWidth - 4);
+  const groups = groupedEntries(state.entries);
+  const columnWidth = Math.max(24, Math.min(36, Math.floor(contentWidth / 3)));
+  const title =
+    state.sequence.length > 0 ? `${state.title}: ${state.sequence.join(" ")}` : state.title;
+
+  return (
+    <box
+      style={{
+        width: "100%",
+        border: true,
+        borderColor: theme.border,
+        backgroundColor: theme.panel,
+        flexDirection: "column",
+        paddingLeft: 1,
+        paddingRight: 1,
+        zIndex: 35,
+      }}
+    >
+      <box style={{ width: "100%", height: 1, flexDirection: "row" }}>
+        <text fg={theme.badgeNeutral}>{fitText(title, Math.max(1, terminalWidth - 20))}</text>
+        {state.pinned ? <text fg={theme.muted}> pinned</text> : null}
+      </box>
+      <box style={{ width: "100%", flexDirection: "row", flexWrap: "wrap" }}>
+        {groups.map((group) => (
+          <box
+            key={group.group}
+            style={{ width: columnWidth, flexDirection: "column", paddingRight: 2 }}
+          >
+            <text fg={theme.accent}>{fitText(group.group, columnWidth)}</text>
+            {group.entries.map((entry) => {
+              const key = entry.prefix ? `${entry.key} +` : entry.key;
+              const left = padText(fitText(key, 8), 8);
+              const label = fitText(entry.label, Math.max(1, columnWidth - 8));
+              return (
+                <box
+                  key={`${group.group}:${entry.key}:${entry.label}`}
+                  style={{ width: "100%", height: 1, flexDirection: "row" }}
+                >
+                  <text fg={theme.badgeNeutral}>{left}</text>
+                  <text fg={theme.text}>{label}</text>
+                </box>
+              );
+            })}
+          </box>
+        ))}
+      </box>
+    </box>
+  );
+}
