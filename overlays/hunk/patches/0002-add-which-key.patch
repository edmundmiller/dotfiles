diff --git i/src/ui/lib/keybindingRegistry.ts w/src/ui/lib/keybindingRegistry.ts
new file mode 100644
index 0000000..74907f4
--- /dev/null
+++ w/src/ui/lib/keybindingRegistry.ts
@@ -0,0 +1,98 @@
+import type { KeyEvent } from "@opentui/core";
+import type { WhichKeyEntry } from "../components/chrome/WhichKeyDock";
+
+export interface KeyBindingSpec {
+  keys: string[];
+}
+
+export interface KeybindingRegistryAction {
+  id: string;
+  label: string;
+  group: string;
+  bindings: KeyBindingSpec[];
+  enabled: boolean;
+  run: (key?: KeyEvent) => void;
+}
+
+const LEADER_PREFIX_LABELS: Record<string, string> = {
+  a: "agent",
+  f: "file",
+  h: "help",
+  n: "navigate",
+  s: "source",
+  v: "view",
+};
+
+function sequenceStartsWith(sequence: string[], prefix: string[]) {
+  return prefix.every((key, index) => sequence[index] === key);
+}
+
+function addEntry(entries: WhichKeyEntry[], entry: WhichKeyEntry) {
+  if (
+    entries.some(
+      (existing) =>
+        existing.group === entry.group &&
+        existing.key === entry.key &&
+        existing.label === entry.label &&
+        existing.prefix === entry.prefix,
+    )
+  ) {
+    return;
+  }
+  entries.push(entry);
+}
+
+export function findActionForSequence(actions: KeybindingRegistryAction[], sequence: string[]) {
+  return actions.find(
+    (action) =>
+      action.enabled &&
+      action.bindings.some(
+        (binding) =>
+          binding.keys.length === sequence.length && sequenceStartsWith(binding.keys, sequence),
+      ),
+  );
+}
+
+export function directWhichKeyEntries(actions: KeybindingRegistryAction[]) {
+  const entries: WhichKeyEntry[] = [];
+  for (const action of actions) {
+    if (!action.enabled) continue;
+    for (const binding of action.bindings) {
+      const key = binding.keys[0];
+      if (binding.keys.length !== 1 || !key || key === "SPC") continue;
+      addEntry(entries, {
+        group: action.group,
+        key,
+        label: action.label,
+      });
+    }
+  }
+  return entries;
+}
+
+export function whichKeyEntriesForSequence(
+  actions: KeybindingRegistryAction[],
+  sequence: string[],
+) {
+  const entries: WhichKeyEntry[] = [];
+  for (const action of actions) {
+    if (!action.enabled) continue;
+    for (const binding of action.bindings) {
+      if (binding.keys.length <= sequence.length || !sequenceStartsWith(binding.keys, sequence)) {
+        continue;
+      }
+      const nextKey = binding.keys[sequence.length];
+      if (!nextKey) continue;
+      const prefix = binding.keys.length > sequence.length + 1;
+      addEntry(entries, {
+        group: prefix ? "Leader" : action.group,
+        key: nextKey,
+        label: prefix
+          ? (LEADER_PREFIX_LABELS[nextKey] ?? action.group.toLowerCase())
+          : action.label,
+        prefix,
+      });
+    }
+  }
+  return entries;
+}
