+      await session.waitForText(/unstagedOnly/, { timeout: 15_000 });
+
+      await session.press("space");
+      await session.waitForText(/Leader: SPC/, { timeout: 5_000 });
+      await session.press("s");
+      await session.waitForText(/Source: SPC s/, { timeout: 5_000 });
+      await session.press("s");
+      const staged = await harness.waitForSnapshot(
+        session,
