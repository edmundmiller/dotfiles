@@ -0,0 +1,168 @@
+import { describe, expect, it } from "bun:test";
+import * as os from "node:os";
+import * as path from "node:path";
+import { HerdrProtocolHandler, HunkProtocolHandler, type LocalCommandRunner } from "../herdr-hunk-protocol";
+import { parseInternalUrl } from "../parse";
+
+type CommandCall = {
+	command: string;
+	args: string[];
+	options?: Parameters<LocalCommandRunner>[2];
+};
+
+type CommandOutput =
+	| Record<string, string>
+	| ((command: string, args: readonly string[], options?: Parameters<LocalCommandRunner>[2]) => string | undefined);
+
+function commandKey(command: string, args: readonly string[]): string {
+	return [command, ...args].join("\0");
+}
+
+function mockRunCommand(outputs: CommandOutput): { runner: LocalCommandRunner; calls: CommandCall[] } {
+	const calls: CommandCall[] = [];
+	const runner: LocalCommandRunner = async (command, args, options) => {
+		calls.push({ command, args: [...args], options });
+		const stdout =
+			typeof outputs === "function" ? outputs(command, args, options) : outputs[commandKey(command, args)];
+		if (stdout === undefined) throw new Error(`Unexpected command: ${command} ${args.join(" ")}`);
+		return { stdout, stderr: "", exitCode: 0 };
+	};
+	return { runner, calls };
+}
+
+describe("Herdr and Hunk internal URL schemes", () => {
+	it("resolves herdr://snapshot through `herdr api snapshot`", async () => {
+		const { runner, calls } = mockRunCommand({ [commandKey("herdr", ["api", "snapshot"])]: '{"workspaces":[]}\n' });
+		const handler = new HerdrProtocolHandler(runner);
+
+		const resource = await handler.resolve(parseInternalUrl("herdr://snapshot"));
+
+		expect(resource.content).toBe('{"workspaces":[]}\n');
+		expect(resource.contentType).toBe("application/json");
+		expect(handler.immutable).toBe(true);
+		expect(calls[0]?.command).toBe("herdr");
+		expect(calls[0]?.args).toEqual(["api", "snapshot"]);
+	});
+
+	for (const [url, prefix, workspace] of [
+		["herdr://workspaces", ["workspace", "list"], undefined],
+		["herdr://tabs?workspace=ws-1", ["tab", "list"], "ws-1"],
+		["herdr://panes?workspace=ws-1", ["pane", "list"], "ws-1"],
+	] as const) {
+		it(`resolves ${url} through the matching herdr list command`, async () => {
+			const { runner, calls } = mockRunCommand((command, args) =>
+				command === "herdr" && prefix.every((arg, index) => args[index] === arg) ? "[]\n" : undefined,
+			);
+			const handler = new HerdrProtocolHandler(runner);
+
+			const resource = await handler.resolve(parseInternalUrl(url));
+
+			expect(resource.content).toBe("[]\n");
+			expect(handler.immutable).toBe(true);
+			expect(calls[0]?.args).toEqual(expect.arrayContaining(prefix));
+			if (workspace) expect(calls[0]?.args).toEqual(expect.arrayContaining([workspace]));
+		});
+	}
+
+	it("resolves herdr://pane/<id> through `herdr pane read` with source and line options", async () => {
+		const args = ["pane", "read", "pane-1", "--source", "recent-unwrapped", "--lines", "25"];
+		const { runner, calls } = mockRunCommand({ [commandKey("herdr", args)]: "pane text\n" });
+		const handler = new HerdrProtocolHandler(runner);
+
+		const resource = await handler.resolve(parseInternalUrl("herdr://pane/pane-1?source=recent-unwrapped&lines=25"));
+
+		expect(resource.content).toBe("pane text\n");
+		expect(resource.contentType).toBe("text/plain");
+		expect(handler.immutable).toBe(true);
+		expect(calls[0]?.args).toEqual(args);
+	});
+
+	it("rejects unsupported herdr pane read sources before running a command", async () => {
+		const { runner, calls } = mockRunCommand({});
+		const handler = new HerdrProtocolHandler(runner);
+
+		await expect(handler.resolve(parseInternalUrl("herdr://pane/pane-1?source=tail"))).rejects.toThrow(
+			/source.*visible.*recent.*recent-unwrapped/i,
+		);
+		expect(calls).toHaveLength(0);
+	});
+
+	it("resolves hunk://context using ResolveContext.cwd as the default repo", async () => {
+		const cwd = path.join(os.tmpdir(), "omp-hunk-context");
+		const args = ["session", "context", "--repo", cwd];
+		const { runner, calls } = mockRunCommand({ [commandKey("hunk", args)]: "context text\n" });
+		const handler = new HunkProtocolHandler(runner);
+
+		const resource = await handler.resolve(parseInternalUrl("hunk://context"), { cwd });
+
+		expect(resource.content).toBe("context text\n");
+		expect(resource.contentType).toBe("text/plain");
+		expect(handler.immutable).toBe(true);
+		expect(calls[0]?.args).toEqual(args);
+	});
+
+	it("runs explicit relative hunk repos from ResolveContext.cwd", async () => {
+		const cwd = path.join(os.tmpdir(), "omp-hunk-parent");
+		const repo = "relative-repo";
+		const args = ["session", "context", "--repo", repo];
+		const { runner, calls } = mockRunCommand({ [commandKey("hunk", args)]: "context text\n" });
+		const handler = new HunkProtocolHandler(runner);
+
+		await handler.resolve(parseInternalUrl(`hunk://context?repo=${repo}`), { cwd });
+
+		expect(calls[0]?.args).toEqual(args);
+		expect(calls[0]?.options?.cwd).toBe(cwd);
+	});
+
+	it("accepts 1/true/yes/on booleans for hunk review includePatch", async () => {
+		const repo = "/tmp/repo";
+		const { runner, calls } = mockRunCommand((command, args) =>
+			command === "hunk" &&
+			args[0] === "session" &&
+			args[1] === "review" &&
+			args.includes("--repo") &&
+			args.includes(repo) &&
+			args.includes("--include-patch")
+				? "{}\n"
+				: undefined,
+		);
+		const handler = new HunkProtocolHandler(runner);
+
+		for (const value of ["1", "true", "yes", "on"]) {
+			await handler.resolve(parseInternalUrl(`hunk://review?repo=/tmp/repo&includePatch=${value}`));
+		}
+
+		expect(calls).toHaveLength(4);
+		for (const call of calls) {
+			expect(call.command).toBe("hunk");
+			expect(call.args).toEqual(expect.arrayContaining(["session", "review", "--repo", repo, "--include-patch"]));
+		}
+	});
+
+	it("resolves hunk review and comments endpoints through hunk session commands", async () => {
+		const repo = "/tmp/repo";
+		const { runner, calls } = mockRunCommand((command, args) => {
+			if (command !== "hunk" || args[0] !== "session" || !args.includes("--repo") || !args.includes(repo))
+				return undefined;
+			if (args[1] === "review" && args.includes("--include-patch") && args.includes("--include-notes"))
+				return "review text\n";
+			if (args[1] === "comment" && args[2] === "list" && args.includes("user")) return "[]\n";
+			return undefined;
+		});
+		const handler = new HunkProtocolHandler(runner);
+
+		const review = await handler.resolve(
+			parseInternalUrl("hunk://review?repo=/tmp/repo&includePatch=1&includeNotes=on"),
+		);
+		const comments = await handler.resolve(parseInternalUrl("hunk://comments?repo=/tmp/repo&type=user"));
+
+		expect(review.content).toBe("review text\n");
+		expect(comments.content).toBe("[]\n");
+		expect(calls.map(call => [call.command, call.args[0], call.args[1], call.args[2]])).toEqual([
+			["hunk", "session", "review", "--repo"],
+			["hunk", "session", "comment", "list"],
+		]);
+		expect(calls[0]?.args).toEqual(expect.arrayContaining(["--include-patch", "--include-notes"]));
+		expect(calls[1]?.args).toEqual(expect.arrayContaining(["user"]));
+	});
+});
diff --git c/packages/coding-agent/src/internal-urls/herdr-hunk-protocol.ts i/packages/coding-agent/src/internal-urls/herdr-hunk-protocol.ts
new file mode 100644
index 000000000..834ccf779
--- /dev/null
+++ i/packages/coding-agent/src/internal-urls/herdr-hunk-protocol.ts
@@ -0,0 +1,304 @@
+/**
+ * Protocol handlers for local Herdr and Hunk resources.
+ *
+ * URL forms:
+ * - herdr://status
+ * - herdr://snapshot
+ * - herdr://workspaces
+ * - herdr://tabs?workspace=<id>
+ * - herdr://panes?workspace=<id>
+ * - herdr://pane/<id>?source=recent&lines=80
+ * - hunk://review?repo=<path>&includePatch=1&includeNotes=1
+ * - hunk://context?repo=<path>
+ * - hunk://comments?repo=<path>&type=user
+ */
+import * as childProcess from "node:child_process";
+import { randomUUID } from "node:crypto";
+import * as fs from "node:fs/promises";
+import * as os from "node:os";
+import * as path from "node:path";
+import type { InternalResource, InternalUrl, ProtocolHandler, ResolveContext } from "./types";
+
+const DEFAULT_HERDR_TIMEOUT_MS = 10_000;
+const DEFAULT_HUNK_TIMEOUT_MS = 30_000;
+const HERDR_PANE_SOURCES = new Set(["visible", "recent", "recent-unwrapped"]);
+const HUNK_COMMENT_TYPES = new Set(["live", "all", "ai", "agent", "user"]);
+
+type ContentType = InternalResource["contentType"];
+
+export interface LocalCommandOptions {
+	cwd?: string;
+	signal?: AbortSignal;
+	timeoutMs?: number;
+}
+
+export interface LocalCommandResult {
+	stdout: string;
+	stderr: string;
+	exitCode: number;
+}
+
+export type LocalCommandRunner = (
+	command: string,
+	args: string[],
+	options?: LocalCommandOptions,
+) => Promise<LocalCommandResult>;
+
+function commandLine(command: string, args: readonly string[]): string {
+	return [command, ...args].join(" ");
+}
+
+function abortError(command: string): Error {
+	return new Error(`${command} command cancelled`);
+}
+
+function textOutput(value: string | Buffer): string {
+	return typeof value === "string" ? value : value.toString("utf-8");
+}
+
+export async function runLocalCommand(
+	command: string,
+	args: string[],
+	options: LocalCommandOptions = {},
+): Promise<LocalCommandResult> {
+	if (options.signal?.aborted) throw abortError(command);
+	return await new Promise<LocalCommandResult>((resolve, reject) => {
+		childProcess.execFile(
+			command,
+			args,
+			{
+				cwd: options.cwd,
+				signal: options.signal,
+				timeout: options.timeoutMs ?? DEFAULT_HERDR_TIMEOUT_MS,
+				maxBuffer: 64 * 1024 * 1024,
+			},
+			(error, stdout, stderr) => {
+				const result = {
+					stdout: textOutput(stdout),
+					stderr: textOutput(stderr),
+					exitCode: typeof error?.code === "number" ? error.code : 0,
+				};
+				if (error && typeof error.code !== "number") {
+					reject(new Error(`${commandLine(command, args)} failed: ${error.message}`));
+					return;
+				}
+				resolve(result);
+			},
+		);
+	});
+}
+
+function assertSuccess(label: string, result: LocalCommandResult): void {
+	if (result.exitCode === 0) return;
+	throw new Error(
+		[`${label} failed with exit code ${result.exitCode}`, result.stdout.trim(), result.stderr.trim()]
+			.filter(Boolean)
+			.join("\n\n"),
+	);
+}
+
+function decodeSegment(segment: string, scheme: string): string {
+	try {
+		return decodeURIComponent(segment);
+	} catch {
+		throw new Error(`Invalid ${scheme}:// URL encoding`);
+	}
+}
+
+function pathSegments(url: InternalUrl, scheme: string): string[] {
+	const raw = url.rawPathname ?? url.pathname;
+	const stripped = raw.startsWith("/") ? raw.slice(1) : raw;
+	if (!stripped) return [];
+	return stripped.split("/").map(segment => {
+		const decoded = decodeSegment(segment, scheme);
+		if (!decoded || decoded === "." || decoded === ".." || decoded.includes("/") || decoded.includes("\\")) {
+			throw new Error(`Invalid ${scheme}:// URL path segment`);
+		}
+		return decoded;
+	});
+}
+
+function parseBooleanParam(params: URLSearchParams, name: string): boolean {
+	const raw = params.get(name);
+	if (raw === null || raw === "") return false;
+	return ["1", "true", "yes", "on"].includes(raw.toLowerCase());
+}
+
+function parsePositiveIntParam(params: URLSearchParams, name: string, fallback: number, scheme: string): number {
+	const raw = params.get(name);
+	if (raw === null || raw === "") return fallback;
+	const parsed = Number(raw);
+	if (!Number.isInteger(parsed) || parsed < 1) {
+		throw new Error(`Invalid ${scheme}:// ${name} '${raw}'. Expected a positive integer.`);
+	}
+	return parsed;
+}
+
+function renderCliContent(
+	stdout: string,
+	fallbackFileName: string,
+): { content: string; contentType: ContentType; fileName: string } {
+	const trimmed = stdout.trim();
+	if (!trimmed) return { content: stdout, contentType: "text/plain", fileName: fallbackFileName };
+	try {
+		JSON.parse(trimmed);
+		return { content: stdout, contentType: "application/json", fileName: "output.json" };
+	} catch {
+		return { content: stdout, contentType: "text/plain", fileName: fallbackFileName };
+	}
+}
+
+function cacheKey(url: string): string {
+	return Bun.hash(url).toString(36);
+}
+
+async function materialize(
+	scheme: string,
+	url: string,
+	fileName: string,
+	content: string,
+): Promise<{ sourcePath: string; sourceDisplayUrl: string }> {
+	const parent = path.join(os.tmpdir(), "omp-internal-urls", scheme);
+	const targetDir = path.join(parent, cacheKey(url));
+	const tempDir = path.join(parent, `${cacheKey(url)}.${process.pid}.${randomUUID()}.tmp`);
+	await fs.mkdir(parent, { recursive: true });
+	await fs.mkdir(tempDir, { recursive: true });
+	try {
+		await fs.writeFile(path.join(tempDir, fileName), content);
+		await fs.rm(targetDir, { recursive: true, force: true });
+		await fs.rename(tempDir, targetDir);
+	} catch (error) {
+		await fs.rm(tempDir, { recursive: true, force: true }).catch(() => {});
+		throw error;
+	}
+	return { sourcePath: path.join(targetDir, fileName), sourceDisplayUrl: url };
+}
+
+function buildResource(
+	url: InternalUrl,
+	scheme: string,
+	payload: { content: string; contentType: ContentType; fileName: string },
+): Promise<InternalResource> {
+	return materialize(scheme, url.href, payload.fileName, payload.content).then(materialized => ({
+		url: url.href,
+		content: payload.content,
+		contentType: payload.contentType,
+		size: Buffer.byteLength(payload.content, "utf-8"),
+		sourcePath: materialized.sourcePath,
+		sourceDisplayUrl: materialized.sourceDisplayUrl,
+	}));
+}
+
+export class HerdrProtocolHandler implements ProtocolHandler {
+	readonly scheme = "herdr";
+	readonly immutable = true;
+
+	constructor(private readonly runCommand: LocalCommandRunner = runLocalCommand) {}
+
+	async resolve(url: InternalUrl, context?: ResolveContext): Promise<InternalResource> {
+		const action = (url.rawHost || url.hostname).toLowerCase();
+		const segments = pathSegments(url, "herdr");
+		const args = this.#argsFor(action, segments, url.searchParams);
+		const result = await this.runCommand("herdr", args, {
+			cwd: context?.cwd,
+			signal: context?.signal,
+			timeoutMs: DEFAULT_HERDR_TIMEOUT_MS,
+		});
+		assertSuccess(`herdr ${args.join(" ")}`, result);
+		const payload = renderCliContent(result.stdout, `${action || "herdr"}.txt`);
+		return buildResource(url, this.scheme, payload);
+	}
+
+	#argsFor(action: string, segments: string[], params: URLSearchParams): string[] {
+		switch (action) {
+			case "status":
+				if (segments.length > 0) throw new Error("herdr://status does not accept path segments");
+				return ["status"];
+			case "snapshot":
+				if (segments.length > 0) throw new Error("herdr://snapshot does not accept path segments");
+				return ["api", "snapshot"];
+			case "workspaces":
+				if (segments.length > 0) throw new Error("herdr://workspaces does not accept path segments");
+				return ["workspace", "list"];
+			case "tabs":
+				if (segments.length > 0) throw new Error("herdr://tabs does not accept path segments");
+				return this.#listArgs("tab", params);
+			case "panes":
+				if (segments.length > 0) throw new Error("herdr://panes does not accept path segments");
+				return this.#listArgs("pane", params);
+			case "pane":
+				return this.#paneArgs(segments, params);
+			default:
+				throw new Error(
+					"Unsupported herdr:// resource. Expected status, snapshot, workspaces, tabs, panes, or pane/<id>.",
+				);
+		}
+	}
+
+	#listArgs(kind: "tab" | "pane", params: URLSearchParams): string[] {
+		const args = [kind, "list"];
+		const workspace = params.get("workspace");
+		if (workspace) args.push("--workspace", workspace);
+		return args;
+	}
+
+	#paneArgs(segments: string[], params: URLSearchParams): string[] {
+		const [paneId, ...extra] = segments;
+		if (!paneId || extra.length > 0) throw new Error("herdr://pane requires exactly one pane id path segment");
+		const source = params.get("source") ?? "recent";
+		if (!HERDR_PANE_SOURCES.has(source)) {
+			throw new Error("Invalid herdr:// pane source. Expected visible, recent, or recent-unwrapped.");
+		}
+		const lines = parsePositiveIntParam(params, "lines", 80, "herdr");
+		return ["pane", "read", paneId, "--source", source, "--lines", String(lines)];
+	}
+}
+
+export class HunkProtocolHandler implements ProtocolHandler {
+	readonly scheme = "hunk";
+	readonly immutable = true;
+
+	constructor(private readonly runCommand: LocalCommandRunner = runLocalCommand) {}
+
+	async resolve(url: InternalUrl, context?: ResolveContext): Promise<InternalResource> {
+		const action = (url.rawHost || url.hostname).toLowerCase();
+		const segments = pathSegments(url, "hunk");
+		if (segments.length > 0) throw new Error(`hunk://${action} does not accept path segments`);
+		const repo = url.searchParams.get("repo") || context?.cwd || process.cwd();
+		const args = this.#argsFor(action, repo, url.searchParams);
+		const result = await this.runCommand("hunk", args, {
+			cwd: context?.cwd || process.cwd(),
+			signal: context?.signal,
+			timeoutMs: DEFAULT_HUNK_TIMEOUT_MS,
+		});
+		assertSuccess(`hunk ${args.join(" ")}`, result);
+		const payload = renderCliContent(result.stdout, `${action || "hunk"}.txt`);
+		return buildResource(url, this.scheme, payload);
