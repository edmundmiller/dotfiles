#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# ///
"""Cycle Herdr workspaces."""

from __future__ import annotations

import argparse
import json
import os
from pathlib import Path
import shutil
import subprocess
import sys
from typing import Any, NoReturn

PROG = "herdr-workspace"


def die(message: str, code: int = 1) -> NoReturn:
    print(f"{PROG}: {message}", file=sys.stderr)
    raise SystemExit(code)


def herdr_bin() -> str:
    configured = os.environ.get("HERDR_BIN_PATH", "herdr")
    return configured if shutil.which(configured) else "herdr"


def run_json(herdr: str, *args: str) -> dict[str, Any]:
    try:
        result = subprocess.run(
            [herdr, *args], check=True, text=True, stdout=subprocess.PIPE
        )
    except FileNotFoundError:
        die(f"Herdr binary not found: {herdr}", 127)
    except subprocess.CalledProcessError as exc:
        raise SystemExit(exc.returncode)
    try:
        return json.loads(result.stdout)
    except json.JSONDecodeError as exc:
        die(f"invalid JSON from `{' '.join([herdr, *args])}`: {exc}")


def target_workspace_id(payload: dict[str, Any], direction: str) -> str:
    workspaces = payload.get("result", {}).get("workspaces", [])
    workspaces.sort(key=lambda ws: ws.get("number", 0))
    if not workspaces:
        die("no workspaces found")
    focused_index = next((i for i, ws in enumerate(workspaces) if ws.get("focused")), 0)
    offset = -1 if direction == "previous" else 1
    return str(workspaces[(focused_index + offset) % len(workspaces)]["workspace_id"])


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(prog=PROG, usage="%(prog)s previous|next")
    parser.add_argument("direction", choices=("previous", "next"))
    return parser.parse_args()


def main() -> None:
    args = parse_args()
    herdr = herdr_bin()
    workspace_id = target_workspace_id(
        run_json(herdr, "workspace", "list"), args.direction
    )
    os.execvp(herdr, [herdr, "workspace", "focus", workspace_id])


def _sample_workspace_payload() -> dict[str, Any]:
    return {
        "result": {
            "workspaces": [
                {"workspace_id": "w1", "number": 1, "focused": False},
                {"workspace_id": "w2", "number": 2, "focused": True},
                {"workspace_id": "w3", "number": 3, "focused": False},
            ]
        }
    }


def test_target_workspace_id_cycles_next() -> None:
    assert target_workspace_id(_sample_workspace_payload(), "next") == "w3"


def test_target_workspace_id_cycles_previous() -> None:
    assert target_workspace_id(_sample_workspace_payload(), "previous") == "w1"


def test_target_workspace_id_wraps() -> None:
    payload = _sample_workspace_payload()
    for workspace in payload["result"]["workspaces"]:
        workspace["focused"] = workspace["workspace_id"] == "w3"
    assert target_workspace_id(payload, "next") == "w1"


def run_self_test() -> int:
    import shutil
    import tempfile

    try:
        import pytest
    except ImportError:
        eprint = getattr(sys.modules[__name__], "eprint", None)
        message = (
            f"{PROG}: pytest is required for --self-test; run via "
            f"`uv run --with pytest --script {Path(__file__).name} --self-test`"
        )
        if eprint:
            eprint(message.removeprefix(f"{PROG}: "))
        else:
            print(message, file=sys.stderr)
        return 1

    with tempfile.TemporaryDirectory(prefix=f"{PROG}-self-test-") as tempdir:
        test_file = Path(tempdir) / f"{PROG}.py"
        shutil.copy2(__file__, test_file)
        return pytest.main([str(test_file)])


if __name__ == "__main__":
    if "--self-test" in sys.argv[1:]:
        raise SystemExit(run_self_test())
    main()
