+/// Identify an agent from distinctive live terminal UI chrome.
+///
+/// This supplements foreground process detection for wrappers/backends where the
+/// running process name belongs to an implementation backend (for example Codex)
+/// while the visible user-facing agent is Hermes.
+pub fn identify_agent_from_screen(screen_content: &str) -> Option<Agent> {
+    let lower = screen_content.to_lowercase();
+
+    // Keep this intentionally narrow: Herdr often captures source files, docs,
+    // and shell output in panes. A random mention of "hermes" (for example in
+    // a Python file or this dotfiles Herdr workspace) must not reclassify the
+    // pane. Only accept distinctive live Hermes chrome/status lines.
+    let has_hermes_title = lower.lines().any(|line| {
+        let trimmed = line.trim();
+        trimmed.starts_with('─')
+            && trimmed.ends_with('─')
+            && trimmed.trim_matches('─').trim() == "hermes"
+    });
+    let has_hermes_status = screen_content.lines().any(|line| {
+        let trimmed = line.trim_start();
+        trimmed.starts_with("⚕ ")
+            && line.contains('│')
+            && (line.contains("⏲") || line.contains("⏱"))
+    });
+
+    if has_hermes_title || has_hermes_status {
+        return Some(Agent::Hermes);
+    }
+
+    None
+}
