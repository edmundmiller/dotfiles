+/// Identify an agent from distinctive live terminal UI chrome.
+///
+/// This supplements foreground process detection for wrappers/backends where the
+/// running process name belongs to an implementation backend (for example Codex)
+/// while the visible user-facing agent is Hermes.
+pub fn identify_agent_from_screen(screen_content: &str) -> Option<Agent> {
+    let lower = screen_content.to_lowercase();
+
+    if screen_content.contains("⚕")
+        || lower.contains(" hermes ")
+        || lower.contains("─  hermes  ─")
+        || lower.contains("msg=interrupt")
+    {
+        return Some(Agent::Hermes);
+    }
+
+    None
+}
