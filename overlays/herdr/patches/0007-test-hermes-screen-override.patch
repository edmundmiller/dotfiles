+    // Regression for https://github.com/ogulcancelik/herdr/issues/258:
+    // Hermes can use Codex as an implementation backend, but Herdr should
+    // still label the visible user-facing Hermes TUI as Hermes.
+    #[test]
+    fn screen_chrome_overrides_codex_backend_to_hermes() {
+        let mut presence = AgentDetectionPresence::from_agent(Some(Agent::Codex));
+        let mut agent = presence.current_agent();
+        let mut agent_changed = false;
+        let screen = " ─  Hermes  ──────────────────────────────────────────────────────────────
+ ⚕ gpt-5.5 │ 0/272K │ [░░░░░░░░░░] 0% │ 11m │ ⏲ 40s
+─────────────────────────────────────────────────────────────────────────
+❯";
+
+        let transition = apply_screen_agent_override(
+            &mut presence,
+            &mut agent,
+            &mut agent_changed,
+            screen,
+        );
+
+        assert_eq!(transition, Some((Some(Agent::Codex), Some(Agent::Hermes))));
+        assert!(agent_changed);
+        assert_eq!(agent, Some(Agent::Hermes));
+        assert_eq!(presence.current_agent(), Some(Agent::Hermes));
+    }
+
+    #[test]
+    fn plain_screen_does_not_override_process_agent() {
+        let mut presence = AgentDetectionPresence::from_agent(Some(Agent::Codex));
+        let mut agent = presence.current_agent();
+        let mut agent_changed = false;
+
+        let transition = apply_screen_agent_override(
+            &mut presence,
+            &mut agent,
+            &mut agent_changed,
+            "plain codex prompt",
+        );
+
+        assert_eq!(transition, None);
+        assert!(!agent_changed);
+        assert_eq!(agent, Some(Agent::Codex));
+    }
