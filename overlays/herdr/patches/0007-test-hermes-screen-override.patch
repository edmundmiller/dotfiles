+fn apply_screen_agent_override(
+    agent_presence: &mut AgentDetectionPresence,
+    agent: &mut Option<Agent>,
+    agent_changed: &mut bool,
+    screen_content: &str,
+) -> Option<(Option<Agent>, Option<Agent>)> {
+    let screen_agent = crate::detect::identify_agent_from_screen(screen_content)?;
+    if Some(screen_agent) == *agent {
+        return None;
+    }
+
+    let previous_agent = *agent;
+    if agent_presence.observe_process_probe(Some(screen_agent)) {
+        *agent = agent_presence.current_agent();
+        *agent_changed = true;
+        return Some((previous_agent, *agent));
+    }
+
+    None
+}
