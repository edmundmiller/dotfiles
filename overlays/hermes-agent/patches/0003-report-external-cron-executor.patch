@@ -65,0 +68,35 @@ def _active_cron_provider_name() -> str:
+def _external_systemd_executor_status():
+    """Return ``(unit, active)`` for a host-declared systemd executor.
+
+    Timer-driven deployments write ``$HERMES_HOME/cron/executor.json`` so
+    CLI health output can verify the real executor instead of assuming the
+    gateway process is the only way built-in cron jobs can fire.
+    """
+    hermes_home = Path(os.environ.get("HERMES_HOME") or (Path.home() / ".hermes"))
+    executor_path = hermes_home / "cron" / "executor.json"
+    try:
+        executor = json.loads(executor_path.read_text(encoding="utf-8"))
+    except (OSError, json.JSONDecodeError, TypeError):
+        return None
+
+    if executor.get("kind") != "systemd":
+        return None
+    unit = executor.get("unit")
+    if not isinstance(unit, str) or not unit.strip():
+        return None
+    unit = unit.strip()
+
+    try:
+        result = subprocess.run(
+            ["systemctl", "is-active", "--quiet", unit],
+            check=False,
+            stdout=subprocess.DEVNULL,
+            stderr=subprocess.DEVNULL,
+            timeout=3,
+        )
+        active = result.returncode == 0
+    except (OSError, subprocess.TimeoutExpired):
+        active = False
+    return unit, active
+
+
