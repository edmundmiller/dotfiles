+import { describe, expect, test } from "bun:test";
+import { buildAppMenus } from "./appMenus";
+
+function noop() {}
+
+describe("app menus", () => {
+  test("builds Source menu entries from review sources", () => {
+    const selected: string[] = [];
+    const menus = buildAppMenus({
+      canRefreshCurrentInput: true,
+      focusFilter: noop,
+      layoutMode: "auto",
+      moveToAnnotatedFile: noop,
+      moveToAnnotatedHunk: noop,
+      moveToHunk: noop,
+      refreshCurrentInput: noop,
+      requestQuit: noop,
+      reviewSourceItems: [
+        { id: "unstaged", label: "Unstaged", hint: "u", active: true, enabled: true },
+        { id: "staged", label: "Staged", hint: "s", active: false, enabled: true },
+      ],
+      selectLayoutMode: noop,
+      switchReviewSource: (source) => selected.push(source),
+      openThemeSelector: noop,
+      copyDecorations: false,
+      showAgentNotes: true,
+      showHelp: false,
+      showHunkHeaders: true,
+      showLineNumbers: true,
+      renderSidebar: true,
+      toggleCopyDecorations: noop,
+      toggleAgentNotes: noop,
+      toggleFocusArea: noop,
+      toggleHelp: noop,
+      toggleHunkHeaders: noop,
+      toggleLineNumbers: noop,
+      toggleLineWrap: noop,
+      toggleSidebar: noop,
+      triggerEditSelectedFile: noop,
+      wrapLines: false,
+    });
+
+    expect(menus.source).toHaveLength(2);
+    expect(menus.source[0]).toMatchObject({
+      kind: "item",
+      label: "Unstaged",
+      hint: "u",
+      checked: true,
+    });
+
+    const staged = menus.source[1];
+    expect(staged?.kind).toBe("item");
+    if (staged?.kind === "item") staged.action();
+    expect(selected).toEqual(["staged"]);
+  });
+});
