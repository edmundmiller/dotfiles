diff --git i/src/ui/lib/sourceSwitch.test.ts w/src/ui/lib/sourceSwitch.test.ts
new file mode 100644
index 0000000..60c3306
--- /dev/null
+++ w/src/ui/lib/sourceSwitch.test.ts
@@ -0,0 +1,128 @@
+import { execFileSync } from "node:child_process";
+import { mkdirSync, mkdtempSync, rmSync, writeFileSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { dirname, join } from "node:path";
+import { describe, expect, test } from "bun:test";
+import {
+  activeReviewSource,
+  buildReviewSourceItems,
+  resolveReviewSourceInput,
+} from "./sourceSwitch";
+import type { CliInput } from "../../core/types";
+
+function git(repo: string, args: string[]) {
+  return execFileSync("git", args, {
+    cwd: repo,
+    encoding: "utf8",
+    stdio: ["ignore", "pipe", "ignore"],
+  }).trim();
+}
+
+function createRepo() {
+  const repo = mkdtempSync(join(tmpdir(), "hunk-source-switch-"));
+  git(repo, ["init"]);
+  git(repo, ["config", "user.email", "test@test"]);
+  git(repo, ["config", "user.name", "Test"]);
+  writeFileSync(join(repo, "file.txt"), "base\n");
+  git(repo, ["add", "."]);
+  git(repo, ["commit", "-m", "init"]);
+  return repo;
+}
+
+describe("source switch", () => {
+  test("builds source entries with active staged source", () => {
+    const input: CliInput = { kind: "vcs", staged: true, options: {} };
+    const items = buildReviewSourceItems(input);
+
+    expect(items.map((item) => item.id)).toEqual([
+      "unstaged",
+      "staged",
+      "commit",
+      "branch",
+      "pi-last-turn",
+    ]);
+    expect(items.find((item) => item.id === "staged")?.active).toBe(true);
+    expect(activeReviewSource(input)).toBe("staged");
+  });
+
+  test("resolves built-in sources to cli inputs", () => {
+    const options = { mode: "stack" as const };
+
+    expect(resolveReviewSourceInput("unstaged", "/repo", options)).toMatchObject({
+      kind: "input",
+      input: { kind: "vcs", staged: false, options },
+      sourcePath: "/repo",
+    });
+    expect(resolveReviewSourceInput("staged", "/repo", options)).toMatchObject({
+      kind: "input",
+      input: { kind: "vcs", staged: true, options },
+      sourcePath: "/repo",
+    });
+    expect(resolveReviewSourceInput("commit", "/repo", options)).toMatchObject({
+      kind: "input",
+      input: { kind: "show", ref: "HEAD", options },
+      sourcePath: "/repo",
+    });
+  });
+
+  test("resolves branch source through upstream merge-base", () => {
+    const repo = createRepo();
+    const remote = mkdtempSync(join(tmpdir(), "hunk-source-remote-"));
+    git(remote, ["init", "--bare"]);
+
+    try {
+      git(repo, ["branch", "-M", "main"]);
+      git(repo, ["remote", "add", "origin", remote]);
+      git(repo, ["push", "-u", "origin", "main"]);
+      writeFileSync(join(repo, "file.txt"), "base\nbranch\n");
+      git(repo, ["add", "."]);
+      git(repo, ["commit", "-m", "branch"]);
+
+      const result = resolveReviewSourceInput("branch", repo, {});
+      expect(result.kind).toBe("input");
+      if (result.kind === "input") {
+        expect(result.input).toMatchObject({ kind: "vcs", staged: false });
+        expect(result.input.kind === "vcs" ? result.input.range : "").toEndWith("...HEAD");
+      }
+    } finally {
+      rmSync(repo, { force: true, recursive: true });
+      rmSync(remote, { force: true, recursive: true });
+    }
+  });
+
+  test("missing Pi marker returns a notice", () => {
+    const repo = createRepo();
+    try {
+      expect(resolveReviewSourceInput("pi-last-turn", repo, {})).toEqual({
+        kind: "notice",
+        message: "No Last Pi turn source for this repo.",
+      });
+    } finally {
+      rmSync(repo, { force: true, recursive: true });
+    }
+  });
+
+  test("Pi marker resolves to patch input", () => {
+    const repo = createRepo();
+    try {
+      const markerPath = join(
+        repo,
+        git(repo, ["rev-parse", "--git-path", "hunk/last-pi-turn.json"]),
+      );
+      const patchPath = join(
+        repo,
+        git(repo, ["rev-parse", "--git-path", "hunk/last-pi-turn.patch"]),
+      );
+      mkdirSync(dirname(markerPath), { recursive: true });
+      writeFileSync(patchPath, "diff --git a/file.txt b/file.txt\n");
+      writeFileSync(markerPath, JSON.stringify({ version: 1, kind: "patch", file: patchPath }));
+
+      expect(resolveReviewSourceInput("pi-last-turn", repo, { mode: "split" })).toMatchObject({
+        kind: "input",
+        input: { kind: "patch", file: patchPath, options: { mode: "split" } },
+      });
+    } finally {
+      rmSync(repo, { force: true, recursive: true });
+    }
+  });
+});
