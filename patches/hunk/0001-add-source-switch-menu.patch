diff --git i/src/ui/lib/sourceSwitch.test.ts w/src/ui/lib/sourceSwitch.test.ts
new file mode 100644
index 0000000..bc015e2
--- /dev/null
+++ w/src/ui/lib/sourceSwitch.test.ts
@@ -0,0 +1,217 @@
+import { execFileSync } from "node:child_process";
+import { chmodSync, mkdirSync, mkdtempSync, readFileSync, rmSync, writeFileSync } from "node:fs";
+import { tmpdir } from "node:os";
+import { dirname, join } from "node:path";
+import { describe, expect, test } from "bun:test";
+import {
+  activeReviewSource,
+  buildReviewSourceItems,
+  resolveReviewSourceInput,
+  repoPathForInput,
+  sourceIndicatorLabel,
+} from "./sourceSwitch";
+import type { CliInput } from "../../core/types";
+
+function git(repo: string, args: string[]) {
+  return execFileSync("git", args, {
+    cwd: repo,
+    encoding: "utf8",
+    stdio: ["ignore", "pipe", "ignore"],
+  }).trim();
+}
+
+function createRepo() {
+  const repo = mkdtempSync(join(tmpdir(), "hunk-source-switch-"));
+  git(repo, ["init"]);
+  git(repo, ["config", "user.email", "test@test"]);
+  git(repo, ["config", "user.name", "Test"]);
+  writeFileSync(join(repo, "file.txt"), "base\n");
+  git(repo, ["add", "."]);
+  git(repo, ["commit", "-m", "init"]);
+  return repo;
+}
+
+describe("source switch", () => {
+  test("builds source entries with active staged source", () => {
+    const input: CliInput = { kind: "vcs", staged: true, options: {} };
+    const items = buildReviewSourceItems(input);
+
+    expect(items.map((item) => item.id)).toEqual([
+      "unstaged",
+      "staged",
+      "commit",
+      "branch",
+      "pi-last-turn",
+      "omp-last-turn",
+    ]);
+    expect(items.find((item) => item.id === "staged")?.active).toBe(true);
+    expect(activeReviewSource(input)).toBe("staged");
+  });
+
+  test("resolves built-in sources to cli inputs", () => {
+    const options = { mode: "stack" as const };
+
+    expect(resolveReviewSourceInput("unstaged", "/repo", options)).toMatchObject({
+      kind: "input",
+      input: { kind: "vcs", staged: false, options },
+      sourcePath: "/repo",
+    });
+    expect(resolveReviewSourceInput("staged", "/repo", options)).toMatchObject({
+      kind: "input",
+      input: { kind: "vcs", staged: true, options },
+      sourcePath: "/repo",
+    });
+    expect(resolveReviewSourceInput("commit", "/repo", options)).toMatchObject({
+      kind: "input",
+      input: { kind: "show", ref: "HEAD", options },
+      sourcePath: "/repo",
+    });
+  });
+
+  test("resolves branch source through upstream merge-base", () => {
+    const repo = createRepo();
+    const remote = mkdtempSync(join(tmpdir(), "hunk-source-remote-"));
+    git(remote, ["init", "--bare"]);
+
+    try {
+      git(repo, ["branch", "-M", "main"]);
+      git(repo, ["remote", "add", "origin", remote]);
+      git(repo, ["push", "-u", "origin", "main"]);
+      writeFileSync(join(repo, "file.txt"), "base\nbranch\n");
+      git(repo, ["add", "."]);
+      git(repo, ["commit", "-m", "branch"]);
+
+      const result = resolveReviewSourceInput("branch", repo, {});
+      expect(result.kind).toBe("input");
+      if (result.kind === "input") {
+        expect(result.input).toMatchObject({ kind: "vcs", staged: false });
+        expect(result.input.kind === "vcs" ? result.input.range : "").toEndWith("...HEAD");
+      }
+    } finally {
+      rmSync(repo, { force: true, recursive: true });
+      rmSync(remote, { force: true, recursive: true });
+    }
+  });
+
+  test("missing Pi marker returns a notice", () => {
+    const repo = createRepo();
+    try {
+      expect(resolveReviewSourceInput("pi-last-turn", repo, {})).toEqual({
+        kind: "notice",
+        message: "No Last Pi turn source for this repo.",
+      });
+    } finally {
+      rmSync(repo, { force: true, recursive: true });
+    }
+  });
+
+  test("Pi marker resolves to patch input", () => {
+    const repo = createRepo();
+    try {
+      const markerPath = join(
+        repo,
+        git(repo, ["rev-parse", "--git-path", "hunk/last-pi-turn.json"]),
+      );
+      const patchPath = join(
+        repo,
+        git(repo, ["rev-parse", "--git-path", "hunk/last-pi-turn.patch"]),
+      );
+      mkdirSync(dirname(markerPath), { recursive: true });
+      writeFileSync(patchPath, "diff --git a/file.txt b/file.txt\n");
+      writeFileSync(markerPath, JSON.stringify({ version: 1, kind: "patch", file: patchPath }));
+
+      expect(resolveReviewSourceInput("pi-last-turn", repo, { mode: "split" })).toMatchObject({
+        kind: "input",
+        input: { kind: "patch", file: patchPath, options: { mode: "split" } },
+      });
+      expect(sourceIndicatorLabel({ kind: "patch", file: patchPath, options: {} }, "")).toBe(
+        "Last Pi turn",
+      );
+      expect(repoPathForInput({ kind: "patch", file: patchPath, options: {} }, "")).toBe(repo);
+      expect(activeReviewSource({ kind: "patch", file: patchPath, options: {} })).toBe(
+        "pi-last-turn",
+      );
+      expect(JSON.parse(readFileSync(markerPath, "utf8"))).toMatchObject({
+        kind: "patch",
+        file: patchPath,
+      });
+    } finally {
+      rmSync(repo, { force: true, recursive: true });
+    }
+  });
+
+  test("OMP marker resolves through same last-turn source seam", () => {
+    const repo = createRepo();
+    try {
+      const markerPath = join(
+        repo,
+        git(repo, ["rev-parse", "--git-path", "hunk/last-omp-turn.json"]),
+      );
+      const patchPath = join(
+        repo,
+        git(repo, ["rev-parse", "--git-path", "hunk/last-omp-turn.patch"]),
+      );
+      mkdirSync(dirname(markerPath), { recursive: true });
+      writeFileSync(patchPath, "diff --git a/file.txt b/file.txt\n");
+      writeFileSync(markerPath, JSON.stringify({ version: 1, kind: "patch", file: patchPath }));
+
+      const result = resolveReviewSourceInput("omp-last-turn", repo, { mode: "split" });
+      expect(result).toMatchObject({
+        kind: "input",
+        input: { kind: "patch", file: patchPath, options: { mode: "split" } },
+        label: "Last OMP turn",
+      });
+      expect(sourceIndicatorLabel({ kind: "patch", file: patchPath, options: {} }, "")).toBe(
+        "Last OMP turn",
+      );
+      expect(activeReviewSource({ kind: "patch", file: patchPath, options: {} })).toBe(
+        "omp-last-turn",
+      );
+      expect(repoPathForInput({ kind: "patch", file: patchPath, options: {} }, "")).toBe(repo);
+    } finally {
+      rmSync(repo, { force: true, recursive: true });
+    }
+  });
+
+  test("adds open PRs for the current branch and resolves PR diffs", () => {
+    const repo = createRepo();
+    const bin = mkdtempSync(join(tmpdir(), "hunk-source-gh-"));
+    const gh = join(bin, "gh");
+    const originalPath = process.env.PATH;
+
+    try {
+      git(repo, ["checkout", "-b", "feature"]);
+      writeFileSync(
+        gh,
+        `#!/bin/sh
+if [ "$2" = "diff" ]; then
+  printf 'diff --git a/file.txt b/file.txt\n--- a/file.txt\n+++ b/file.txt\n@@ -1 +1,2 @@\n base\n+pr change\n'
+else
+  printf '[{"number":123,"title":"Add source switch"}]'
+fi
+`,
+      );
+      chmodSync(gh, 0o755);
+      process.env.PATH = `${bin}:${originalPath ?? ""}`;
+
+      const items = buildReviewSourceItems({ kind: "vcs", staged: false, options: {} }, repo);
+      expect(items.find((item) => item.id === "pr:123")).toMatchObject({
+        label: "PR #123 Add source switch",
+        hint: "1",
+      });
+
+      const result = resolveReviewSourceInput("pr:123", repo, { mode: "stack" });
+      expect(result.kind).toBe("input");
+      if (result.kind === "input") {
+        expect(result).toMatchObject({ label: "PR #123", sourcePath: repo });
+        expect(result.input).toMatchObject({ kind: "patch", options: { mode: "stack" } });
+        expect(sourceIndicatorLabel(result.input, "")).toBe("PR #123");
+        expect(repoPathForInput(result.input, "")).toBe(repo);
+      }
+    } finally {
+      process.env.PATH = originalPath;
+      rmSync(repo, { force: true, recursive: true });
+      rmSync(bin, { force: true, recursive: true });
+    }
+  });
+});
diff --git i/src/ui/lib/sourceSwitch.ts w/src/ui/lib/sourceSwitch.ts
new file mode 100644
index 0000000..faf5aff
--- /dev/null
+++ w/src/ui/lib/sourceSwitch.ts
@@ -0,0 +1,432 @@
+import { execFileSync } from "node:child_process";
+import { existsSync, mkdirSync, readFileSync, writeFileSync } from "node:fs";
+import { basename, dirname, isAbsolute, join, resolve, sep } from "node:path";
+import type { CliInput, CommonOptions } from "../../core/types";
+
+export type BaseReviewSourceId = "unstaged" | "staged" | "commit" | "branch";
+export type LastTurnReviewSourceId = "pi-last-turn" | "omp-last-turn";
+export type BuiltInReviewSourceId = BaseReviewSourceId | LastTurnReviewSourceId;
+export type PullRequestReviewSourceId = `pr:${number}`;
+export type ReviewSourceId = BuiltInReviewSourceId | PullRequestReviewSourceId;
+
+export interface ReviewSourceItem {
+  id: ReviewSourceId;
+  label: string;
+  hint: string;
+  active: boolean;
+  enabled: boolean;
+}
+
+export type ReviewSourceSwitchResult =
+  | { kind: "input"; input: CliInput; sourcePath?: string; label: string }
+  | { kind: "notice"; message: string };
+
+interface BranchPullRequest {
+  number: number;
+  title: string;
+}
+
+interface LastTurnSource {
+  id: LastTurnReviewSourceId;
+  label: string;
+  hint: string;
+  markerBasename: string;
+}
+
+const BASE_SOURCE_LABELS: Record<BaseReviewSourceId, string> = {
+  unstaged: "Unstaged",
+  staged: "Staged",
+  commit: "Commit",
+  branch: "Branch",
+};
+
+const BASE_SOURCE_HINTS: Record<BaseReviewSourceId, string> = {
+  unstaged: "u",
+  staged: "s",
+  commit: "c",
+  branch: "b",
+};
+
+const LAST_TURN_SOURCES: LastTurnSource[] = [
+  { id: "pi-last-turn", label: "Last Pi turn", hint: "p", markerBasename: "last-pi-turn" },
+  { id: "omp-last-turn", label: "Last OMP turn", hint: "o", markerBasename: "last-omp-turn" },
+];
+
+export const REVIEW_SOURCE_ORDER: BuiltInReviewSourceId[] = [
+  "unstaged",
+  "staged",
+  "commit",
+  "branch",
+  ...LAST_TURN_SOURCES.map((source) => source.id),
+];
+
+function run(repo: string, command: string, args: string[], timeout?: number) {
+  return execFileSync(command, args, {
+    cwd: repo,
+    env: process.env,
+    encoding: "utf8",
+    stdio: ["ignore", "pipe", "ignore"],
+    timeout,
+  }).trim();
+}
+
+function runGit(repo: string, args: string[]) {
+  return run(repo, "git", args);
+}
+
+function runGh(repo: string, args: string[], timeout = 30_000) {
+  return run(repo, "gh", args, timeout);
+}
+
+function lastTurnSource(id: string) {
+  return LAST_TURN_SOURCES.find((source) => source.id === id);
+}
+
+function lastTurnSourceByPatch(path: string) {
+  const patchBasename = basename(path).replace(/\.patch$/, "");
+  return LAST_TURN_SOURCES.find((source) => source.markerBasename === patchBasename);
+}
+
+function sourceLabel(id: BuiltInReviewSourceId) {
+  return BASE_SOURCE_LABELS[id as BaseReviewSourceId] ?? lastTurnSource(id)?.label ?? id;
+}
+
+function sourceHint(id: BuiltInReviewSourceId) {
+  return BASE_SOURCE_HINTS[id as BaseReviewSourceId] ?? lastTurnSource(id)?.hint ?? "";
+}
+
+function parsePullRequestId(id: string): number | null {
+  const match = id.match(/^pr:(\d+)$/);
+  return match ? Number(match[1]) : null;
+}
+
+function pullRequestPatchPath(repo: string, number: number) {
+  const gitPath = runGit(repo, ["rev-parse", "--git-path", `hunk/pr-${number}.patch`]);
+  return isAbsolute(gitPath) ? gitPath : resolve(repo, gitPath);
+}
+
+function pullRequestLabelFromPath(path: string) {
+  const match = basename(path).match(/^pr-(\d+)\.patch$/);
+  return match ? `PR #${match[1]}` : null;
+}
+
+function isBuiltInReviewSourceId(id: string): id is BuiltInReviewSourceId {
+  return (
+    id === "unstaged" ||
+    id === "staged" ||
+    id === "commit" ||
+    id === "branch" ||
+    Boolean(lastTurnSource(id))
+  );
+}
+
+function isReviewSourceId(id: string): id is ReviewSourceId {
+  return isBuiltInReviewSourceId(id) || parsePullRequestId(id) !== null;
+}
+
+function sourceMetadataPath(patchFile: string) {
+  return `${patchFile}.source.json`;
+}
+
+function sourceMetadataForPatch(patchFile: string | undefined) {
+  if (!patchFile) return null;
+
+  const metadataFile = sourceMetadataPath(patchFile);
+
+  if (!existsSync(metadataFile)) return null;
+
+  try {
+    const metadata: unknown = JSON.parse(readFileSync(metadataFile, "utf8"));
+    return metadata && typeof metadata === "object" ? (metadata as Record<string, unknown>) : null;
+  } catch {
+    return null;
+  }
+}
+
+function persistSourceMetadata(patchFile: string, metadata: Record<string, string>) {
+  try {
+    writeFileSync(sourceMetadataPath(patchFile), JSON.stringify(metadata));
+  } catch {
+    // Sidecar metadata should never prevent reviewing a readable patch.
+  }
+}
+
+function repoPathFromGitHunkPath(patchFile: string) {
+  const marker = `${sep}.git${sep}hunk${sep}`;
+  const markerIndex = patchFile.indexOf(marker);
+  return markerIndex === -1 ? undefined : patchFile.slice(0, markerIndex);
+}
+
+function currentBranch(repo: string) {
+  try {
+    return runGit(repo, ["branch", "--show-current"]);
+  } catch {
+    return "";
+  }
+}
+
+function openPullRequestsForBranch(repo: string): BranchPullRequest[] {
+  const branch = currentBranch(repo);
+  if (!branch) return [];
+
+  try {
+    const output = runGh(
+      repo,
+      ["pr", "list", "--state", "open", "--head", branch, "--json", "number,title"],
+      2_000,
+    );
+    const parsed: unknown = JSON.parse(output || "[]");
+    if (!Array.isArray(parsed)) return [];
+
+    return parsed.flatMap((item) => {
+      if (!item || typeof item !== "object") return [];
+      const record = item as Record<string, unknown>;
+      return typeof record.number === "number" && typeof record.title === "string"
+        ? [{ number: record.number, title: record.title }]
+        : [];
+    });
+  } catch {
+    return [];
+  }
+}
+
+function pullRequestSourceItems(repo: string | undefined, activeLabel: string | null) {
+  if (!repo) return [];
+
+  return openPullRequestsForBranch(repo).map((pr, index): ReviewSourceItem => {
+    const label = `PR #${pr.number} ${pr.title}`;
+    return {
+      id: `pr:${pr.number}`,
+      label,
+      hint: String(index + 1),
+      active: activeLabel === `PR #${pr.number}`,
+      enabled: true,
+    };
+  });
+}
+
+export function reviewSourceLabel(id: ReviewSourceId) {
+  const prNumber = parsePullRequestId(id);
+  if (prNumber !== null) return `PR #${prNumber}`;
+  if (isBuiltInReviewSourceId(id)) return sourceLabel(id);
+  return id;
+}
+
+export function activeReviewSource(input: CliInput): ReviewSourceId | null {
+  if (input.kind === "show") return "commit";
+  if (input.kind === "patch" && input.file) {
+    const metadata = sourceMetadataForPatch(input.file);
+    if (typeof metadata?.sourceId === "string" && isReviewSourceId(metadata.sourceId)) {
+      return metadata.sourceId;
+    }
+    const lastTurn = lastTurnSourceByPatch(input.file);
+    if (lastTurn) return lastTurn.id;
+
+    const label = pullRequestLabelFromPath(input.file);
+    return label ? (`pr:${label.slice(4)}` as PullRequestReviewSourceId) : null;
+  }
+  if (input.kind !== "vcs") return null;
+  if (input.staged) return "staged";
+  if (input.range) return "branch";
+  return "unstaged";
+}
+
+export function sourceIndicatorLabel(input: CliInput, sourceLabel: string): string | null {
+  const active = activeReviewSource(input);
+  if (active) return reviewSourceLabel(active);
+  if (input.kind !== "patch") return null;
+
+  const patchFile = input.file ?? sourceLabel;
+  const metadata = sourceMetadataForPatch(patchFile);
+  if (typeof metadata?.label === "string") return metadata.label;
+  return lastTurnSourceByPatch(patchFile)?.label ?? pullRequestLabelFromPath(patchFile);
+}
+
+export function buildReviewSourceItems(input: CliInput, repo?: string): ReviewSourceItem[] {
+  const active = activeReviewSource(input);
+  const activeLabel = sourceIndicatorLabel(input, "");
+  return [
+    ...REVIEW_SOURCE_ORDER.map((id) => ({
+      id,
+      label: sourceLabel(id),
+      hint: sourceHint(id),
+      active: active === id,
+      enabled: true,
+    })),
+    ...pullRequestSourceItems(repo, activeLabel),
+  ];
+}
+
+export function repoPathForInput(input: CliInput, sourceLabel: string): string | undefined {
+  if (input.kind === "vcs" || input.kind === "show" || input.kind === "stash-show") {
+    return sourceLabel;
+  }
+  if (input.kind !== "patch") return undefined;
+
+  const patchFile = input.file ?? sourceLabel;
+  const metadata = sourceMetadataForPatch(patchFile);
+  if (typeof metadata?.repo === "string") return metadata.repo;
+  return repoPathFromGitHunkPath(patchFile);
+}
+
+function defaultBranchRange(repo: string): string | null {
+  let baseRef = "";
+  try {
+    baseRef = runGit(repo, ["rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{upstream}"]);
+  } catch {
+    for (const candidate of ["origin/main", "origin/master", "main", "master"]) {
+      try {
+        runGit(repo, ["rev-parse", "--verify", candidate]);
+        baseRef = candidate;
+        break;
+      } catch {
+        // Try next fallback.
+      }
+    }
+  }
+
+  if (!baseRef) return null;
+
+  try {
+    const mergeBase = runGit(repo, ["merge-base", "HEAD", baseRef]);
+    return mergeBase ? `${mergeBase}...HEAD` : "HEAD";
+  } catch {
+    return "HEAD";
+  }
+}
+
+function lastTurnMarker(repo: string, source: LastTurnSource) {
+  const markerName = `hunk/${source.markerBasename}.json`;
+  try {
+    const marker = runGit(repo, ["rev-parse", "--git-path", markerName]);
+    return isAbsolute(marker) ? marker : resolve(repo, marker);
+  } catch {
+    return join(repo, ".git", markerName);
+  }
+}
+
+function resolveMarkerPath(repo: string, value: unknown) {
+  if (typeof value !== "string" || value.trim() === "") return null;
+  return isAbsolute(value) ? value : resolve(repo, value);
+}
+
+function lastTurnInput(
+  source: LastTurnSource,
+  repo: string,
+  options: CommonOptions,
+): ReviewSourceSwitchResult {
+  const markerPath = lastTurnMarker(repo, source);
+  if (!existsSync(markerPath)) {
+    return { kind: "notice", message: `No ${source.label} source for this repo.` };
+  }
+
+  let marker: unknown;
+  try {
+    marker = JSON.parse(readFileSync(markerPath, "utf8"));
+  } catch {
+    return { kind: "notice", message: `${source.label} marker is unreadable.` };
+  }
+
+  if (!marker || typeof marker !== "object") {
+    return { kind: "notice", message: `${source.label} marker is invalid.` };
+  }
+
+  const record = marker as Record<string, unknown>;
+  if (record.kind === "patch") {
+    const file = resolveMarkerPath(repo, record.file);
+    if (!file || !existsSync(file)) {
+      return { kind: "notice", message: `${source.label} patch is missing.` };
+    }
+    persistSourceMetadata(file, { repo, label: source.label, sourceId: source.id });
+    return {
+      kind: "input",
+      input: { kind: "patch", file, options },
+      sourcePath: repo,
+      label: source.label,
+    };
+  }
+
+  return { kind: "notice", message: `${source.label} marker has no supported source.` };
+}
+
+function pullRequestInput(
+  repo: string,
+  number: number,
+  options: CommonOptions,
+): ReviewSourceSwitchResult {
+  let patchText = "";
+  try {
+    patchText = runGh(repo, ["pr", "diff", String(number), "--patch"]);
+  } catch {
+    return { kind: "notice", message: `Could not load PR #${number}.` };
+  }
+
+  if (!patchText) {
+    return { kind: "notice", message: `PR #${number} has no diff.` };
+  }
+
+  const file = pullRequestPatchPath(repo, number);
+  mkdirSync(dirname(file), { recursive: true });
+  writeFileSync(file, `${patchText}\n`);
+  persistSourceMetadata(file, { repo, label: `PR #${number}`, sourceId: `pr:${number}` });
+  return {
+    kind: "input",
+    input: { kind: "patch", file, options },
+    sourcePath: repo,
+    label: `PR #${number}`,
+  };
+}
+
+export function resolveReviewSourceInput(
+  sourceId: ReviewSourceId,
+  repo: string | undefined,
+  options: CommonOptions,
+): ReviewSourceSwitchResult {
+  if (!repo) {
+    return { kind: "notice", message: "Source switching requires a Git-backed Hunk session." };
+  }
+
+  const prNumber = parsePullRequestId(sourceId);
+  if (prNumber !== null) return pullRequestInput(repo, prNumber, options);
+
+  const lastTurn = lastTurnSource(sourceId);
+  if (lastTurn) return lastTurnInput(lastTurn, repo, options);
+
+  switch (sourceId) {
+    case "unstaged":
+      return {
+        kind: "input",
+        input: { kind: "vcs", staged: false, options },
+        sourcePath: repo,
+        label: BASE_SOURCE_LABELS.unstaged,
+      };
+    case "staged":
+      return {
+        kind: "input",
+        input: { kind: "vcs", staged: true, options },
+        sourcePath: repo,
+        label: BASE_SOURCE_LABELS.staged,
+      };
+    case "commit":
+      return {
+        kind: "input",
+        input: { kind: "show", ref: "HEAD", options },
+        sourcePath: repo,
+        label: BASE_SOURCE_LABELS.commit,
+      };
+    case "branch": {
+      const range = defaultBranchRange(repo);
+      if (!range) {
+        return { kind: "notice", message: "No upstream or default branch found." };
+      }
+      return {
+        kind: "input",
+        input: { kind: "vcs", range, staged: false, options },
+        sourcePath: repo,
+        label: BASE_SOURCE_LABELS.branch,
+      };
+    }
+  }
+
+  return { kind: "notice", message: "Unsupported source." };
+}
