@@ -0,0 +1,197 @@
+import { execFileSync } from "node:child_process";
+import { existsSync, readFileSync } from "node:fs";
+import { isAbsolute, join, resolve } from "node:path";
+import type { CliInput, CommonOptions } from "../../core/types";
+
+export type ReviewSourceId = "unstaged" | "staged" | "commit" | "branch" | "pi-last-turn";
+
+export interface ReviewSourceItem {
+  id: ReviewSourceId;
+  label: string;
+  hint: string;
+  active: boolean;
+  enabled: boolean;
+}
+
+export type ReviewSourceSwitchResult =
+  | { kind: "input"; input: CliInput; sourcePath?: string }
+  | { kind: "notice"; message: string };
+
+const SOURCE_LABELS: Record<ReviewSourceId, string> = {
+  unstaged: "Unstaged",
+  staged: "Staged",
+  commit: "Commit",
+  branch: "Branch",
+  "pi-last-turn": "Last Pi turn",
+};
+
+const SOURCE_HINTS: Record<ReviewSourceId, string> = {
+  unstaged: "u",
+  staged: "s",
+  commit: "c",
+  branch: "b",
+  "pi-last-turn": "p",
+};
+
+export const REVIEW_SOURCE_ORDER: ReviewSourceId[] = [
+  "unstaged",
+  "staged",
+  "commit",
+  "branch",
+  "pi-last-turn",
+];
+
+function runGit(repo: string, args: string[]) {
+  return execFileSync("git", args, {
+    cwd: repo,
+    encoding: "utf8",
+    stdio: ["ignore", "pipe", "ignore"],
+  }).trim();
+}
+
+export function reviewSourceLabel(id: ReviewSourceId) {
+  return SOURCE_LABELS[id];
+}
+
+export function activeReviewSource(input: CliInput): ReviewSourceId | null {
+  if (input.kind === "show") return "commit";
+  if (input.kind !== "vcs") return null;
+  if (input.staged) return "staged";
+  if (input.range) return "branch";
+  return "unstaged";
+}
+
+export function buildReviewSourceItems(input: CliInput): ReviewSourceItem[] {
+  const active = activeReviewSource(input);
+  return REVIEW_SOURCE_ORDER.map((id) => ({
+    id,
+    label: SOURCE_LABELS[id],
+    hint: SOURCE_HINTS[id],
+    active: active === id,
+    enabled: true,
+  }));
+}
+
+export function repoPathForInput(input: CliInput, sourceLabel: string): string | undefined {
+  if (input.kind === "vcs" || input.kind === "show" || input.kind === "stash-show") {
+    return sourceLabel;
+  }
+  return undefined;
+}
+
+function defaultBranchRange(repo: string): string | null {
+  let baseRef = "";
+  try {
+    baseRef = runGit(repo, ["rev-parse", "--abbrev-ref", "--symbolic-full-name", "@{upstream}"]);
+  } catch {
+    for (const candidate of ["origin/main", "origin/master", "main", "master"]) {
+      try {
+        runGit(repo, ["rev-parse", "--verify", candidate]);
+        baseRef = candidate;
+        break;
+      } catch {
+        // Try next fallback.
+      }
+    }
+  }
+
+  if (!baseRef) return null;
+
+  try {
+    const mergeBase = runGit(repo, ["merge-base", "HEAD", baseRef]);
+    return mergeBase ? `${mergeBase}...HEAD` : "HEAD";
+  } catch {
+    return "HEAD";
+  }
+}
+
+function piLastTurnMarker(repo: string) {
+  try {
+    const marker = runGit(repo, ["rev-parse", "--git-path", "hunk/last-pi-turn.json"]);
+    return isAbsolute(marker) ? marker : resolve(repo, marker);
+  } catch {
+    return join(repo, ".git", "hunk", "last-pi-turn.json");
+  }
+}
+
+function resolveMarkerPath(repo: string, value: unknown) {
+  if (typeof value !== "string" || value.trim() === "") return null;
+  return isAbsolute(value) ? value : resolve(repo, value);
+}
+
+function piLastTurnInput(repo: string, options: CommonOptions): ReviewSourceSwitchResult {
+  const markerPath = piLastTurnMarker(repo);
+  if (!existsSync(markerPath)) {
+    return { kind: "notice", message: "No Last Pi turn source for this repo." };
+  }
+
+  let marker: unknown;
+  try {
+    marker = JSON.parse(readFileSync(markerPath, "utf8"));
+  } catch {
+    return { kind: "notice", message: "Last Pi turn marker is unreadable." };
+  }
+
+  if (!marker || typeof marker !== "object") {
+    return { kind: "notice", message: "Last Pi turn marker is invalid." };
+  }
+
+  const record = marker as Record<string, unknown>;
+  if (record.kind === "patch") {
+    const file = resolveMarkerPath(repo, record.file);
+    if (!file || !existsSync(file)) {
+      return { kind: "notice", message: "Last Pi turn patch is missing." };
+    }
+    return { kind: "input", input: { kind: "patch", file, options } };
+  }
+
+  if (record.kind === "vcs") {
+    return {
+      kind: "input",
+      input: {
+        kind: "vcs",
+        range: typeof record.range === "string" ? record.range : undefined,
+        staged: record.staged === true,
+        pathspecs: Array.isArray(record.pathspecs)
+          ? record.pathspecs.filter((item): item is string => typeof item === "string")
+          : undefined,
+        options,
+      },
+      sourcePath: repo,
+    };
+  }
+
+  return { kind: "notice", message: "Last Pi turn marker has no supported source." };
+}
+
+export function resolveReviewSourceInput(
+  sourceId: ReviewSourceId,
+  repo: string | undefined,
+  options: CommonOptions,
+): ReviewSourceSwitchResult {
+  if (!repo) {
+    return { kind: "notice", message: "Source switching requires a Git-backed Hunk session." };
+  }
+
+  switch (sourceId) {
+    case "unstaged":
+      return { kind: "input", input: { kind: "vcs", staged: false, options }, sourcePath: repo };
+    case "staged":
+      return { kind: "input", input: { kind: "vcs", staged: true, options }, sourcePath: repo };
+    case "commit":
+      return { kind: "input", input: { kind: "show", ref: "HEAD", options }, sourcePath: repo };
+    case "branch": {
+      const range = defaultBranchRange(repo);
+      if (!range) {
+        return { kind: "notice", message: "No upstream or default branch found." };
+      }
+      return {
+        kind: "input",
+        input: { kind: "vcs", range, staged: false, options },
+        sourcePath: repo,
+      };
+    }
+    case "pi-last-turn":
+      return piLastTurnInput(repo, options);
+  }
+}
