+pub(super) fn run_hunk_command(args: &[String]) -> std::io::Result<i32> {
+    let mut open_tab = false;
+    let mut mode = HunkMode::Worktree;
+    let mut passthrough = Vec::new();
+    let mut index = 0;
+
+    while index < args.len() {
+        match args[index].as_str() {
+            "--tab" => {
+                open_tab = true;
+                index += 1;
+            }
+            "--staged" | "--cached" => {
+                mode = HunkMode::Staged;
+                index += 1;
+            }
+            "--branch-committed" => {
+                mode = HunkMode::BranchCommitted;
+                index += 1;
+            }
+            "--" => {
+                passthrough.extend(args[index + 1..].iter().cloned());
+                break;
+            }
+            "-h" | "--help" => {
+                print_hunk_help();
+                return Ok(0);
+            }
+            other => {
+                passthrough.push(other.to_string());
+                index += 1;
+            }
+        }
+    }
+
+    let context = active_context()?;
+    let command = hunk_command(mode, &passthrough, &context.cwd);
+    let target_pane = if open_tab {
+        let response = super::send_request(&Request {
+            id: "cli:hunk:tab:create".into(),
+            method: Method::TabCreate(TabCreateParams {
+                workspace_id: Some(context.workspace_id),
+                cwd: Some(context.cwd.display().to_string()),
+                focus: true,
+                label: Some("hunk".into()),
+            }),
+        })?;
+        response_string_path(&response, &["result", "root_pane", "pane_id"]).ok_or_else(|| {
+            std::io::Error::other("tab.create response did not include root_pane.pane_id")
+        })?
+    } else {
+        let response = super::send_request(&Request {
+            id: "cli:hunk:pane:split".into(),
+            method: Method::PaneSplit(PaneSplitParams {
+                workspace_id: Some(context.workspace_id),
+                target_pane_id: context.pane_id,
+                direction: SplitDirection::Right,
+                cwd: Some(context.cwd.display().to_string()),
+                focus: true,
+            }),
+        })?;
+        response_string_path(&response, &["result", "pane", "pane_id"]).ok_or_else(|| {
+            std::io::Error::other("pane.split response did not include pane.pane_id")
+        })?
+    };
+
+    send_pane_run(&target_pane, &command)
+}
+
+pub(super) fn run_worktree_layout_command(args: &[String]) -> std::io::Result<i32> {
+    let mut no_pi = false;
+    let mut no_hunk = false;
+    let mut no_nvim = false;
+    let mut branch = None;
+
+    for arg in args {
+        match arg.as_str() {
+            "--no-pi" => no_pi = true,
+            "--no-hunk" => no_hunk = true,
+            "--no-nvim" => no_nvim = true,
+            "-h" | "--help" => {
+                print_worktree_layout_help();
+                return Ok(0);
+            }
+            value if value.starts_with('-') => {
+                eprintln!("unknown option: {value}");
+                return Ok(2);
+            }
+            value => {
+                if branch.is_some() {
+                    eprintln!(
+                        "usage: herdr worktree layout [--no-pi] [--no-hunk] [--no-nvim] [branch]"
+                    );
+                    return Ok(2);
+                }
+                branch = Some(value.to_string());
+            }
+        }
+    }
+
+    let created = if let Some(path) = std::env::var_os("HERDR_CREATED_WORKTREE_PATH") {
+        CreatedWorktree {
+            workspace_id: env_or("HERDR_CREATED_WORKSPACE_ID", "HERDR_ACTIVE_WORKSPACE_ID")
+                .ok_or_else(|| std::io::Error::other("missing HERDR_CREATED_WORKSPACE_ID"))?,
+            root_tab_id: std::env::var("HERDR_CREATED_ROOT_TAB_ID").ok(),
+            root_pane_id: std::env::var("HERDR_CREATED_ROOT_PANE_ID").ok(),
+            path: PathBuf::from(path),
+        }
+    } else {
+        let branch = branch.ok_or_else(|| {
+            std::io::Error::new(
+                std::io::ErrorKind::InvalidInput,
+                "branch is required outside Herdr's native worktree post-create hook",
+            )
+        })?;
+        create_worktree_from_branch(&branch)?
+    };
+
+    if !no_pi && command_exists("pi") {
+        let pane_id = create_tab(&created.workspace_id, &created.path, "pi")?;
+        rename_pane(&pane_id, "pi")?;
+        send_pane_run(&pane_id, "pi")?;
+    }
+    if !no_hunk {
+        let pane_id = create_tab(&created.workspace_id, &created.path, "hunk")?;
+        rename_pane(&pane_id, "hunk")?;
+        send_pane_run(
+            &pane_id,
+            &hunk_command(HunkMode::Worktree, &[], &created.path),
+        )?;
+    }
+    if !no_nvim {
+        let pane_id = create_tab(&created.workspace_id, &created.path, "nvim")?;
+        rename_pane(&pane_id, "nvim")?;
+        send_pane_run(&pane_id, "nvim .")?;
+    }
+
+    let shell_pane = create_tab(&created.workspace_id, &created.path, "shell")?;
+    rename_pane(&shell_pane, "shell")?;
+
+    if let Some(tab_id) = created.root_tab_id {
+        let _ = super::send_ok_request(Method::TabClose(TabTarget { tab_id }));
+    } else if let Some(pane_id) = created.root_pane_id {
+        let _ = super::send_ok_request(Method::PaneClose(PaneTarget { pane_id }));
+    }
+
+    super::send_ok_request(Method::WorkspaceFocus(
+        crate::api::schema::WorkspaceTarget {
+            workspace_id: created.workspace_id,
+        },
+    ))
+}
+
+struct ActiveContext {
+    pane_id: String,
+    workspace_id: String,
+    cwd: PathBuf,
+}
+
+struct CreatedWorktree {
+    workspace_id: String,
+    root_tab_id: Option<String>,
+    root_pane_id: Option<String>,
+    path: PathBuf,
+}
+
+#[derive(Clone, Copy)]
+enum HunkMode {
+    Worktree,
+    Staged,
+    BranchCommitted,
+}
+
+fn active_context() -> std::io::Result<ActiveContext> {
+    if let (Ok(pane_id), Ok(workspace_id)) = (
+        std::env::var("HERDR_ACTIVE_PANE_ID"),
+        std::env::var("HERDR_ACTIVE_WORKSPACE_ID"),
+    ) {
+        let cwd = std::env::var_os("HERDR_ACTIVE_PANE_CWD")
+            .map(PathBuf::from)
+            .unwrap_or(std::env::current_dir()?);
+        return Ok(ActiveContext {
+            pane_id,
+            workspace_id,
+            cwd,
+        });
+    }
+
+    let response = super::send_request(&Request {
+        id: "cli:hunk:pane:list".into(),
+        method: Method::PaneList(PaneListParams { workspace_id: None }),
+    })?;
+    let panes = response["result"]["panes"]
+        .as_array()
+        .ok_or_else(|| std::io::Error::other("pane.list response did not include result.panes"))?;
+    let pane = panes
+        .iter()
+        .find(|pane| pane["focused"].as_bool().unwrap_or(false))
+        .ok_or_else(|| std::io::Error::other("could not determine the active Herdr pane"))?;
+    let pane_id = pane["pane_id"]
+        .as_str()
+        .ok_or_else(|| std::io::Error::other("focused pane missing pane_id"))?
+        .to_string();
+    let workspace_id = pane["workspace_id"]
+        .as_str()
+        .ok_or_else(|| std::io::Error::other("focused pane missing workspace_id"))?
+        .to_string();
+    let cwd = pane["cwd"]
+        .as_str()
+        .map(PathBuf::from)
+        .unwrap_or(std::env::current_dir()?);
+    Ok(ActiveContext {
+        pane_id,
+        workspace_id,
+        cwd,
+    })
+}
+
+fn focused_workspace_id() -> std::io::Result<String> {
+    if let Ok(workspace_id) = std::env::var("HERDR_ACTIVE_WORKSPACE_ID") {
+        return Ok(workspace_id);
+    }
+    let response = super::send_request(&Request {
+        id: "cli:layout:workspace:list".into(),
+        method: Method::WorkspaceList(EmptyParams::default()),
+    })?;
+    let workspaces = response["result"]["workspaces"].as_array().ok_or_else(|| {
+        std::io::Error::other("workspace.list response did not include result.workspaces")
+    })?;
+    let workspace = workspaces
+        .iter()
+        .find(|workspace| workspace["focused"].as_bool().unwrap_or(false))
+        .ok_or_else(|| std::io::Error::other("no focused Herdr workspace found"))?;
+    response_string_path(workspace, &["workspace_id"])
+        .ok_or_else(|| std::io::Error::other("focused workspace missing workspace_id"))
+}
+
+fn create_worktree_from_branch(branch: &str) -> std::io::Result<CreatedWorktree> {
+    let workspace_id = focused_workspace_id()?;
+    let response = super::send_request(&Request {
+        id: "cli:layout:worktree:create".into(),
+        method: Method::WorktreeCreate(WorktreeCreateParams {
+            workspace_id: Some(workspace_id),
+            cwd: None,
+            branch: Some(branch.to_string()),
+            base: None,
+            path: None,
+            label: None,
+            focus: true,
+        }),
+    })?;
+    if response.get("error").is_some() {
+        eprintln!("{}", serde_json::to_string(&response).unwrap());
+        return Err(std::io::Error::other("worktree.create failed"));
+    }
+
+    let workspace_id = response_string_path(&response, &["result", "workspace", "workspace_id"])
+        .ok_or_else(|| {
+            std::io::Error::other("worktree.create response missing workspace.workspace_id")
+        })?;
+    let root_tab_id = response_string_path(&response, &["result", "tab", "tab_id"]);
+    let root_pane_id = response_string_path(&response, &["result", "root_pane", "pane_id"]);
+    let path = response_string_path(&response, &["result", "worktree", "path"])
+        .or_else(|| response_string_path(&response, &["result", "root_pane", "cwd"]))
+        .ok_or_else(|| std::io::Error::other("worktree.create response missing worktree path"))?;
+
+    Ok(CreatedWorktree {
+        workspace_id,
+        root_tab_id,
+        root_pane_id,
+        path: PathBuf::from(path),
+    })
+}
+
+fn create_tab(workspace_id: &str, cwd: &Path, label: &str) -> std::io::Result<String> {
+    let response = super::send_request(&Request {
+        id: format!("cli:layout:tab:create:{label}"),
+        method: Method::TabCreate(TabCreateParams {
+            workspace_id: Some(workspace_id.to_string()),
+            cwd: Some(cwd.display().to_string()),
+            focus: true,
+            label: Some(label.to_string()),
+        }),
+    })?;
+    response_string_path(&response, &["result", "root_pane", "pane_id"]).ok_or_else(|| {
+        std::io::Error::other(format!(
+            "tab.create response for {label:?} missing root_pane.pane_id"
+        ))
+    })
+}
+
+fn rename_pane(pane_id: &str, label: &str) -> std::io::Result<i32> {
+    super::send_ok_request(Method::PaneRename(crate::api::schema::PaneRenameParams {
+        pane_id: pane_id.to_string(),
+        label: Some(label.to_string()),
+    }))
+}
+
+fn send_pane_run(pane_id: &str, command: &str) -> std::io::Result<i32> {
+    super::send_ok_request(Method::PaneSendInput(
+        crate::api::schema::PaneSendInputParams {
+            pane_id: pane_id.to_string(),
+            text: command.to_string(),
+            keys: vec!["Enter".into()],
+        },
+    ))
+}
+
+fn hunk_command(mode: HunkMode, passthrough: &[String], cwd: &Path) -> String {
+    let executable = if command_exists("hunk") {
+        "hunk"
+    } else {
+        "bunx hunkdiff"
+    };
+    let mut args = Vec::new();
+    match mode {
+        HunkMode::Worktree => args.push("diff".to_string()),
+        HunkMode::Staged => args.extend(["diff".to_string(), "--staged".to_string()]),
+        HunkMode::BranchCommitted => args.extend(branch_committed_args(cwd)),
+    }
+    args.extend(passthrough.iter().map(|arg| shell_quote(arg)));
+    if args.is_empty() {
+        executable.to_string()
+    } else {
+        format!("{executable} {}", args.join(" "))
+    }
+}
+
+fn branch_committed_args(cwd: &Path) -> Vec<String> {
+    let branch = git_output(cwd, &["branch", "--show-current"])
+        .filter(|branch| !branch.is_empty())
+        .unwrap_or_else(|| "HEAD".into());
+    let upstream = git_output(
+        cwd,
+        &[
+            "rev-parse",
+            "--abbrev-ref",
+            "--symbolic-full-name",
+            "@{upstream}",
+        ],
+    )
+    .or_else(|| default_base_ref(cwd))
+    .unwrap_or_else(|| "origin/main".into());
+    vec!["diff".into(), format!("{upstream}..{branch}")]
+}
+
+fn default_base_ref(cwd: &Path) -> Option<String> {
+    for candidate in ["origin/main", "origin/master", "main", "master"] {
+        if git_output(cwd, &["rev-parse", "--verify", candidate]).is_some() {
+            return Some(candidate.into());
+        }
+    }
+    None
+}
+
+fn git_output(cwd: &Path, args: &[&str]) -> Option<String> {
+    let output = std::process::Command::new("git")
+        .args(args)
+        .current_dir(cwd)
+        .output()
+        .ok()?;
+    if !output.status.success() {
+        return None;
+    }
+    Some(String::from_utf8_lossy(&output.stdout).trim().to_string())
+}
+
+fn command_exists(command: &str) -> bool {
+    std::env::var_os("PATH")
+        .is_some_and(|paths| std::env::split_paths(&paths).any(|path| path.join(command).is_file()))
+}
+
+fn env_or(primary: &str, fallback: &str) -> Option<String> {
+    std::env::var(primary)
+        .ok()
+        .or_else(|| std::env::var(fallback).ok())
+}
+
+fn response_string_path(value: &serde_json::Value, path: &[&str]) -> Option<String> {
+    let mut cursor = value;
+    for segment in path {
+        cursor = cursor.get(*segment)?;
+    }
+    cursor.as_str().map(ToString::to_string)
+}
+
+fn shell_quote(value: &str) -> String {
+    if value.bytes().all(|byte| {
+        byte.is_ascii_alphanumeric() || matches!(byte, b'_' | b'-' | b'.' | b'/' | b':' | b'=')
+    }) {
+        value.to_string()
+    } else {
+        format!("'{}'", value.replace('\'', "'\\''"))
+    }
+}
+
+fn print_hunk_help() {
+    eprintln!("usage: herdr hunk [--tab] [--staged|--cached|--branch-committed] [-- HUNK_ARGS...]");
+}
+
+fn print_worktree_layout_help() {
+    eprintln!("usage: herdr worktree layout [--no-pi] [--no-hunk] [--no-nvim] [branch]");
+}
