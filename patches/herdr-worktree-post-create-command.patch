+    fn spawn_worktree_post_create_command(
+        &self,
+        ws_idx: usize,
+        root_pane: crate::layout::PaneId,
+        path: &std::path::Path,
+    ) {
+        let command_text = self.state.worktree_post_create_command.trim();
+        if command_text.is_empty() {
+            return;
+        }
+
+        let mut command = std::process::Command::new("/bin/sh");
+        command
+            .arg("-lc")
+            .arg(command_text)
+            .stdin(std::process::Stdio::null())
+            .stdout(std::process::Stdio::null())
+            .stderr(std::process::Stdio::null())
+            .current_dir(path);
+
+        command.env(crate::api::SOCKET_PATH_ENV_VAR, crate::api::socket_path());
+        if let Ok(current_exe) = std::env::current_exe() {
+            command.env("HERDR_BIN_PATH", current_exe);
+        }
+        command.env(
+            "HERDR_ACTIVE_WORKSPACE_ID",
+            self.public_workspace_id(ws_idx),
+        );
+        command.env(
+            "HERDR_CREATED_WORKSPACE_ID",
+            self.public_workspace_id(ws_idx),
+        );
+        command.env("HERDR_CREATED_WORKTREE_PATH", path);
+        if let Some(tab_id) = self.public_tab_id(ws_idx, 0) {
+            command.env("HERDR_CREATED_ROOT_TAB_ID", tab_id);
+        }
+        if let Some(pane_id) = self.public_pane_id(ws_idx, root_pane) {
+            command.env("HERDR_CREATED_ROOT_PANE_ID", pane_id);
+        }
+
+        if let Err(err) = command.spawn() {
+            tracing::warn!(error = %err, "failed to spawn worktree post-create command");
+        }
+    }
