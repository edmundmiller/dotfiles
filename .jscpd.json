{
  "threshold": 10,
  "reporters": ["console", "json"],
  "ignore": [
    "**/.git/**",
    "**/node_modules/**",
    "**/dist/**",
    "**/build/**",
    "**/target/**",
    "**/.beads/**",
    "**/.direnv/**",
    "**/.pi/**",
    "**/result/**",
    "**/.jscpd-report/**",
    "flake.lock",
    "**/package-lock.json",
    "**/bun.lock",
    "**/*.lock",
    "**/*.md5",
    "**/*.hex"
  ],
  "format": ["typescript", "javascript", "nix"],
  "min-lines": 5,
  "min-tokens": 50,
  "max-lines": 500,
  "max-size": "100kb",
  "mode": "strict",
  "blame": false,
  "silent": false,
  "absolute": false,
  "noSymlinks": true,
  "skipLocal": false,
  "gitignore": true,
  "output": ".jscpd-report"
}
